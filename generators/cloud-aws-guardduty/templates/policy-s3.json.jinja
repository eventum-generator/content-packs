{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, remote_ip_block, severity_block, service_meta, event_block, rule_block, s3bucket_resource_block, detector_id, finding_arn -%}
{%- set account = samples.accounts | random -%}
{%- set region = samples.regions | random -%}
{%- set user = samples.users | random -%}
{%- set actor = samples.threat_actors | random -%}
{%- set bucket = samples.buckets | random -%}
{%- set det_id = detector_id(account) -%}
{%- set finding_id = module.rand.string.hex(32) -%}
{%- set f_arn = finding_arn(account, region, det_id, finding_id) -%}
{%- set finding_count = module.rand.number.integer(1, 5) -%}
{%- set first_seen = (timestamp - module.datetime.timedelta(hours=module.rand.number.integer(1, 24))).strftime('%Y-%m-%dT%H:%M:%S.000Z') -%}
{%- set last_seen = timestamp.strftime('%Y-%m-%dT%H:%M:%S.000Z') -%}
{%- set finding_type_name = module.rand.weighted_choice(["Policy:S3/BucketBlockPublicAccessDisabled", "Policy:S3/AccountBlockPublicAccessDisabled", "Policy:S3/BucketAnonymousAccessGranted"], [40, 30, 30]) -%}
{%- set finding_types_map = {} -%}
{%- for ft in samples.finding_types -%}
    {%- do finding_types_map.update({ft.type: ft}) -%}
{%- endfor -%}
{%- set finding_type = finding_types_map[finding_type_name] -%}
{%- set api_name = module.rand.choice(["PutBucketPublicAccessBlock", "DeleteBucketPublicAccessBlock", "PutBucketPolicy", "PutBucketAcl"]) -%}
{
    "@timestamp": "{{ last_seen }}",
    {{ agent_block(params) }},
    "aws": {
        "guardduty": {
            "account_id": "{{ account.account_id }}",
            "arn": "{{ f_arn }}",
            "created_at": "{{ first_seen }}",
            "description": "{{ finding_type.description | replace('{bucket_name}', bucket.bucket_name) | replace('{user_name}', user.username) | replace('{account_id}', account.account_id) }}",
            "id": "{{ finding_id }}",
            "partition": "aws",
            "region": "{{ region.region_code }}",
            {{ s3bucket_resource_block(bucket, account) }},
            "schema_version": "2.0",
            "service": {
                "action": {
                    "aws_api_call_action": {
                        "api": "{{ api_name }}",
                        "caller_type": "remoteIp",
                        {{ remote_ip_block(actor) }},
                        "service_name": "s3.amazonaws.com",
                        "user_agent": "{{ module.rand.weighted_choice(['aws-cli/2.15.0 Python/3.11.6 Linux/5.15.0', 'aws-sdk-java/2.20.0 Linux/5.15.0', 'console.amazonaws.com', 'Boto3/1.28.0 Python/3.11.6 Linux/5.15.0', 'aws-sdk-go/1.44.0 (go1.19; linux; amd64)'], [30, 20, 25, 15, 10]) }}"
                    },
                    "type": "AWS_API_CALL"
                },
                "additional_info": {
                    "type": "default",
                    "value": "{}"
                },
                {{ service_meta(det_id, finding_count, first_seen, last_seen, "TARGET") }}
            },
            {{ severity_block(finding_type.severity_code, finding_type.severity_value) }},
            "title": "{{ finding_type.title | replace('{bucket_name}', bucket.bucket_name) }}",
            "type": "{{ finding_type.type }}",
            "updated_at": "{{ last_seen }}"
        }
    },
    {{ cloud_block(account, region) }},
    {{ ecs_block() }},
    {{ event_block(finding_type, finding_id, finding_type.severity_code, first_seen, last_seen) }},
    "message": "{{ finding_type.description | replace('{bucket_name}', bucket.bucket_name) | replace('{user_name}', user.username) | replace('{account_id}', account.account_id) }}",
    "related": {
        "ip": ["{{ actor.ip }}"],
        "user": ["{{ user.username }}"]
    },
    {{ rule_block(finding_type) }},
    "source": {
        "address": ["{{ actor.ip }}"],
        "as": {
            "number": [{{ actor.asn }}],
            "organization": {
                "name": ["{{ actor.asn_org }}"]
            }
        },
        "geo": {
            "city_name": "{{ actor.city }}",
            "country_iso_code": "{{ actor.country_code }}",
            "country_name": "{{ actor.country_name }}",
            "location": {
                "lat": {{ actor.lat }},
                "lon": {{ actor.lon }}
            }
        },
        "ip": ["{{ actor.ip }}"]
    },
    "user": {
        "id": "{{ user.principal_id }}",
        "name": "{{ user.username }}"
    }
}
