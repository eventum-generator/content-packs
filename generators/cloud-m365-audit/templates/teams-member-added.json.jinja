{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, event_block, source_block, user_block, organization_block, related_block, o365_base_block, pick_user_agent, pick_source_ip, user_type_value, record_type_for_workload -%}
{#- Actor (person adding) -#}
{%- set actor = samples.users | random -%}
{#- Target (person being added) -#}
{%- set target = samples.users | random -%}
{%- set org = samples.organizations | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{#- Pick a team -#}
{%- set team = samples.teams.weighted_pick('weight') -%}
{%- set ua_type = module.rand.weighted_choice(["teams_desktop", "browser_windows"], [60, 40]) -%}
{%- set ua_value = pick_user_agent(ua_type, samples.user_agents) -%}
{%- set operation = "MemberAdded" -%}
{%- set workload = "MicrosoftTeams" -%}
{%- set rec_type = record_type_for_workload(workload, operation) -%}
{%- set ut_val = user_type_value(actor) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block() }},
    {{ ecs_block() }},
    {{ event_block(operation, ["iam"], event_id, "success", ["change"]) }},
    {{ source_block(src_ip) }},
    {{ user_block(actor) }},
    "user_agent": {
        "original": {{ ua_value | tojson }}
    },
    {{ organization_block(org) }},
    {{ related_block([src_ip], [actor.upn.split('@')[0], actor.upn, target.upn.split('@')[0]]) }},
    "o365": {
        "audit": {
            {{ o365_base_block(audit_id, rec_type, "Succeeded", operation, workload, actor, src_ip, team.team_id, ut_val) }},
            "user_agent": {{ ua_value | tojson }},
            "teams": {
                "team_name": {{ team.team_name | tojson }},
                "team_id": "{{ team.team_id }}",
                "members": [
                    {
                        "id": "{{ target.object_id }}",
                        "upn": "{{ target.upn }}",
                        "display_name": "{{ target.display_name }}",
                        "role": "{{ module.rand.weighted_choice(["Member", "Owner", "Guest"], [80, 10, 10]) }}"
                    }
                ],
                "added_by": {
                    "id": "{{ actor.object_id }}",
                    "upn": "{{ actor.upn }}"
                }
            }
        }
    }
}
