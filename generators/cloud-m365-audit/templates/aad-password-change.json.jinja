{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, event_block, source_block, user_block, organization_block, related_block, o365_base_block, pick_source_ip, user_type_value, record_type_for_workload -%}
{%- set user = samples.users | random -%}
{%- set org = samples.organizations | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{%- set correlation_id = module.rand.crypto.uuid4() -%}
{%- set operation = "Change user password." -%}
{%- set workload = "AzureActiveDirectory" -%}
{%- set rec_type = record_type_for_workload(workload, operation) -%}
{%- set ut_val = user_type_value(user) -%}
{#- 95% success, 5% failure -#}
{%- set is_success = module.rand.chance(0.95) -%}
{%- set outcome = "success" if is_success else "failure" -%}
{%- set result_status = "Succeeded" if is_success else "Failed" -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block() }},
    {{ ecs_block() }},
    {{ event_block(operation, ["iam"], event_id, outcome, ["change"]) }},
    {{ source_block(src_ip) }},
    {{ user_block(user) }},
    {{ organization_block(org) }},
    {{ related_block([src_ip], [user.upn.split('@')[0], user.upn]) }},
    "o365": {
        "audit": {
            {{ o365_base_block(audit_id, rec_type, result_status, operation, workload, user, src_ip, user.upn, ut_val) }},
            "actor": [
                {
                    "id": "{{ user.object_id }}",
                    "type": 0
                },
                {
                    "id": "{{ user.upn }}",
                    "type": 5
                }
            ],
            "target": [
                {
                    "id": "{{ user.object_id }}",
                    "type": 0
                },
                {
                    "id": "{{ user.upn }}",
                    "type": 5
                },
                {
                    "id": "{{ user.display_name }}",
                    "type": 1
                }
            ],
            "modified_properties": [
                {
                    "name": "Included Updated Properties",
                    "new_value": "StrongAuthenticationMethod, StrongAuthenticationPhoneAppDetail, LastPasswordChangeTimestamp"
                },
                {
                    "name": "LastPasswordChangeTimestamp",
                    "new_value": {{ timestamp.isoformat() | tojson }}
                }
            ],
            "correlation_id": "{{ correlation_id }}"
        }
    }
}
