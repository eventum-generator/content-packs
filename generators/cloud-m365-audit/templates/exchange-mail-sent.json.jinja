{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, event_block, source_block, user_block, organization_block, related_block, o365_base_block, pick_user_agent, pick_source_ip, user_type_value, record_type_for_workload -%}
{%- set user = samples.users | random -%}
{%- set org = samples.organizations | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{%- set mailbox_guid = module.rand.crypto.uuid4() -%}
{%- set session_id = module.rand.crypto.uuid4() -%}
{%- set message_id = "<" ~ module.rand.string.hex(12) ~ "@" ~ org.domain ~ ">" -%}
{#- Pick a recipient (another user in the org or external) -#}
{%- set is_external = module.rand.chance(0.2) -%}
{%- if is_external -%}
    {%- set external_domains = ["partner.com", "vendor.io", "client.org", "consultant.net", "agency.co"] -%}
    {%- set recipient_name = module.rand.choice(["contact", "info", "support", "billing", "orders"]) -%}
    {%- set recipient = recipient_name ~ "@" ~ module.rand.choice(external_domains) -%}
{%- else -%}
    {%- set recipient_user = samples.users | random -%}
    {%- set recipient = recipient_user.upn -%}
{%- endif -%}
{%- set ua_type = module.rand.weighted_choice(["outlook_desktop", "outlook_mobile", "browser_windows"], [50, 20, 30]) -%}
{%- set ua_value = pick_user_agent(ua_type, samples.user_agents) -%}
{%- set subjects = ["Re: Project Update", "Meeting Notes", "Document Review Request", "FYI: Schedule Change", "Invitation: " ~ module.rand.choice(["Sprint Planning", "Design Review", "1:1 Meeting", "Team Sync"]), "Action Required: " ~ module.rand.choice(["Approve PR", "Review Doc", "Sign Off", "Confirm Budget"]), "Question about " ~ module.rand.choice(["deployment", "timeline", "requirements", "access"])] -%}
{%- set subject = module.rand.choice(subjects) -%}
{%- set operation = "Send" -%}
{%- set workload = "Exchange" -%}
{%- set rec_type = record_type_for_workload(workload, operation) -%}
{%- set ut_val = user_type_value(user) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block() }},
    {{ ecs_block() }},
    {{ event_block(operation, ["email"], event_id, "success", ["creation"]) }},
    {{ source_block(src_ip) }},
    {{ user_block(user) }},
    "user_agent": {
        "original": {{ ua_value | tojson }}
    },
    {{ organization_block(org) }},
    {{ related_block([src_ip], [user.upn.split('@')[0], user.upn]) }},
    "o365": {
        "audit": {
            {{ o365_base_block(audit_id, rec_type, "Succeeded", operation, workload, user, src_ip, user.upn, ut_val) }},
            "user_agent": {{ ua_value | tojson }},
            "item": {
                "subject": {{ subject | tojson }},
                "internet_message_id": {{ message_id | tojson }},
                "parent_folder": {
                    "name": "Sent Items"
                }
            },
            "affected_items": [
                {
                    "subject": {{ subject | tojson }},
                    "internet_message_id": {{ message_id | tojson }}
                }
            ],
            "recipients": [{{ recipient | tojson }}],
            "logon_type": 0,
            "mailbox_guid": "{{ mailbox_guid }}",
            "mailbox_owner_upn": "{{ user.upn }}",
            "session_id": "{{ session_id }}",
            "client_info_string": {{ ua_value | tojson }},
            "external_access": {{ is_external | tojson | lower }}
        }
    }
}
