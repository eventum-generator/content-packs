{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, event_block, source_block, user_block, organization_block, related_block, o365_base_block, pick_user_agent, pick_source_ip, user_type_value, record_type_for_workload -%}
{%- set user = samples.users | random -%}
{%- set org = samples.organizations | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{%- set meeting_id = module.rand.crypto.uuid4() -%}
{%- set thread_id = "19:meeting_" ~ module.rand.string.hex(16) ~ "@thread.v2" -%}
{#- Meeting organizer -#}
{%- set organizer = samples.users | random -%}
{%- set ua_type = module.rand.weighted_choice(["teams_desktop", "teams_mobile", "browser_windows"], [60, 20, 20]) -%}
{%- set ua_value = pick_user_agent(ua_type, samples.user_agents) -%}
{%- set operation = "MeetingParticipantJoined" -%}
{%- set workload = "MicrosoftTeams" -%}
{%- set rec_type = record_type_for_workload(workload, operation) -%}
{%- set ut_val = user_type_value(user) -%}
{%- set meeting_subjects = ["Sprint Planning", "Daily Standup", "Design Review", "Architecture Discussion", "1:1 with Manager", "Project Alpha Sync", "All Hands Meeting", "Budget Review", "Customer Demo", "Interview - Software Engineer", "Retrospective", "Quarterly Business Review"] -%}
{%- set meeting_subject = module.rand.choice(meeting_subjects) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block() }},
    {{ ecs_block() }},
    {{ event_block(operation, ["session"], event_id, "success", ["start"]) }},
    {{ source_block(src_ip) }},
    {{ user_block(user) }},
    "user_agent": {
        "original": {{ ua_value | tojson }}
    },
    {{ organization_block(org) }},
    {{ related_block([src_ip], [user.upn.split('@')[0], user.upn, organizer.upn.split('@')[0]]) }},
    "o365": {
        "audit": {
            {{ o365_base_block(audit_id, rec_type, "Succeeded", operation, workload, user, src_ip, thread_id, ut_val) }},
            "user_agent": {{ ua_value | tojson }},
            "teams": {
                "meeting_id": "{{ meeting_id }}",
                "meeting_type": "{{ module.rand.weighted_choice(["Scheduled", "Adhoc", "Recurring"], [60, 20, 20]) }}",
                "meeting_detail": {
                    "subject": {{ meeting_subject | tojson }},
                    "organizer": "{{ organizer.upn }}",
                    "thread_id": {{ thread_id | tojson }}
                },
                "participant": {
                    "id": "{{ user.object_id }}",
                    "upn": "{{ user.upn }}",
                    "display_name": "{{ user.display_name }}",
                    "role": "{{ module.rand.weighted_choice(["Presenter", "Attendee"], [30, 70]) }}"
                }
            }
        }
    }
}
