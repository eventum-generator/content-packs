{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, event_block, source_block, user_block, organization_block, related_block, o365_base_block, pick_user_agent, pick_source_ip, user_type_value, record_type_for_workload -%}
{%- set user = samples.users | random -%}
{%- set org = samples.organizations | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{%- set correlation_id = module.rand.crypto.uuid4() -%}
{#- User agent: mostly browsers and Outlook -#}
{%- set ua_type = module.rand.weighted_choice(["browser_windows", "browser_mac", "outlook_desktop", "outlook_mobile", "teams_desktop"], [35, 15, 20, 10, 20]) -%}
{%- set ua_value = pick_user_agent(ua_type, samples.user_agents) -%}
{#- Application IDs for common M365 apps -#}
{%- set app_choices = [
    {"id": "00000003-0000-0000-c000-000000000000", "name": "Microsoft Graph"},
    {"id": "00000002-0000-0ff1-ce00-000000000000", "name": "Office 365 Exchange Online"},
    {"id": "00000003-0000-0ff1-ce00-000000000000", "name": "Microsoft Office"},
    {"id": "1fec8e78-bce4-4aaf-ab1b-5451cc387264", "name": "Microsoft Teams"},
    {"id": "4765445b-32c6-49b0-83e6-1d93765276ca", "name": "Microsoft Office Web Apps"}
] -%}
{%- set app = module.rand.choice(app_choices) -%}
{%- set operation = "UserLoggedIn" -%}
{%- set workload = "AzureActiveDirectory" -%}
{%- set rec_type = record_type_for_workload(workload, operation) -%}
{%- set ut_val = user_type_value(user) -%}
{%- set object_id = app.id -%}
{#- Store login session for correlation -#}
{%- set sessions = shared.get('active_sessions', []) -%}
{%- do sessions.append({"user_upn": user.upn, "user_object_id": user.object_id, "src_ip": src_ip, "ts": timestamp.isoformat()}) -%}
{%- if sessions | length > 50 -%}{%- do sessions.pop(0) -%}{%- endif -%}
{%- do shared.set('active_sessions', sessions) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block() }},
    {{ ecs_block() }},
    {{ event_block(operation, ["authentication"], event_id, "success", ["start"]) }},
    {{ source_block(src_ip) }},
    {{ user_block(user) }},
    "user_agent": {
        "original": {{ ua_value | tojson }}
    },
    {{ organization_block(org) }},
    {{ related_block([src_ip], [user.upn.split('@')[0], user.upn]) }},
    "o365": {
        "audit": {
            {{ o365_base_block(audit_id, rec_type, "Succeeded", operation, workload, user, src_ip, object_id, ut_val) }},
            "user_agent": {{ ua_value | tojson }},
            "extended_properties": [
                {
                    "name": "ResultStatusDetail",
                    "value": "Success"
                },
                {
                    "name": "UserAuthenticationMethod",
                    "value": "{{ module.rand.weighted_choice(["1", "2"], [60, 40]) }}"
                },
                {
                    "name": "RequestType",
                    "value": "{{ module.rand.weighted_choice(["OAuth2:Authorize", "OAuth2:Token", "SAS:EndAuth"], [40, 40, 20]) }}"
                }
            ],
            "actor": [
                {
                    "id": "{{ user.object_id }}",
                    "type": 0
                },
                {
                    "id": "{{ user.upn }}",
                    "type": 5
                }
            ],
            "target": [
                {
                    "id": "{{ app.id }}",
                    "type": 0
                },
                {
                    "id": {{ app.name | tojson }},
                    "type": 1
                }
            ],
            "application_id": "{{ app.id }}",
            "correlation_id": "{{ correlation_id }}",
            "error_number": "0",
            "logon_error": ""
        }
    }
}
