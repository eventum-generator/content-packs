{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set local_node = samples.coordinators | random -%}
{%- set remote_candidates = samples.coordinators | rejectattr('node_id', 'equalto', local_node.node_id) | list -%}
{%- set remote_node = remote_candidates | random -%}
{%- set tunnel_type = module.rand.weighted_choice(["site-to-site", "client-to-site"], [70, 30]) -%}
{%- set protocol = module.rand.weighted_choice(["UDP", "TCP"], [75, 25]) -%}
{%- set port = 55777 if protocol == "UDP" else 80 -%}
{%- set encryption = module.rand.weighted_choice(
  ["GOST R 34.12-2015 (Kuznechik)", "GOST 28147-89", "GOST R 34.12-2015 (Magma)"],
  [60, 25, 15]
) -%}
{%- set tunnel_id = module.rand.crypto.uuid4() -%}
{%- set tunnels = shared.get('tunnels', []) -%}
{%- do tunnels.append({
  "tunnel_id": tunnel_id,
  "local_node": local_node,
  "remote_node": remote_node,
  "tunnel_type": tunnel_type,
  "protocol": protocol,
  "encryption": encryption
}) -%}
{%- if tunnels | length > 100 -%}{%- do tunnels.pop(0) -%}{%- endif -%}
{%- do shared.set('tunnels', tunnels) -%}
{%- set event_msg = "Tunnel established: " ~ local_node.node_name ~ " (" ~ local_node.node_ip ~ ") <-> " ~ remote_node.node_name ~ " (" ~ remote_node.node_ip ~ "), type=" ~ tunnel_type ~ ", proto=" ~ protocol ~ "/" ~ port ~ ", cipher=" ~ encryption -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "tunnel-established",
        "category": ["network"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "success",
        "severity": 6,
        "type": ["connection", "start", "allowed"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 166,
            "severity": {
                "code": 6
            }
        }
    },
    "network": {
        "protocol": "{{ protocol | lower }}",
        "transport": "{{ protocol | lower }}",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ local_node.node_name }}", "{{ remote_node.node_name }}"],
        "ip": ["{{ local_node.node_ip }}", "{{ remote_node.node_ip }}"]
    },
    "source": {
        "address": "{{ local_node.node_ip }}",
        "ip": "{{ local_node.node_ip }}"
    },
    "destination": {
        "address": "{{ remote_node.node_ip }}",
        "ip": "{{ remote_node.node_ip }}",
        "port": {{ port }}
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "tunnel_id": "{{ tunnel_id }}",
            "tunnel_type": "{{ tunnel_type }}",
            "encryption_algorithm": "{{ encryption }}",
            "local_node": {
                "id": "{{ local_node.node_id }}",
                "name": "{{ local_node.node_name }}"
            },
            "remote_node": {
                "id": "{{ remote_node.node_id }}",
                "name": "{{ remote_node.node_name }}"
            }
        }
    }
}
