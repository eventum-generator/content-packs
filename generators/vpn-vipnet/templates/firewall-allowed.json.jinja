{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set src_ip = module.rand.network.ip_v4_private_a() -%}
{%- set dst_ip = module.rand.network.ip_v4_private_a() -%}
{%- set proto = module.rand.weighted_choice(["TCP", "UDP", "ICMP"], [60, 30, 10]) -%}
{%- if proto == "ICMP" -%}
  {%- set src_port = 0 -%}
  {%- set dst_port = 0 -%}
{%- else -%}
  {%- set src_port = module.rand.number.integer(1024, 65535) -%}
  {%- set dst_port = module.rand.weighted_choice(
    [443, 80, 22, 53, 8443, 3389, 445, 389, 636, 25],
    [30, 15, 10, 10, 8, 7, 5, 5, 5, 5]
  ) -%}
{%- endif -%}
{%- set rule_id = module.rand.number.integer(1, 50) -%}
{%- set direction = module.rand.weighted_choice(["inbound", "outbound"], [55, 45]) -%}
{%- set interface = module.rand.weighted_choice(["eth0", "eth1", "eth2"], [50, 35, 15]) -%}
{%- set bytes_val = (module.rand.number.lognormal(7, 1.5)) | int -%}
{%- set event_msg = "Firewall: ALLOW " ~ proto ~ " " ~ src_ip ~ ":" ~ src_port ~ " -> " ~ dst_ip ~ ":" ~ dst_port ~ " rule=" ~ rule_id ~ " iface=" ~ interface ~ " dir=" ~ direction -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ dst_ip }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "firewall-rule-match",
        "category": ["network"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "success",
        "severity": 6,
        "type": ["connection", "allowed"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 166,
            "severity": {
                "code": 6
            }
        }
    },
    "network": {
        "bytes": {{ bytes_val }},
        "direction": "{{ direction }}",
        "iana_number": "{{ 6 if proto == 'TCP' else (17 if proto == 'UDP' else 1) }}",
        "transport": "{{ proto | lower }}",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "firewall",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "rule": {
        "id": "{{ rule_id }}"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "firewall_action": "allow",
            "interface": "{{ interface }}",
            "direction": "{{ direction }}"
        }
    }
}
