{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set src_ip = module.rand.network.ip_v4_private_a() -%}
{%- set dst_ip = module.rand.network.ip_v4_private_a() -%}
{%- set proto = module.rand.weighted_choice(["TCP", "UDP"], [60, 40]) -%}
{%- set src_port = module.rand.number.integer(1024, 65535) -%}
{%- set dst_port = module.rand.weighted_choice(
  [443, 80, 445, 389, 636, 53, 22, 3389],
  [25, 20, 12, 10, 8, 10, 8, 7]
) -%}
{%- set reason = module.rand.weighted_choice(
  ["user-not-authenticated", "missing-key-exchange", "coordinator-mismatch", "directory-not-synced"],
  [40, 25, 20, 15]
) -%}
{#- Event 22 from ViPNet IP packet journal — non-encrypted packet from network node -#}
{%- set event_msg = "Event 22: Non-encrypted IP packet from network node: " ~ proto ~ " " ~ src_ip ~ ":" ~ src_port ~ " -> " ~ dst_ip ~ ":" ~ dst_port ~ " reason=" ~ reason -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ dst_ip }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "packet-unencrypted",
        "category": ["network"],
        "code": "22",
        "dataset": "vipnet.coordinator",
        "kind": "alert",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "failure",
        "reason": "{{ reason }}",
        "severity": 3,
        "type": ["info", "denied"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "error",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 163,
            "severity": {
                "code": 3
            }
        }
    },
    "network": {
        "iana_number": "{{ 6 if proto == 'TCP' else 17 }}",
        "transport": "{{ proto | lower }}",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "event_code": 22,
            "violation_type": "{{ reason }}"
        }
    }
}
