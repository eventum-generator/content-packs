{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set src_ip = module.rand.weighted_choice(
  [module.rand.network.ip_v4_public(), module.rand.network.ip_v4_private_a()],
  [65, 35]
) -%}
{%- set dst_ip = module.rand.network.ip_v4_private_a() -%}
{%- set proto = module.rand.weighted_choice(["TCP", "UDP", "ICMP"], [55, 25, 20]) -%}
{%- if proto == "ICMP" -%}
  {%- set src_port = 0 -%}
  {%- set dst_port = 0 -%}
{%- else -%}
  {%- set src_port = module.rand.number.integer(1024, 65535) -%}
  {%- set dst_port = module.rand.weighted_choice(
    [445, 3389, 22, 23, 135, 139, 1433, 3306, 8080, 53],
    [20, 18, 12, 10, 10, 8, 7, 5, 5, 5]
  ) -%}
{%- endif -%}
{%- set rule_id = module.rand.number.integer(1, 50) -%}
{%- set direction = module.rand.weighted_choice(["inbound", "outbound"], [75, 25]) -%}
{%- set interface = module.rand.weighted_choice(["eth0", "eth1", "eth2"], [55, 30, 15]) -%}
{%- set block_reason = module.rand.weighted_choice(
  ["rule-deny", "default-deny", "no-matching-rule", "rate-limit", "geo-block"],
  [35, 25, 20, 10, 10]
) -%}
{%- set event_msg = "Firewall: BLOCK " ~ proto ~ " " ~ src_ip ~ ":" ~ src_port ~ " -> " ~ dst_ip ~ ":" ~ dst_port ~ " rule=" ~ rule_id ~ " reason=" ~ block_reason ~ " iface=" ~ interface -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ dst_ip }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "firewall-rule-match",
        "category": ["network"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "failure",
        "reason": "{{ block_reason }}",
        "severity": 4,
        "type": ["connection", "denied"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "warning",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 164,
            "severity": {
                "code": 4
            }
        }
    },
    "network": {
        "direction": "{{ direction }}",
        "iana_number": "{{ 6 if proto == 'TCP' else (17 if proto == 'UDP' else 1) }}",
        "transport": "{{ proto | lower }}",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "firewall",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "rule": {
        "id": "{{ rule_id }}"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "firewall_action": "block",
            "block_reason": "{{ block_reason }}",
            "interface": "{{ interface }}",
            "direction": "{{ direction }}"
        }
    }
}
