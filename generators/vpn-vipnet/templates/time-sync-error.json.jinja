{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set nodes = samples.vipnet_nodes -%}
{%- set remote_node = nodes | random -%}
{%- set time_diff_sec = module.rand.number.integer(120, 7200) -%}
{%- set src_ip = module.rand.network.ip_v4_private_a() -%}
{#- Event 4 from ViPNet IP packet journal — IP packet timeout (time divergence) -#}
{%- set event_msg = "Event 4: IP packet timeout: node=" ~ remote_node.node_name ~ " (" ~ remote_node.node_ip ~ ") time_difference=" ~ time_diff_sec ~ "s, src=" ~ src_ip ~ ", max_allowed=" ~ params.get('max_timediff', 7200) ~ "s" -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "time-sync-error",
        "category": ["network"],
        "code": "4",
        "dataset": "vipnet.coordinator",
        "kind": "alert",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "failure",
        "reason": "Time divergence between nodes exceeds threshold",
        "severity": 3,
        "type": ["info", "error"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "error",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 163,
            "severity": {
                "code": 3
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ remote_node.node_name }}"],
        "ip": ["{{ remote_node.node_ip }}", "{{ src_ip }}"]
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}"
    },
    "destination": {
        "address": "{{ remote_node.node_ip }}",
        "ip": "{{ remote_node.node_ip }}"
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "event_code": 4,
            "time_difference_sec": {{ time_diff_sec }},
            "max_timediff_sec": {{ params.get('max_timediff', 7200) }},
            "remote_node": {
                "id": "{{ remote_node.node_id }}",
                "name": "{{ remote_node.node_name }}"
            }
        }
    }
}
