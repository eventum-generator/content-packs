{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set user = (samples.usernames | random) -%}
{%- set client_ip = module.rand.network.ip_v4_private_a() -%}
{%- set config_type = module.rand.weighted_choice(
  ["firewall-rule", "network-interface", "logging-settings", "tunnel-config", "key-update", "access-policy"],
  [25, 15, 15, 20, 15, 10]
) -%}
{%- set change_action = module.rand.weighted_choice(
  ["added", "modified", "removed"],
  [35, 45, 20]
) -%}
{%- set interface = module.rand.weighted_choice(
  ["web-console", "cli"],
  [65, 35]
) -%}
{%- set event_msg = "Configuration changed: type=" ~ config_type ~ ", action=" ~ change_action ~ ", user=" ~ user.username ~ ", interface=" ~ interface ~ ", src=" ~ client_ip -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "configuration-changed",
        "category": ["configuration"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "success",
        "severity": 5,
        "type": ["change"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "notice",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 165,
            "severity": {
                "code": 5
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ client_ip }}"],
        "user": ["{{ user.username }}"]
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "user": {
            "name": "{{ user.username }}"
        }
    },
    "tags": ["vipnet", "forwarded"],
    "user": {
        "name": "{{ user.username }}",
        "full_name": "{{ user.full_name }}"
    },
    "vipnet": {
        "coordinator": {
            "config_type": "{{ config_type }}",
            "config_action": "{{ change_action }}",
            "admin_interface": "{{ interface }}"
        }
    }
}
