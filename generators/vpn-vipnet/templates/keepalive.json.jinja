{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set remote_node = samples.coordinators | random -%}
{%- set latency_ms = (module.rand.number.lognormal(2.5, 0.8)) | round(1) -%}
{%- set status = module.rand.weighted_choice(["alive", "alive", "alive", "alive", "timeout"], [25, 25, 25, 20, 5]) -%}
{%- set event_msg = "Keepalive: node=" ~ remote_node.node_name ~ " (" ~ remote_node.node_ip ~ ") status=" ~ status ~ " latency=" ~ latency_ms ~ "ms" -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "keepalive",
        "category": ["network"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "{{ 'success' if status == 'alive' else 'failure' }}",
        "severity": {{ 6 if status == "alive" else 4 }},
        "type": ["info"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "{{ 'informational' if status == 'alive' else 'warning' }}",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": {{ 166 if status == "alive" else 164 }},
            "severity": {
                "code": {{ 6 if status == "alive" else 4 }}
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ remote_node.node_name }}"],
        "ip": ["{{ remote_node.node_ip }}"]
    },
    "destination": {
        "address": "{{ remote_node.node_ip }}",
        "ip": "{{ remote_node.node_ip }}"
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "keepalive_status": "{{ status }}",
            "latency_ms": {{ latency_ms }},
            "remote_node": {
                "id": "{{ remote_node.node_id }}",
                "name": "{{ remote_node.node_name }}"
            }
        }
    }
}
