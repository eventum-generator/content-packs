{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set nodes = samples.vipnet_nodes -%}
{%- set src_node = nodes | random -%}
{%- set dst_candidates = nodes | rejectattr('node_id', 'equalto', src_node.node_id) | list -%}
{%- set dst_node = dst_candidates | random -%}
{%- set proto = module.rand.weighted_choice(["TCP", "UDP", "ICMP"], [65, 25, 10]) -%}
{%- if proto == "ICMP" -%}
  {%- set src_port = 0 -%}
  {%- set dst_port = 0 -%}
{%- else -%}
  {%- set src_port = module.rand.number.integer(1024, 65535) -%}
  {%- set dst_port = module.rand.weighted_choice(
    [443, 80, 22, 445, 53, 8443, 389, 636, 3389, 25],
    [25, 15, 12, 10, 10, 8, 5, 5, 5, 5]
  ) -%}
{%- endif -%}
{%- set bytes_val = (module.rand.number.lognormal(8, 2)) | int -%}
{%- set encryption = module.rand.weighted_choice(
  ["GOST R 34.12-2015 (Kuznechik)", "GOST 28147-89", "GOST R 34.12-2015 (Magma)"],
  [60, 25, 15]
) -%}
{%- set event_msg = "IP packet encrypted: " ~ proto ~ " " ~ src_node.node_ip ~ ":" ~ src_port ~ " -> " ~ dst_node.node_ip ~ ":" ~ dst_port ~ " cipher=" ~ encryption ~ " bytes=" ~ bytes_val -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ dst_node.node_ip }}",
        "ip": "{{ dst_node.node_ip }}",
        "port": {{ dst_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "packet-encrypted",
        "category": ["network"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "success",
        "severity": 7,
        "type": ["info"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "debug",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 167,
            "severity": {
                "code": 7
            }
        }
    },
    "network": {
        "bytes": {{ bytes_val }},
        "iana_number": "{{ 6 if proto == 'TCP' else (17 if proto == 'UDP' else 1) }}",
        "transport": "{{ proto | lower }}",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_node.node_ip }}", "{{ dst_node.node_ip }}"]
    },
    "source": {
        "address": "{{ src_node.node_ip }}",
        "ip": "{{ src_node.node_ip }}",
        "port": {{ src_port }}
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "encryption_algorithm": "{{ encryption }}",
            "source_node": {
                "id": "{{ src_node.node_id }}",
                "name": "{{ src_node.node_name }}"
            },
            "destination_node": {
                "id": "{{ dst_node.node_id }}",
                "name": "{{ dst_node.node_name }}"
            }
        }
    }
}
