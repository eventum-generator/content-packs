{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set user = (samples.usernames | random) -%}
{%- set client_ip = module.rand.network.ip_v4_private_a() -%}
{%- set auth_method = module.rand.weighted_choice(
  ["certificate", "password", "two-factor"],
  [50, 30, 20]
) -%}
{%- set interface = module.rand.weighted_choice(
  ["web-console", "cli", "vipnet-client"],
  [40, 15, 45]
) -%}
{%- set event_msg = "Authentication successful: user=" ~ user.username ~ ", method=" ~ auth_method ~ ", interface=" ~ interface ~ ", src=" ~ client_ip -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "logon",
        "category": ["authentication"],
        "dataset": "vipnet.coordinator",
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "success",
        "severity": 6,
        "type": ["start", "allowed"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 166,
            "severity": {
                "code": 6
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ client_ip }}"],
        "user": ["{{ user.username }}"]
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "user": {
            "name": "{{ user.username }}",
            "full_name": "{{ user.full_name }}"
        }
    },
    "tags": ["vipnet", "forwarded"],
    "user": {
        "name": "{{ user.username }}",
        "full_name": "{{ user.full_name }}"
    },
    "vipnet": {
        "coordinator": {
            "auth_method": "{{ auth_method }}",
            "auth_interface": "{{ interface }}"
        }
    }
}
