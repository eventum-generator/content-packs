{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set tunnels = shared.get('tunnels', []) -%}
{%- if tunnels | length > 0 -%}
  {%- set tunnel = tunnels | random -%}
  {%- set local_node = tunnel.local_node -%}
  {%- set remote_node = tunnel.remote_node -%}
  {%- set tunnel_id = tunnel.tunnel_id -%}
  {%- set tunnel_type = tunnel.tunnel_type -%}
  {%- set encryption = tunnel.encryption -%}
{%- else -%}
  {%- set local_node = samples.coordinators[0] -%}
  {%- set remote_node = samples.coordinators[1] -%}
  {%- set tunnel_id = module.rand.crypto.uuid4() -%}
  {%- set tunnel_type = "site-to-site" -%}
  {%- set encryption = "GOST R 34.12-2015 (Kuznechik)" -%}
{%- endif -%}
{%- set reason = module.rand.weighted_choice(
  ["administrative", "timeout", "peer-unreachable", "key-expiry", "rekeying"],
  [25, 30, 15, 10, 20]
) -%}
{%- set duration_sec = module.rand.number.integer(60, 86400) -%}
{%- set bytes_sent = (module.rand.number.lognormal(14, 1.5)) | int -%}
{%- set bytes_recv = (module.rand.number.lognormal(14, 1.5)) | int -%}
{%- set event_msg = "Tunnel destroyed: " ~ local_node.node_name ~ " (" ~ local_node.node_ip ~ ") <-> " ~ remote_node.node_name ~ " (" ~ remote_node.node_ip ~ "), reason=" ~ reason ~ ", duration=" ~ duration_sec ~ "s" -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "vipnet.coordinator",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "tunnel-destroyed",
        "category": ["network"],
        "dataset": "vipnet.coordinator",
        "duration": {{ duration_sec * 1000000000 }},
        "kind": "event",
        "module": "vipnet",
        "original": "{{ timestamp.strftime('%b %d %H:%M:%S') }} {{ hostname }} vipnet-coordinator: {{ event_msg }}",
        "outcome": "success",
        "reason": "{{ reason }}",
        "severity": 6,
        "type": ["connection", "end"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 20
            },
            "priority": 166,
            "severity": {
                "code": 6
            }
        }
    },
    "network": {
        "bytes": {{ bytes_sent + bytes_recv }},
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "ViPNet Coordinator",
        "type": "vpn",
        "vendor": "InfoTeCS"
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ local_node.node_name }}", "{{ remote_node.node_name }}"],
        "ip": ["{{ local_node.node_ip }}", "{{ remote_node.node_ip }}"]
    },
    "source": {
        "address": "{{ local_node.node_ip }}",
        "bytes": {{ bytes_sent }},
        "ip": "{{ local_node.node_ip }}"
    },
    "destination": {
        "address": "{{ remote_node.node_ip }}",
        "bytes": {{ bytes_recv }},
        "ip": "{{ remote_node.node_ip }}"
    },
    "tags": ["vipnet", "forwarded"],
    "vipnet": {
        "coordinator": {
            "tunnel_id": "{{ tunnel_id }}",
            "tunnel_type": "{{ tunnel_type }}",
            "encryption_algorithm": "{{ encryption }}",
            "disconnect_reason": "{{ reason }}",
            "local_node": {
                "id": "{{ local_node.node_id }}",
                "name": "{{ local_node.node_name }}"
            },
            "remote_node": {
                "id": "{{ remote_node.node_id }}",
                "name": "{{ remote_node.node_name }}"
            }
        }
    }
}
