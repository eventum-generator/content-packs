{#- Shared macros for Kaspersky Web Traffic Security (KWTS) proxy events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import agent_block, ecs_block, host_block, observer_block, user_block, network_block, tls_block, http_block, url_block, kwts_base_block, related_block %} -#}

{%- macro agent_block(params) -%}
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ params.kwts_hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    }
{%- endmacro -%}

{%- macro ecs_block() -%}
    "ecs": {
        "version": "8.17.0"
    }
{%- endmacro -%}

{%- macro host_block(host_entry) -%}
    "host": {
        "hostname": "{{ host_entry.hostname }}",
        "name": "{{ host_entry.hostname | lower }}",
        "os": {
            "type": "{{ 'windows' if host_entry.os_type == 'Windows' else 'linux' }}",
            "version": "{{ host_entry.os_version }}"
        }
    }
{%- endmacro -%}

{%- macro observer_block(params) -%}
    "observer": {
        "hostname": "{{ params.kwts_hostname }}",
        "ip": ["{{ params.proxy_ip }}"],
        "product": "Kaspersky Web Traffic Security",
        "type": "proxy",
        "vendor": "Kaspersky",
        "version": "{{ params.kwts_version }}"
    }
{%- endmacro -%}

{%- macro user_block(user) -%}
    "user": {
        "domain": "{{ user.domain }}",
        "name": "{{ user.username }}"
    }
{%- endmacro -%}

{%- macro network_block(protocol, direction) -%}
    "network": {
        "direction": "{{ direction }}",
        "protocol": "{{ protocol | lower }}",
        "transport": "tcp"
    }
{%- endmacro -%}

{%- macro tls_block(tls_version, cipher) -%}
    "tls": {
        "cipher": "{{ cipher }}",
        "version": "{{ tls_version }}",
        "version_protocol": "tls"
    }
{%- endmacro -%}

{%- macro http_block(method, resp_code, user_agent, req_bytes, resp_bytes, content_type, version) -%}
    "http": {
        "request": {
            "bytes": {{ req_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "bytes": {{ resp_bytes }},
            "mime_type": "{{ content_type }}",
            "status_code": {{ resp_code }}
        },
        "version": "{{ version }}"
    }
{%- endmacro -%}

{%- macro url_block(url_entry, scheme) -%}
    {%- set url_full = scheme ~ "://" ~ url_entry.domain ~ url_entry.path -%}
    "url": {
        "domain": "{{ url_entry.domain }}",
        "full": {{ url_full | tojson }},
        "original": {{ url_full | tojson }},
        "path": "{{ url_entry.path }}",
        "scheme": "{{ scheme }}"
    }
{%- endmacro -%}

{%- macro related_block(src_ip, dst_ip, username, hostname, extra_hashes) -%}
    "related": {
        {%- if extra_hashes %}
        "hash": {{ extra_hashes | tojson }},
        {%- endif %}
        "hosts": ["{{ hostname | lower }}", "{{ dst_ip }}"],
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"],
        "user": ["{{ username }}"]
    }
{%- endmacro -%}

{%- macro kwts_scan_results(av_status, ap_status, mlf_status, kata_alert, encrypted, macros_status) -%}
            "scan_result": {
                "av": "{{ av_status }}",
                "ap": "{{ ap_status }}",
                "mlf": "{{ mlf_status }}",
                "kata": "{{ kata_alert }}",
                "encrypted": "{{ encrypted }}",
                "macros": "{{ macros_status }}"
            }
{%- endmacro -%}
