{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, host_block, observer_block, user_block, network_block, tls_block, http_block, url_block, related_block -%}
{%- set record_id = shared.get('record_id', 1) -%}
{#- Pick user and host -#}
{%- set user = samples.users | random -%}
{%- set host_entry = samples.hosts | random -%}
{#- Pick URL category and URL -#}
{%- set category = samples.url_categories_allowed.weighted_pick('weight') -%}
{%- set url_entry = category.urls | random -%}
{#- HTTP details -#}
{%- set protocol = module.rand.weighted_choice(["HTTPS", "HTTP"], [92, 8]) -%}
{%- set http_method = module.rand.weighted_choice(["GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS", "CONNECT"], [70, 15, 3, 1, 4, 2, 5]) -%}
{%- set resp_code = module.rand.weighted_choice([200, 301, 302, 304, 404, 403, 500], [76, 4, 5, 10, 3, 1, 1]) -%}
{%- set user_agent = module.faker.locale.en_US.user_agent() -%}
{%- set content_type = module.rand.weighted_choice(["text/html", "application/json", "application/javascript", "text/css", "image/png", "image/jpeg", "application/octet-stream", "text/xml"], [28, 18, 15, 10, 10, 8, 6, 5]) -%}
{#- Network details -#}
{%- set src_ip = host_entry.ip_prefix ~ "." ~ module.rand.number.integer(10, 254) -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{%- set dst_ip = module.rand.network.ip_v4_public() -%}
{%- set dst_port = 443 if protocol == "HTTPS" else 80 -%}
{#- Byte sizes (lognormal for realistic distribution) -#}
{%- set req_bytes = module.rand.number.clamp(module.rand.number.lognormal(6, 1.5) | int, 100, 500000) -%}
{%- set resp_bytes = module.rand.number.clamp(module.rand.number.lognormal(8, 2) | int, 200, 15000000) -%}
{%- set processing_ms = module.rand.number.clamp(module.rand.number.lognormal(3, 1.2) | int, 1, 30000) -%}
{#- TLS details -#}
{%- set tls_version = module.rand.weighted_choice(["1.3", "1.2"], [70, 30]) -%}
{%- set cipher = module.rand.weighted_choice(["TLS_AES_256_GCM_SHA384", "TLS_AES_128_GCM_SHA256", "TLS_CHACHA20_POLY1305_SHA256", "ECDHE-RSA-AES256-GCM-SHA384", "ECDHE-RSA-AES128-GCM-SHA256"], [30, 30, 10, 18, 12]) -%}
{%- set url_scheme = "https" if protocol == "HTTPS" else "http" -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    "destination": {
        "domain": "{{ url_entry.domain }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    {{ ecs_block() }},
    "event": {
        "action": "allowed",
        "category": ["web", "network"],
        "dataset": "kaspersky_kwts.traffic",
        "duration": {{ processing_ms * 1000000 }},
        "id": "{{ record_id }}",
        "kind": "event",
        "module": "kaspersky_kwts",
        "outcome": "success",
        "reason": "Not detected",
        "type": ["access", "allowed", "connection"]
    },
    {{ host_block(host_entry) }},
    {{ http_block(http_method, resp_code, user_agent, req_bytes, resp_bytes, content_type, "1.1") }},
    "kaspersky": {
        "kwts": {
            "action": "Allow",
            "blocked_by_rule": "-",
            "processing_time_ms": {{ processing_ms }},
            "scan_result": "Not detected",
            "av_status": "NotScanned (ByACL)",
            "ap_status": "NotScanned (ByACL)",
            "mlf_status": "NotScanned (ByACL)",
            "kata_alert": "NotApplicable",
            "encrypted": "NotDetected",
            "macros": "NotDetected",
            "workspace": "Default",
            "type": "{{ module.rand.weighted_choice(['Request', 'Response'], [40, 60]) }}",
            "filename": "nofile",
            "filesize": "NotApplicable",
            "content_type": "{{ content_type }}",
            "method": "{{ http_method }}",
            "url_category": "{{ category.category }}",
            "rules": "Allow All Traffic"
        }
    },
    {{ network_block(protocol, "outbound") }},
    {{ observer_block(params) }},
    {{ related_block(src_ip, dst_ip, user.username, host_entry.hostname, []) }},
    "source": {
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    {%- if protocol == "HTTPS" %}
    {{ tls_block(tls_version, cipher) }},
    {%- endif %}
    {{ url_block(url_entry, url_scheme) }},
    {{ user_block(user) }},
    "user_agent": {
        "original": {{ user_agent | tojson }}
    }
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}
