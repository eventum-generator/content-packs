{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, host_block, observer_block, user_block, network_block, tls_block, http_block, url_block, related_block -%}
{%- set record_id = shared.get('record_id', 1) -%}
{#- Pick user and host -#}
{%- set user = samples.users | random -%}
{%- set host_entry = samples.hosts | random -%}
{#- Redirected URLs — policy-triggering but not fully blocked (warning pages) -#}
{%- set redirect_categories = [
    {"category": "Uncategorized", "urls": [
        {"domain": "unknown-service.xyz", "path": "/app/"},
        {"domain": "new-startup-tool.io", "path": "/dashboard"},
        {"domain": "beta-app-test.net", "path": "/login"}
    ]},
    {"category": "File sharing", "urls": [
        {"domain": "mega.nz", "path": "/file/abc123"},
        {"domain": "www.mediafire.com", "path": "/file/xyz789/download"},
        {"domain": "zippyshare.com", "path": "/v/abcdef/file.html"}
    ]},
    {"category": "Potentially dangerous", "urls": [
        {"domain": "free-vpn-download.com", "path": "/install"},
        {"domain": "torrent-search.xyz", "path": "/browse"},
        {"domain": "crack-software.net", "path": "/programs"}
    ]}
] -%}
{%- set cat_entry = redirect_categories | random -%}
{%- set url_entry = cat_entry.urls | random -%}
{#- HTTP details -#}
{%- set protocol = module.rand.weighted_choice(["HTTPS", "HTTP"], [70, 30]) -%}
{%- set http_method = "GET" -%}
{%- set user_agent = module.faker.locale.en_US.user_agent() -%}
{#- Network details -#}
{%- set src_ip = host_entry.ip_prefix ~ "." ~ module.rand.number.integer(10, 254) -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{%- set dst_ip = module.rand.network.ip_v4_public() -%}
{%- set dst_port = 443 if protocol == "HTTPS" else 80 -%}
{#- Byte sizes -#}
{%- set req_bytes = module.rand.number.integer(200, 600) -%}
{%- set resp_bytes = module.rand.number.integer(500, 3000) -%}
{%- set processing_ms = module.rand.number.integer(2, 30) -%}
{#- TLS details -#}
{%- set tls_version = module.rand.weighted_choice(["1.3", "1.2"], [60, 40]) -%}
{%- set cipher = module.rand.weighted_choice(["TLS_AES_256_GCM_SHA384", "TLS_AES_128_GCM_SHA256"], [50, 50]) -%}
{%- set url_scheme = "https" if protocol == "HTTPS" else "http" -%}
{#- Redirect rule -#}
{%- set rule_name = module.rand.weighted_choice(["Redirect_Uncategorized_Warning", "File_Sharing_Caution", "Potentially_Dangerous_Redirect"], [40, 35, 25]) -%}
{%- set redirect_url = "https://" ~ params.kwts_hostname ~ "/warning?url=" ~ url_entry.domain ~ "&rule=" ~ rule_name -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    "destination": {
        "domain": "{{ url_entry.domain }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    {{ ecs_block() }},
    "event": {
        "action": "redirected",
        "category": ["web", "network"],
        "dataset": "kaspersky_kwts.traffic",
        "duration": {{ processing_ms * 1000000 }},
        "id": "{{ record_id }}",
        "kind": "event",
        "module": "kaspersky_kwts",
        "outcome": "unknown",
        "reason": "Redirected to warning page: {{ cat_entry.category }}",
        "type": ["access", "connection"]
    },
    {{ host_block(host_entry) }},
    {{ http_block(http_method, 302, user_agent, req_bytes, resp_bytes, "text/html", "1.1") }},
    "kaspersky": {
        "kwts": {
            "action": "Redirect",
            "redirected_by_rule": "[Default/{{ rule_name }}]",
            "blocked_by_rule": "-",
            "processing_time_ms": {{ processing_ms }},
            "scan_result": "Not scanned",
            "av_status": "NotScanned (ByACL)",
            "ap_status": "NotScanned (ByACL)",
            "mlf_status": "NotScanned (ByACL)",
            "kata_alert": "NotApplicable",
            "encrypted": "NotDetected",
            "macros": "NotDetected",
            "workspace": "Default",
            "type": "Request",
            "filename": "nofile",
            "filesize": "NotApplicable",
            "content_type": "text/html",
            "method": "{{ http_method }}",
            "url_category": "{{ cat_entry.category }}",
            "rules": "{{ rule_name }}",
            "redirect_url": {{ redirect_url | tojson }}
        }
    },
    {{ network_block(protocol, "outbound") }},
    {{ observer_block(params) }},
    {{ related_block(src_ip, dst_ip, user.username, host_entry.hostname, []) }},
    "rule": {
        "name": "{{ rule_name }}",
        "ruleset": "URL Filtering"
    },
    "source": {
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    {%- if protocol == "HTTPS" %}
    {{ tls_block(tls_version, cipher) }},
    {%- endif %}
    {{ url_block(url_entry, url_scheme) }},
    {{ user_block(user) }},
    "user_agent": {
        "original": {{ user_agent | tojson }}
    }
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}
