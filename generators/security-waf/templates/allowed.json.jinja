{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set geo = samples.geo_data | random -%}
{#- URL selection with category weighting -#}
{%- set url_category = module.rand.weighted_choice(
  ["page", "api", "asset", "wellknown"],
  [35, 25, 30, 10]
) -%}
{%- set category_urls = [] -%}
{%- for u in samples.urls if u.category == url_category -%}
  {%- do category_urls.append(u) -%}
{%- endfor -%}
{%- set url_entry = category_urls | random -%}
{%- set url_path = url_entry.path -%}
{%- if url_entry.methods | length > 1 -%}
  {%- set method = url_entry.methods | random -%}
{%- else -%}
  {%- set method = url_entry.methods[0] -%}
{%- endif -%}
{#- User agent — mostly browsers and mobile -#}
{%- set ua_type = module.rand.weighted_choice(
  ["browser", "mobile", "bot", "tool"],
  [60, 20, 12, 8]
) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- set ua = type_uas | random -%}
{#- HTTP version and status -#}
{%- set http_version = module.rand.weighted_choice(["1.1", "2.0"], [45, 55]) -%}
{%- set status_code = module.rand.weighted_choice([200, 201, 204, 301, 302, 304], [72, 5, 3, 4, 4, 12]) -%}
{%- set body_bytes = module.rand.number.integer(200, 85000) -%}
{%- if status_code == 304 -%}
  {%- set body_bytes = 0 -%}
{%- endif -%}
{%- set request_bytes = module.rand.number.integer(200, 2500) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "allowed",
        "category": ["web", "network"],
        "dataset": "waf.log",
        "kind": "event",
        "module": "waf",
        "outcome": "success",
        "type": ["access", "allowed"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "body": {
                "bytes": {{ body_bytes }}
            },
            "status_code": {{ status_code }}
        },
        "version": "{{ http_version }}"
    },
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua.ua }}"
    },
    "waf": {
        "action": "pass",
        "anomaly_score": 0,
        "mode": "{{ params.waf_mode }}",
        "rule_count": 0,
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf"]
}