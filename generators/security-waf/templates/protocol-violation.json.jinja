{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set geo = samples.geo_data | random -%}
{%- set url_entry = samples.urls | random -%}
{%- set url_path = url_entry.path -%}
{%- set method = url_entry.methods[0] -%}
{%- set proto_rules = [] -%}
{%- for r in samples.waf_rules if r.tag == "protocol-violation" -%}
  {%- do proto_rules.append(r) -%}
{%- endfor -%}
{%- set rule = proto_rules | random -%}
{%- set ua_type = module.rand.weighted_choice(["tool", "scanner", "browser", "empty"], [35, 25, 25, 15]) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- if type_uas | length > 0 -%}
  {%- set ua = (type_uas | random).ua -%}
{%- else -%}
  {%- set ua = "" -%}
{%- endif -%}
{%- set http_version = module.rand.weighted_choice(["1.0", "1.1"], [40, 60]) -%}
{%- set anomaly_score = module.rand.weighted_choice([3, 5, 10], [40, 40, 20]) -%}
{%- set action = module.rand.weighted_choice(["blocked", "logged"], [65, 35]) -%}
{%- if action == "blocked" -%}
  {%- set status_code = 400 -%}
  {%- set event_action = "denied" -%}
  {%- set outcome = "failure" -%}
{%- else -%}
  {%- set status_code = 200 -%}
  {%- set event_action = "allowed" -%}
  {%- set outcome = "success" -%}
{%- endif -%}
{%- set request_bytes = module.rand.number.integer(150, 2000) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "{{ event_action }}",
        "category": ["web", "network"],
        "dataset": "waf.log",
        "kind": "alert",
        "module": "waf",
        "outcome": "{{ outcome }}",
        "severity": {{ rule.severity }},
        "type": ["access", "{{ event_action }}"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "status_code": {{ status_code }}
        },
        "version": "{{ http_version }}"
    },
    "message": "{{ rule.msg }}",
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "rule": {
        "category": "{{ rule.category }}",
        "id": "{{ rule.id }}",
        "name": "{{ rule.msg }}",
        "ruleset": "OWASP CRS"
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua }}"
    },
    "waf": {
        "action": "{{ action }}",
        "anomaly_score": {{ anomaly_score }},
        "mode": "{{ params.waf_mode }}",
        "rule_count": 1,
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf", "protocol-violation"]
}