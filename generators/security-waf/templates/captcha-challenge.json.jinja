{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set geo = samples.geo_data | random -%}
{%- set target_paths = ["/login", "/register", "/contact", "/api/v1/auth/login", "/support", "/api/v1/comments"] -%}
{%- set url_path = target_paths | random -%}
{%- set method = module.rand.weighted_choice(["GET", "POST"], [40, 60]) -%}
{%- set ua_type = module.rand.weighted_choice(["browser", "mobile", "tool"], [50, 30, 20]) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- if type_uas | length > 0 -%}
  {%- set ua = (type_uas | random).ua -%}
{%- else -%}
  {%- set ua = "Mozilla/5.0" -%}
{%- endif -%}
{%- set http_version = module.rand.weighted_choice(["1.1", "2.0"], [45, 55]) -%}
{%- set challenge_result = module.rand.weighted_choice(["passed", "failed", "pending"], [40, 35, 25]) -%}
{%- if challenge_result == "passed" -%}
  {%- set status_code = 200 -%}
  {%- set event_action = "allowed" -%}
  {%- set outcome = "success" -%}
{%- else -%}
  {%- set status_code = 403 -%}
  {%- set event_action = "denied" -%}
  {%- set outcome = "failure" -%}
{%- endif -%}
{%- set request_bytes = module.rand.number.integer(200, 2000) -%}
{%- set challenge_reasons = [
  "Suspicious request pattern detected",
  "Multiple failed login attempts",
  "High request velocity from IP",
  "Anomalous browsing behavior",
  "New IP with sensitive endpoint access"
] -%}
{%- set reason = challenge_reasons | random -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "{{ event_action }}",
        "category": ["web", "authentication"],
        "dataset": "waf.log",
        "kind": "alert",
        "module": "waf",
        "outcome": "{{ outcome }}",
        "severity": 4,
        "type": ["access", "{{ event_action }}"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "status_code": {{ status_code }}
        },
        "version": "{{ http_version }}"
    },
    "message": "CAPTCHA challenge issued: {{ reason }}",
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "rule": {
        "category": "CAPTCHA-CHALLENGE",
        "id": "captcha-{{ module.rand.number.integer(100, 999) }}",
        "name": "{{ reason }}",
        "ruleset": "Bot Management"
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua }}"
    },
    "waf": {
        "action": "captcha",
        "anomaly_score": 0,
        "captcha_result": "{{ challenge_result }}",
        "mode": "{{ params.waf_mode }}",
        "rule_count": 1,
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf", "captcha-challenge"]
}