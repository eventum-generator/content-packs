{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{#- Blocked countries -#}
{%- set blocked_geos = [
  {"country_code": "KP", "country": "North Korea", "city": "Pyongyang", "lat": 39.0392, "lon": 125.7625},
  {"country_code": "IR", "country": "Iran", "city": "Tehran", "lat": 35.6892, "lon": 51.3890},
  {"country_code": "SY", "country": "Syria", "city": "Damascus", "lat": 33.5138, "lon": 36.2765},
  {"country_code": "CU", "country": "Cuba", "city": "Havana", "lat": 23.1136, "lon": -82.3666}
] -%}
{%- set geo = blocked_geos | random -%}
{%- set url_entry = samples.urls | random -%}
{%- set url_path = url_entry.path -%}
{%- set method = url_entry.methods[0] -%}
{%- set ua_type = module.rand.weighted_choice(["browser", "tool", "scanner"], [50, 30, 20]) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- if type_uas | length > 0 -%}
  {%- set ua = (type_uas | random).ua -%}
{%- else -%}
  {%- set ua = "Mozilla/5.0" -%}
{%- endif -%}
{%- set http_version = module.rand.weighted_choice(["1.1", "2.0"], [55, 45]) -%}
{%- set request_bytes = module.rand.number.integer(200, 1500) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "denied",
        "category": ["web", "intrusion_detection"],
        "dataset": "waf.log",
        "kind": "alert",
        "module": "waf",
        "outcome": "failure",
        "severity": 3,
        "type": ["access", "denied"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "status_code": 403
        },
        "version": "{{ http_version }}"
    },
    "message": "Geo-blocking: request from restricted country {{ geo.country_code }}",
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "rule": {
        "category": "GEO-RESTRICTION",
        "id": "geo-{{ geo.country_code | lower }}",
        "name": "Access denied from restricted country: {{ geo.country }}",
        "ruleset": "Geo-Blocking"
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua }}"
    },
    "waf": {
        "action": "blocked",
        "anomaly_score": 0,
        "blocked_country": "{{ geo.country_code }}",
        "mode": "{{ params.waf_mode }}",
        "rule_count": 1,
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf", "geo-block"]
}