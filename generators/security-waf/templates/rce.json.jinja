{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set geo = samples.geo_data | random -%}
{%- set target_paths = ["/api/v1/upload", "/api/v2/graphql", "/api/v1/search", "/api/v1/users", "/contact", "/support"] -%}
{%- set url_path = target_paths | random -%}
{%- set method = module.rand.weighted_choice(["POST", "GET", "PUT"], [55, 30, 15]) -%}
{%- set rce_payloads = [] -%}
{%- for p in samples.attack_payloads if p.type == "rce" -%}
  {%- do rce_payloads.append(p) -%}
{%- endfor -%}
{%- set payload = rce_payloads | random -%}
{%- set rce_rules = [] -%}
{%- for r in samples.waf_rules if r.tag == "attack-rce" -%}
  {%- do rce_rules.append(r) -%}
{%- endfor -%}
{%- set rule = rce_rules | random -%}
{%- set ua_type = module.rand.weighted_choice(["scanner", "tool", "browser"], [45, 35, 20]) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- if type_uas | length > 0 -%}
  {%- set ua = (type_uas | random).ua -%}
{%- else -%}
  {%- set ua = "curl/8.5.0" -%}
{%- endif -%}
{%- set http_version = module.rand.weighted_choice(["1.1", "2.0"], [65, 35]) -%}
{%- set anomaly_score = module.rand.weighted_choice([15, 20, 25, 30], [15, 30, 35, 20]) -%}
{%- set action = module.rand.weighted_choice(["blocked", "logged"], [92, 8]) -%}
{%- if action == "blocked" -%}
  {%- set status_code = 403 -%}
  {%- set event_action = "denied" -%}
  {%- set outcome = "failure" -%}
{%- else -%}
  {%- set status_code = 200 -%}
  {%- set event_action = "allowed" -%}
  {%- set outcome = "success" -%}
{%- endif -%}
{%- set request_bytes = module.rand.number.integer(250, 5000) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "{{ event_action }}",
        "category": ["web", "intrusion_detection"],
        "dataset": "waf.log",
        "kind": "alert",
        "module": "waf",
        "outcome": "{{ outcome }}",
        "severity": {{ rule.severity }},
        "type": ["access", "{{ event_action }}"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "status_code": {{ status_code }}
        },
        "version": "{{ http_version }}"
    },
    "message": "{{ rule.msg }}",
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "rule": {
        "category": "{{ rule.category }}",
        "id": "{{ rule.id }}",
        "name": "{{ rule.msg }}",
        "ruleset": "OWASP CRS"
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "threat": {
        "framework": "MITRE ATT&CK",
        "tactic": {
            "id": "TA0002",
            "name": "Execution",
            "reference": "https://attack.mitre.org/tactics/TA0002/"
        },
        "technique": {
            "id": "T1059",
            "name": "Command and Scripting Interpreter",
            "reference": "https://attack.mitre.org/techniques/T1059/",
            "subtechnique": {
                "id": "T1059.004",
                "name": "Unix Shell",
                "reference": "https://attack.mitre.org/techniques/T1059/004/"
            }
        }
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua }}"
    },
    "waf": {
        "action": "{{ action }}",
        "anomaly_score": {{ anomaly_score }},
        "matched_data": {{ payload.payload | tojson }},
        "matched_var": "{{ payload.target | upper }}",
        "mode": "{{ params.waf_mode }}",
        "rule_count": {{ module.rand.number.integer(1, 5) }},
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf", "attack-rce"]
}