{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set geo = samples.geo_data | random -%}
{%- set url_entry = samples.urls | random -%}
{%- set url_path = url_entry.path -%}
{%- set method = url_entry.methods[0] -%}
{#- Bot user agents — scanners, empty UAs, known bad bots -#}
{%- set bot_ua_type = module.rand.weighted_choice(["scanner", "empty", "tool", "bot"], [35, 20, 25, 20]) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == bot_ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- if type_uas | length > 0 -%}
  {%- set ua = (type_uas | random).ua -%}
{%- else -%}
  {%- set ua = "" -%}
{%- endif -%}
{%- set http_version = module.rand.weighted_choice(["1.0", "1.1", "2.0"], [30, 50, 20]) -%}
{%- set bot_reasons = [
  "Known malicious bot detected",
  "Automated scanner detected",
  "Empty or missing User-Agent",
  "Known vulnerability scanner",
  "Suspicious crawling pattern",
  "Bot impersonating legitimate browser"
] -%}
{%- set reason = bot_reasons | random -%}
{%- set anomaly_score = module.rand.weighted_choice([5, 10, 15], [30, 45, 25]) -%}
{%- set action = module.rand.weighted_choice(["blocked", "captcha", "logged"], [60, 20, 20]) -%}
{%- if action == "blocked" -%}
  {%- set status_code = 403 -%}
  {%- set event_action = "denied" -%}
  {%- set outcome = "failure" -%}
{%- elif action == "captcha" -%}
  {%- set status_code = 403 -%}
  {%- set event_action = "denied" -%}
  {%- set outcome = "failure" -%}
{%- else -%}
  {%- set status_code = 200 -%}
  {%- set event_action = "allowed" -%}
  {%- set outcome = "success" -%}
{%- endif -%}
{%- set request_bytes = module.rand.number.integer(150, 1200) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "{{ event_action }}",
        "category": ["web", "intrusion_detection"],
        "dataset": "waf.log",
        "kind": "alert",
        "module": "waf",
        "outcome": "{{ outcome }}",
        "severity": 4,
        "type": ["access", "{{ event_action }}"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "status_code": {{ status_code }}
        },
        "version": "{{ http_version }}"
    },
    "message": "{{ reason }}",
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "rule": {
        "category": "BOT-DETECTION",
        "id": "bot-{{ module.rand.number.integer(1000, 9999) }}",
        "name": "{{ reason }}",
        "ruleset": "Bot Management"
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "threat": {
        "framework": "MITRE ATT&CK",
        "tactic": {
            "id": "TA0043",
            "name": "Reconnaissance",
            "reference": "https://attack.mitre.org/tactics/TA0043/"
        },
        "technique": {
            "id": "T1595",
            "name": "Active Scanning",
            "reference": "https://attack.mitre.org/techniques/T1595/"
        }
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua }}"
    },
    "waf": {
        "action": "{{ action }}",
        "anomaly_score": {{ anomaly_score }},
        "bot_score": {{ module.rand.number.integer(75, 99) }},
        "mode": "{{ params.waf_mode }}",
        "rule_count": 1,
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf", "bot-detection"]
}