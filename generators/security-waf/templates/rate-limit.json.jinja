{%- set txid = shared.get('tx_counter', 1000000) -%}
{%- do shared.set('tx_counter', txid + 1) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set geo = samples.geo_data | random -%}
{%- set target_paths = ["/api/v1/auth/login", "/api/v1/auth/refresh", "/api/v1/search", "/api/v1/users", "/api/v1/orders", "/login", "/register"] -%}
{%- set url_path = target_paths | random -%}
{%- set method = module.rand.weighted_choice(["POST", "GET"], [65, 35]) -%}
{%- set ua_type = module.rand.weighted_choice(["tool", "browser", "scanner"], [45, 35, 20]) -%}
{%- set type_uas = [] -%}
{%- for ua in samples.user_agents if ua.type == ua_type -%}
  {%- do type_uas.append(ua) -%}
{%- endfor -%}
{%- if type_uas | length > 0 -%}
  {%- set ua = (type_uas | random).ua -%}
{%- else -%}
  {%- set ua = "python-requests/2.31.0" -%}
{%- endif -%}
{%- set http_version = module.rand.weighted_choice(["1.1", "2.0"], [55, 45]) -%}
{%- set request_count = module.rand.number.integer(100, 2000) -%}
{%- set window_seconds = module.rand.weighted_choice([60, 300, 600], [50, 30, 20]) -%}
{%- set request_bytes = module.rand.number.integer(200, 1500) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "id": "{{ params.agent_id }}",
        "name": "{{ params.hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "data_stream": {
        "dataset": "waf.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ params.server_ip }}",
        "ip": "{{ params.server_ip }}",
        "port": 443
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "denied",
        "category": ["web", "intrusion_detection"],
        "dataset": "waf.log",
        "kind": "alert",
        "module": "waf",
        "outcome": "failure",
        "severity": 3,
        "type": ["access", "denied"]
    },
    "host": {
        "hostname": "{{ params.hostname }}",
        "name": "{{ params.hostname }}"
    },
    "http": {
        "request": {
            "bytes": {{ request_bytes }},
            "method": "{{ method }}"
        },
        "response": {
            "status_code": 429
        },
        "version": "{{ http_version }}"
    },
    "message": "Rate limit exceeded: {{ request_count }} requests in {{ window_seconds }}s window",
    "network": {
        "protocol": "https",
        "transport": "tcp",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.hostname }}",
        "product": "WAF",
        "type": "waf",
        "vendor": "{{ params.waf_vendor }}"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ params.server_ip }}"]
    },
    "rule": {
        "category": "RATE-LIMITING",
        "id": "rate-{{ module.rand.weighted_choice([1001, 1002, 1003], [50, 30, 20]) }}",
        "name": "Rate limit exceeded for {{ url_path }}",
        "ruleset": "Rate Limiting"
    },
    "source": {
        "address": "{{ src_ip }}",
        "geo": {
            "city_name": "{{ geo.city }}",
            "country_iso_code": "{{ geo.country_code }}",
            "country_name": "{{ geo.country }}",
            "location": {
                "lat": {{ geo.lat }},
                "lon": {{ geo.lon }}
            }
        },
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "threat": {
        "framework": "MITRE ATT&CK",
        "tactic": {
            "id": "TA0040",
            "name": "Impact",
            "reference": "https://attack.mitre.org/tactics/TA0040/"
        },
        "technique": {
            "id": "T1499",
            "name": "Endpoint Denial of Service",
            "reference": "https://attack.mitre.org/techniques/T1499/"
        }
    },
    "url": {
        "domain": "{{ params.server_name }}",
        "original": "{{ url_path }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user_agent": {
        "original": "{{ ua }}"
    },
    "waf": {
        "action": "blocked",
        "anomaly_score": 0,
        "mode": "{{ params.waf_mode }}",
        "rate_limit": {
            "requests": {{ request_count }},
            "window_seconds": {{ window_seconds }}
        },
        "rule_count": 1,
        "transaction_id": "{{ params.hostname }}-{{ txid }}"
    },
    "tags": ["waf", "rate-limit"]
}