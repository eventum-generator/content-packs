{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, event_block, source_block, user_block, user_agent_block, related_block, okta_actor_block, okta_auth_context_block, okta_client_block, okta_debug_block, okta_outcome_block, okta_transaction_block, okta_request_block, okta_security_context_block -%}
{%- set user = samples.users | random -%}
{%- set ip_row = samples.source_ips | random -%}
{%- set ua = samples.user_agents | random -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{%- set session_id = module.rand.crypto.uuid4() -%}
{%- set request_id = module.rand.crypto.uuid4() -%}
{%- set transaction_id = request_id -%}
{#- Store session for correlation -#}
{%- set sessions = shared.get('active_sessions', []) -%}
{%- do sessions.append({"user_id": user.id, "user_email": user.email, "display_name": user.display_name, "alternate_id": user.alternate_id, "src_ip": ip_row.ip, "session_id": session_id, "ts": timestamp.isoformat()}) -%}
{%- if sessions | length > 100 -%}{%- do sessions.pop(0) -%}{%- endif -%}
{%- do shared.set('active_sessions', sessions) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    "client": {
        "geo": {
            "city_name": {{ ip_row.city | tojson }},
            "country_name": {{ ip_row.country | tojson }},
            "location": {
                "lat": {{ ip_row.lat }},
                "lon": {{ ip_row.lon }}
            },
            "region_name": {{ ip_row.state | tojson }}
        },
        "ip": "{{ ip_row.ip }}",
        "user": {
            "email": "{{ user.email }}",
            "full_name": "{{ user.display_name }}",
            "id": "{{ user.id }}",
            "name": "{{ user.alternate_id }}"
        }
    },
    {{ ecs_block() }},
    {{ event_block("user.session.start", ["session", "authentication"], event_id, "success", ["start", "info"]) }},
    {{ source_block(ip_row, user) }},
    {{ user_block(user) }},
    {{ user_agent_block(ua) }},
    {{ related_block([ip_row.ip], [user.display_name, user.alternate_id]) }},
    "okta": {
        {{ okta_actor_block(user) }},
        {{ okta_auth_context_block(session_id, 0, "PASSWORD") }},
        {{ okta_client_block(ip_row, ua) }},
        {{ okta_debug_block(request_id, "/api/v1/authn", "false") }},
        "display_message": "User login to Okta",
        "event_type": "user.session.start",
        {{ okta_outcome_block("SUCCESS", none) }},
        {{ okta_request_block(ip_row) }},
        {{ okta_transaction_block(transaction_id, "WEB") }},
        "severity": "INFO",
        {{ okta_security_context_block(ip_row) }},
        "version": "0",
        "uuid": "{{ event_id }}"
    },
    "tags": ["forwarded", "okta-system"]
}
