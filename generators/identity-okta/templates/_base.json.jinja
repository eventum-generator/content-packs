{#- Shared macros for Okta System Log events (ECS-compatible) -#}
{#- Import with: {% from 'templates/_base.json.jinja' import agent_block, ecs_block, event_block, client_block, source_block, user_block, user_agent_block, related_block, okta_actor_block, okta_auth_context_block, okta_client_block, okta_debug_block, okta_outcome_block, okta_transaction_block, okta_target_block, okta_request_block, okta_security_context_block, pick_user, pick_ip, pick_ua, pick_app %} -#}

{%- macro agent_block(params) -%}
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ params.agent_name }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    }
{%- endmacro -%}

{%- macro ecs_block() -%}
    "ecs": {
        "version": "8.11.0"
    }
{%- endmacro -%}

{%- macro event_block(action, categories, event_id, outcome, types) -%}
    "event": {
        "action": {{ action | tojson }},
        "category": {{ categories | tojson }},
        "dataset": "okta.system",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "okta",
        "outcome": "{{ outcome }}",
        "type": {{ types | tojson }}
    }
{%- endmacro -%}

{%- macro client_block(ip_row, ua) -%}
    "client": {
        "geo": {
            "city_name": {{ ip_row.city | tojson }},
            "country_name": {{ ip_row.country | tojson }},
            "location": {
                "lat": {{ ip_row.lat }},
                "lon": {{ ip_row.lon }}
            },
            "region_name": {{ ip_row.state | tojson }}
        },
        "ip": "{{ ip_row.ip }}",
        "user": {
            "email": "{{ ua._user.email }}",
            "full_name": "{{ ua._user.display_name }}",
            "id": "{{ ua._user.id }}",
            "name": "{{ ua._user.alternate_id }}"
        }
    }
{%- endmacro -%}

{%- macro source_block(ip_row, user) -%}
    "source": {
        "ip": "{{ ip_row.ip }}",
        "user": {
            "email": "{{ user.email }}",
            "full_name": "{{ user.display_name }}",
            "id": "{{ user.id }}",
            "name": "{{ user.alternate_id }}"
        }
    }
{%- endmacro -%}

{%- macro user_block(user) -%}
    "user": {
        "email": "{{ user.email }}",
        "full_name": "{{ user.display_name }}",
        "id": "{{ user.id }}",
        "name": "{{ user.alternate_id }}"
    }
{%- endmacro -%}

{%- macro user_agent_block(ua) -%}
    "user_agent": {
        "device": {
            "name": "{{ ua.device }}"
        },
        "name": "{{ ua.browser }}",
        "original": {{ ua.raw | tojson }},
        "os": {
            "name": "{{ ua.os }}"
        }
    }
{%- endmacro -%}

{%- macro related_block(ips, users) -%}
    "related": {
        "ip": {{ ips | tojson }},
        "user": {{ users | tojson }}
    }
{%- endmacro -%}

{%- macro okta_actor_block(user) -%}
        "actor": {
            "alternate_id": "{{ user.alternate_id }}",
            "display_name": "{{ user.display_name }}",
            "id": "{{ user.id }}",
            "type": "User"
        }
{%- endmacro -%}

{%- macro okta_auth_context_block(session_id, step, credential_type) -%}
        "authentication_context": {
            "authentication_provider": "OKTA_AUTHENTICATION_PROVIDER",
            "authentication_step": {{ step }},
            "credential_type": {{ credential_type | tojson }},
            "external_session_id": "{{ session_id }}"
        }
{%- endmacro -%}

{%- macro okta_client_block(ip_row, ua) -%}
        "client": {
            "device": "{{ ua.device }}",
            "ip": "{{ ip_row.ip }}",
            "user_agent": {
                "browser": "{{ ua.browser }}",
                "os": "{{ ua.os }}",
                "raw_user_agent": {{ ua.raw | tojson }}
            },
            "zone": "null"
        }
{%- endmacro -%}

{%- macro okta_debug_block(request_id, request_uri, threat_suspected) -%}
        "debug_context": {
            "debug_data": {
                "request_id": "{{ request_id }}",
                "request_uri": {{ request_uri | tojson }},
                "threat_suspected": "{{ threat_suspected }}",
                "url": {{ request_uri | tojson }}
            }
        }
{%- endmacro -%}

{%- macro okta_outcome_block(result, reason) -%}
        "outcome": {
            "reason": {{ reason | tojson }},
            "result": "{{ result }}"
        }
{%- endmacro -%}

{%- macro okta_transaction_block(transaction_id, tx_type) -%}
        "transaction": {
            "id": "{{ transaction_id }}",
            "type": "{{ tx_type }}"
        }
{%- endmacro -%}

{%- macro okta_target_block(targets) -%}
        "target": [
{%- for t in targets %}
            {
                "alternateId": {{ t.alternate_id | tojson }},
                "displayName": {{ t.display_name | tojson }},
                "id": {{ t.id | tojson }},
                "type": {{ t.type | tojson }}
            }{{ "," if not loop.last }}
{%- endfor %}
        ]
{%- endmacro -%}

{%- macro okta_request_block(ip_row) -%}
        "request": {
            "ip_chain": [
                {
                    "geographicalContext": {
                        "city": {{ ip_row.city | tojson }},
                        "country": {{ ip_row.country | tojson }},
                        "geolocation": {
                            "lat": {{ ip_row.lat }},
                            "lon": {{ ip_row.lon }}
                        },
                        "postalCode": {{ ip_row.postal_code | tojson }},
                        "state": {{ ip_row.state | tojson }}
                    },
                    "ip": "{{ ip_row.ip }}",
                    "version": "V4"
                }
            ]
        }
{%- endmacro -%}

{%- macro okta_security_context_block(ip_row) -%}
        "security_context": {
            "as": {
                "number": {{ ip_row.asn }},
                "organization": {
                    "name": {{ ip_row.isp | tojson }}
                }
            },
            "domain": {{ ip_row.domain | tojson }},
            "is_proxy": false,
            "isp": {{ ip_row.isp | tojson }}
        }
{%- endmacro -%}

{#- Helper macros for picking sample data -#}

{%- macro pick_user(users) -%}
{{- users | random -}}
{%- endmacro -%}

{%- macro pick_ip(source_ips) -%}
{{- source_ips | random -}}
{%- endmacro -%}

{%- macro pick_ua(user_agents) -%}
{{- user_agents | random -}}
{%- endmacro -%}

{%- macro pick_app(applications) -%}
{{- applications | random -}}
{%- endmacro -%}
