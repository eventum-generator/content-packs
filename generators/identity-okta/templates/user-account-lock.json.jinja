{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, event_block, source_block, user_block, user_agent_block, related_block, okta_actor_block, okta_auth_context_block, okta_client_block, okta_debug_block, okta_outcome_block, okta_transaction_block, okta_target_block, okta_request_block, okta_security_context_block -%}
{%- set user = samples.users | random -%}
{%- set ip_row = samples.source_ips | random -%}
{%- set ua = samples.user_agents | random -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{%- set request_id = module.rand.crypto.uuid4() -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    "client": {
        "geo": {
            "city_name": {{ ip_row.city | tojson }},
            "country_name": {{ ip_row.country | tojson }},
            "location": {
                "lat": {{ ip_row.lat }},
                "lon": {{ ip_row.lon }}
            },
            "region_name": {{ ip_row.state | tojson }}
        },
        "ip": "{{ ip_row.ip }}",
        "user": {
            "email": "{{ user.email }}",
            "full_name": "{{ user.display_name }}",
            "id": "{{ user.id }}",
            "name": "{{ user.alternate_id }}"
        }
    },
    {{ ecs_block() }},
    {{ event_block("user.account.lock", ["iam"], event_id, "success", ["user", "change"]) }},
    {{ source_block(ip_row, user) }},
    {{ user_block(user) }},
    {{ user_agent_block(ua) }},
    {{ related_block([ip_row.ip], [user.display_name, user.alternate_id]) }},
    "okta": {
        {{ okta_actor_block(user) }},
        {{ okta_client_block(ip_row, ua) }},
        {{ okta_debug_block(request_id, "/api/v1/authn", "false") }},
        "display_message": "Okta user locked out",
        "event_type": "user.account.lock",
        {{ okta_outcome_block("SUCCESS", "MAX_LOGIN_ATTEMPTS_EXCEEDED") }},
        {{ okta_request_block(ip_row) }},
        {{ okta_target_block([
            {"alternate_id": user.alternate_id, "display_name": user.display_name, "id": user.id, "type": "User"}
        ]) }},
        {{ okta_transaction_block(request_id, "WEB") }},
        "severity": "WARN",
        {{ okta_security_context_block(ip_row) }},
        "version": "0",
        "uuid": "{{ event_id }}"
    },
    "tags": ["forwarded", "okta-system"]
}
