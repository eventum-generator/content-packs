{#- Shared macros for Kaspersky Secure Mail Gateway (KSMG) events -#}
{#- Import with: {% from 'templates/macros/envelope.jinja' import agent_block, ecs_block, observer_block, related_block %} -#}

{%- macro agent_block(params) -%}
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.get('agent_id', 'a1b2c3d4-e5f6-7890-abcd-ef1234567890') }}",
        "name": "{{ params.get('ksmg_hostname', 'ksmg-node01') }}",
        "type": "filebeat",
        "version": "{{ params.get('agent_version', '8.17.0') }}"
    }
{%- endmacro -%}

{%- macro ecs_block() -%}
    "ecs": {
        "version": "8.17.0"
    }
{%- endmacro -%}

{%- macro observer_block(params) -%}
    "observer": {
        "hostname": "{{ params.get('ksmg_hostname', 'ksmg-node01') }}.{{ params.get('domain', 'corp.example.com') }}",
        "ip": ["{{ params.get('ksmg_ip', '10.1.0.20') }}"],
        "product": "Kaspersky Secure Mail Gateway",
        "type": "email-gateway",
        "vendor": "Kaspersky",
        "version": "{{ params.get('ksmg_version', '2.0.1.6960') }}"
    }
{%- endmacro -%}

{%- macro related_block(ips, users, hosts) -%}
    "related": {
        {%- if hosts %}
        "hosts": {{ hosts | tojson }},
        {%- endif %}
        "ip": {{ ips | tojson }},
        "user": {{ users | tojson }}
    }
{%- endmacro -%}
