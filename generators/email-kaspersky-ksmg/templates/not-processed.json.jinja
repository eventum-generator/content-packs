{#- KSMG LMS_EV_SCAN_LOGIC_ALL_NOT_PROCESSED — message could not be scanned by any module.
     Occurs when scanning fails due to errors, timeouts, or resource exhaustion. -#}
{%- from 'templates/macros/envelope.jinja' import agent_block, ecs_block, observer_block, related_block -%}
{%- set ext = samples.external_domains.weighted_pick('weight') -%}
{%- set sender_user = module.faker.locale.en_US.user_name() -%}
{%- set sender_email = sender_user ~ '@' ~ ext.domain -%}
{%- set rcpt = samples.internal_users.pick() -%}
{%- set recipient_email = rcpt.username ~ '@' ~ params.get('domain', 'corp.example.com') -%}
{%- set message_id = '<' ~ module.rand.crypto.uuid4() ~ '@' ~ ext.domain ~ '>' -%}
{%- set msg_size = module.rand.number.clamp(module.rand.number.lognormal(10, 1.5) | int, 500, 30000000) -%}
{%- set error_reason = module.rand.weighted_choice(
  ["ScanTimeout", "InternalError", "DatabaseUpdateInProgress", "ResourceExhausted", "ModuleUnavailable"],
  [30, 25, 20, 15, 10]
) -%}
{%- set subject_cat = module.rand.weighted_choice(["business", "automated"], [60, 40]) -%}
{%- set subject = (samples.subjects | selectattr("category", "equalto", subject_cat) | list | random).text -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ ecs_block() }},
    "email": {
        "direction": "inbound",
        "from": {
            "address": ["{{ sender_email }}"]
        },
        "message_id": {{ message_id | tojson }},
        "subject": {{ subject | tojson }},
        "to": {
            "address": ["{{ recipient_email }}"]
        }
    },
    "event": {
        "action": "Skip",
        "category": ["email"],
        "dataset": "kaspersky_ksmg.scanlogic",
        "kind": "event",
        "module": "kaspersky_ksmg",
        "outcome": "failure",
        "reason": {{ error_reason | tojson }},
        "severity": 6,
        "type": ["info", "error"]
    },
    "kaspersky": {
        "ksmg": {
            "event_class": "LMS_EV_SCAN_LOGIC_ALL_NOT_PROCESSED",
            "message_id": {{ message_id | tojson }},
            "message_size": {{ msg_size }},
            "error_reason": "{{ error_reason }}",
            "action": "Skip",
            "rule": "{{ (samples.rules.weighted_pick('weight')).name }}",
            "direction": "inbound",
            "node": "{{ params.get('ksmg_hostname', 'ksmg-node01') }}"
        }
    },
    "log": {
        "level": "error"
    },
    {{ observer_block(params) }},
    {{ related_block([ext.ip, params.get('ksmg_ip', '10.1.0.20')], [sender_user, rcpt.username], [params.get('ksmg_hostname', 'ksmg-node01')]) }},
    "source": {
        "domain": "{{ ext.domain }}",
        "ip": "{{ ext.ip }}"
    },
    "tags": ["kaspersky-ksmg", "forwarded"]
}
