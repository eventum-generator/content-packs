{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, pick_az, flow_timestamps -%}
{%- set record_id = shared.get('record_counter', 0) -%}
{%- set account = samples.accounts | random -%}
{%- set region = samples.regions | random -%}
{%- set az_id = pick_az(region) -%}
{%- set eni = samples.enis | random -%}
{#- SKIPDATA: flow log service skipped records during the aggregation interval
    due to internal capacity constraints. All traffic fields are '-'. -#}
{%- set ts_data = flow_timestamps(timestamp, 60, 600).split('|') -%}
{%- set start_ts = ts_data[0] | int -%}
{%- set end_ts = ts_data[1] | int -%}
{%- set start_iso = ts_data[2] -%}
{%- set end_iso = ts_data[3] -%}
{
    "@timestamp": "{{ end_iso }}",
    {{ agent_block(params) }},
    {{ cloud_block(account, region, az_id) }},
    {{ ecs_block() }},
    "event": {
        "action": "skipdata",
        "category": ["network"],
        "dataset": "aws.vpcflow",
        "end": "{{ end_iso }}",
        "kind": "event",
        "module": "aws",
        "original": {{ ("2 " ~ account.account_id ~ " " ~ eni.eni_id ~ " - - - - - - - " ~ start_ts ~ " " ~ end_ts ~ " - SKIPDATA") | tojson }},
        "start": "{{ start_iso }}",
        "type": ["info"]
    },
    "network": {
        "type": "ipv4"
    },
    "aws": {
        "vpcflow": {
            "version": 2,
            "account_id": "{{ account.account_id }}",
            "interface_id": "{{ eni.eni_id }}",
            "start": {{ start_ts }},
            "end": {{ end_ts }},
            "action": "-",
            "log_status": "SKIPDATA",
            "instance_id": "{{ eni.instance_id }}",
            "vpc_id": "{{ eni.vpc_id }}",
            "subnet_id": "{{ eni.subnet_id }}",
            "type": "IPv4"
        }
    }
}
{%- do shared.set('record_counter', record_id + 1) -%}
