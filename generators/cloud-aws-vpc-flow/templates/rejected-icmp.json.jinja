{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, pick_az, gen_subnet_ip, flow_timestamps, detect_direction, vpcflow_block, original_log -%}
{%- set record_id = shared.get('record_counter', 0) -%}
{%- set account = samples.accounts | random -%}
{%- set region = samples.regions | random -%}
{%- set az_id = pick_az(region) -%}
{%- set eni = samples.enis | random -%}
{#- Rejected ICMP: blocked pings from external, security group denies -#}
{%- set icmp_type = module.rand.weighted_choice([8, 0, 3, 11, 13, 17], [50, 20, 10, 5, 10, 5]) -%}
{#- Mostly inbound (external ping attempts blocked by SG) -#}
{%- set dir_type = module.rand.weighted_choice(["inbound", "internal", "outbound"], [80, 10, 10]) -%}
{%- if dir_type == "inbound" -%}
    {%- set src_ip = module.rand.network.ip_v4_public() -%}
    {%- set dst_ip = gen_subnet_ip(eni.subnet_cidr) -%}
{%- elif dir_type == "internal" -%}
    {%- set other_eni = samples.enis | random -%}
    {%- set src_ip = gen_subnet_ip(eni.subnet_cidr) -%}
    {%- set dst_ip = gen_subnet_ip(other_eni.subnet_cidr) -%}
{%- else -%}
    {%- set src_ip = gen_subnet_ip(eni.subnet_cidr) -%}
    {%- set dst_ip = module.rand.network.ip_v4_public() -%}
{%- endif -%}
{%- set src_port = 0 -%}
{%- set dst_port = icmp_type -%}
{#- Single attempt -#}
{%- set packets = module.rand.number.integer(1, 3) -%}
{%- set bytes = packets * module.rand.number.integer(56, 84) -%}
{%- set ts_data = flow_timestamps(timestamp, 0, 5).split('|') -%}
{%- set start_ts = ts_data[0] | int -%}
{%- set end_ts = ts_data[1] | int -%}
{%- set start_iso = ts_data[2] -%}
{%- set end_iso = ts_data[3] -%}
{%- set direction = detect_direction(src_ip, dst_ip) | trim -%}
{
    "@timestamp": "{{ end_iso }}",
    {{ agent_block(params) }},
    {{ cloud_block(account, region, az_id) }},
    "destination": {
        "address": "{{ dst_ip }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    {{ ecs_block() }},
    "event": {
        "action": "reject",
        "category": ["network"],
        "dataset": "aws.vpcflow",
        "end": "{{ end_iso }}",
        "kind": "event",
        "module": "aws",
        "original": {{ original_log(account, eni, src_ip, dst_ip, src_port, dst_port, 1, packets, bytes, start_ts, end_ts, "REJECT", "OK") | tojson }},
        "outcome": "failure",
        "start": "{{ start_iso }}",
        "type": ["connection", "denied"]
    },
    "network": {
        "bytes": {{ bytes }},
        "direction": "{{ direction }}",
        "iana_number": "1",
        "packets": {{ packets }},
        "transport": "icmp",
        "type": "ipv4"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "source": {
        "address": "{{ src_ip }}",
        "bytes": {{ bytes }},
        "ip": "{{ src_ip }}",
        "packets": {{ packets }},
        "port": {{ src_port }}
    },
    {{ vpcflow_block(eni, account, src_ip, dst_ip, src_port, dst_port, 1, packets, bytes, start_ts, end_ts, "REJECT", "OK") }}
}
{%- do shared.set('record_counter', record_id + 1) -%}
