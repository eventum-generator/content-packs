{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, pick_az, gen_subnet_ip, flow_timestamps, detect_direction, vpcflow_block, original_log -%}
{%- set record_id = shared.get('record_counter', 0) -%}
{%- set account = samples.accounts | random -%}
{%- set region = samples.regions | random -%}
{%- set az_id = pick_az(region) -%}
{%- set eni = samples.enis | random -%}
{#- ICMP: ping, traceroute, path MTU discovery -#}
{#- ICMP type as "port": 0=Echo Reply, 8=Echo Request, 3=Dest Unreachable, 11=Time Exceeded -#}
{%- set icmp_type = module.rand.weighted_choice([8, 0, 3, 11], [45, 35, 15, 5]) -%}
{#- ICMP mostly internal (health checks, monitoring) -#}
{%- set dir_type = module.rand.weighted_choice(["internal", "outbound", "inbound"], [60, 25, 15]) -%}
{%- if dir_type == "internal" -%}
    {%- set other_eni = samples.enis | random -%}
    {%- set src_ip = gen_subnet_ip(eni.subnet_cidr) -%}
    {%- set dst_ip = gen_subnet_ip(other_eni.subnet_cidr) -%}
{%- elif dir_type == "outbound" -%}
    {%- set src_ip = gen_subnet_ip(eni.subnet_cidr) -%}
    {%- set dst_ip = module.rand.network.ip_v4_public() -%}
{%- else -%}
    {%- set src_ip = module.rand.network.ip_v4_public() -%}
    {%- set dst_ip = gen_subnet_ip(eni.subnet_cidr) -%}
{%- endif -%}
{#- ICMP: port fields represent type and code -#}
{%- set src_port = 0 -%}
{%- set dst_port = icmp_type -%}
{#- ICMP flows: small packet counts -#}
{%- set packets = module.rand.number.integer(1, 10) -%}
{%- set bytes = packets * module.rand.number.integer(56, 128) -%}
{#- Short duration -#}
{%- set ts_data = flow_timestamps(timestamp, 1, 30).split('|') -%}
{%- set start_ts = ts_data[0] | int -%}
{%- set end_ts = ts_data[1] | int -%}
{%- set start_iso = ts_data[2] -%}
{%- set end_iso = ts_data[3] -%}
{%- set direction = detect_direction(src_ip, dst_ip) | trim -%}
{
    "@timestamp": "{{ end_iso }}",
    {{ agent_block(params) }},
    {{ cloud_block(account, region, az_id) }},
    "destination": {
        "address": "{{ dst_ip }}",
        "ip": "{{ dst_ip }}",
        "port": {{ dst_port }}
    },
    {{ ecs_block() }},
    "event": {
        "action": "accept",
        "category": ["network"],
        "dataset": "aws.vpcflow",
        "end": "{{ end_iso }}",
        "kind": "event",
        "module": "aws",
        "original": {{ original_log(account, eni, src_ip, dst_ip, src_port, dst_port, 1, packets, bytes, start_ts, end_ts, "ACCEPT", "OK") | tojson }},
        "outcome": "success",
        "start": "{{ start_iso }}",
        "type": ["connection", "allowed"]
    },
    "network": {
        "bytes": {{ bytes }},
        "direction": "{{ direction }}",
        "iana_number": "1",
        "packets": {{ packets }},
        "transport": "icmp",
        "type": "ipv4"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "source": {
        "address": "{{ src_ip }}",
        "bytes": {{ bytes }},
        "ip": "{{ src_ip }}",
        "packets": {{ packets }},
        "port": {{ src_port }}
    },
    {{ vpcflow_block(eni, account, src_ip, dst_ip, src_port, dst_port, 1, packets, bytes, start_ts, end_ts, "ACCEPT", "OK") }}
}
{%- do shared.set('record_counter', record_id + 1) -%}
