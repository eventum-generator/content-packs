{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set success = module.rand.chance(0.95) -%}
{%- set update_type = module.rand.weighted_choice(['databases', 'application_modules', 'patches'], [70, 20, 10]) -%}
{%- set db_version_major = module.rand.number.integer(20250101, 20260306) -%}
{%- set db_records = module.rand.number.integer(25000000, 30000000) -%}
{%- set download_size = module.rand.number.integer(512000, 104857600) -%}
{
    {{ event_base(host, ["package"], ["change"], 1 if success else 2, "success" if success else "failure", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
{%- if success %}
            "event_class_id": "GNRL_EV_BASES_UPDATED",
            "event_type": "Databases updated successfully",
{%- else %}
            "event_class_id": "GNRL_EV_BASES_OUTDATED",
            "event_type": "Databases are out of date",
{%- endif %}
            "component": "Update",
            "result": {{ ("Success" if success else "Update source unavailable") | tojson }},
            "update": {
                "type": {{ update_type | tojson }},
                "database_version": "{{ db_version_major }}",
                "database_records": {{ db_records }},
                "download_size_bytes": {{ download_size }},
                "source": {{ params.get('update_source', 'https://dnl-01.geo.kaspersky.com/') | tojson }}
            },
            "group": {{ host.group | tojson }}
        }
    },
    "user": {
        "name": "SYSTEM",
        "domain": "NT AUTHORITY"
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": ["SYSTEM"]
    }
}