{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set policy_action = module.rand.weighted_choice(['applied', 'violation', 'changed'], [60, 25, 15]) -%}
{%- set policy_name = module.rand.choice([
  'Default Endpoint Policy',
  'Server Protection Policy',
  'Workstation Protection Policy',
  'Laptop Protection Policy',
  'Executive Devices Policy'
]) -%}
{%- set policy_component = module.rand.choice([
  'Application Control',
  'Device Control',
  'Web Control',
  'Adaptive Anomaly Control',
  'Firewall'
]) -%}
{%- if policy_action == 'violation' -%}
  {%- set violation_detail = module.rand.choice([
    'Blocked application launch: unauthorized software',
    'Blocked device connection: removable drive',
    'Blocked web resource: category Gambling',
    'Blocked web resource: category Social Networks',
    'Adaptive Anomaly Control triggered: suspicious script execution',
    'Firewall rule blocked: outbound connection to prohibited host'
  ]) -%}
  {%- set severity = 3 -%}
  {%- set event_class = 'GNRL_EV_APP_CTRL_BLOCKED' -%}
{%- elif policy_action == 'changed' -%}
  {%- set violation_detail = 'Policy settings changed by administrator' -%}
  {%- set severity = 1 -%}
  {%- set event_class = 'KLSRV_EV_POLICY_CHANGED' -%}
{%- else -%}
  {%- set violation_detail = 'Policy applied successfully' -%}
  {%- set severity = 1 -%}
  {%- set event_class = 'KLSRV_EV_POLICY_APPLIED' -%}
{%- endif -%}
{
    {{ event_base(host, ["configuration"], ["change" if policy_action == 'changed' else "info"], severity, "success" if policy_action != 'violation' else "failure", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": {{ event_class | tojson }},
            "event_type": {{ ("Policy violation" if policy_action == 'violation' else ("Policy changed" if policy_action == 'changed' else "Policy applied")) | tojson }},
            "component": {{ policy_component | tojson }},
            "result": {{ violation_detail | tojson }},
            "policy": {
                "name": {{ policy_name | tojson }},
                "action": {{ policy_action | tojson }},
                "component": {{ policy_component | tojson }}
            },
            "group": {{ host.group | tojson }}
        }
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}