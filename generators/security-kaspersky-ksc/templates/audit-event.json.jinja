{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set admin_user = module.rand.choice(['admin', 'ksc_admin', 'it_admin', 'sec_admin']) -%}
{%- set audit_action = module.rand.weighted_choice(['login', 'logout', 'policy_modified', 'task_created', 'task_deleted', 'group_modified', 'user_role_changed', 'report_generated', 'siem_export_started'], [25, 15, 15, 10, 5, 10, 5, 10, 5]) -%}
{%- set action_details = {
  'login': {'desc': 'Console login successful', 'type': 'authentication_success', 'cat': 'authentication', 'component': 'Console'},
  'logout': {'desc': 'Console logout', 'type': 'end', 'cat': 'session', 'component': 'Console'},
  'policy_modified': {'desc': 'Security policy modified', 'type': 'change', 'cat': 'configuration', 'component': 'Policy Management'},
  'task_created': {'desc': 'New task created', 'type': 'creation', 'cat': 'configuration', 'component': 'Task Management'},
  'task_deleted': {'desc': 'Task deleted', 'type': 'deletion', 'cat': 'configuration', 'component': 'Task Management'},
  'group_modified': {'desc': 'Administration group structure modified', 'type': 'change', 'cat': 'configuration', 'component': 'Group Management'},
  'user_role_changed': {'desc': 'User role assignment changed', 'type': 'change', 'cat': 'iam', 'component': 'User Management'},
  'report_generated': {'desc': 'Report generated', 'type': 'access', 'cat': 'configuration', 'component': 'Reporting'},
  'siem_export_started': {'desc': 'SIEM event export configuration changed', 'type': 'change', 'cat': 'configuration', 'component': 'SIEM Integration'}
} -%}
{%- set detail = action_details[audit_action] -%}
{%- set src_ip = module.rand.choice(['10.1.20.50', '10.1.20.55', '10.1.30.5', '10.1.10.21']) -%}
{
    {{ event_base(host, [detail.cat], [detail.type], 1, "success", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": "KLAUD_EV_SERVERACTION",
            "event_type": "Audit: {{ audit_action | replace('_', ' ') }}",
            "component": {{ detail.component | tojson }},
            "result": {{ detail.desc | tojson }},
            "audit": {
                "action": {{ audit_action | tojson }},
                "description": {{ detail.desc | tojson }},
                "admin_user": {{ admin_user | tojson }},
                "source_ip": {{ src_ip | tojson }}
            }
        }
    },
    "source": {
        "ip": {{ src_ip | tojson }}
    },
    "user": {
        "name": {{ admin_user | tojson }},
        "domain": "CORP",
        "roles": ["KSC Administrator"]
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}, {{ params.get('ksc_server', 'KSC-SRV01') | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ src_ip | tojson }}],
        "user": [{{ admin_user | tojson }}]
    }
}