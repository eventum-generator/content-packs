{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set threat = samples.threat_scenarios.pick() -%}
{%- set malware_obj = samples.malware_paths.pick() -%}
{%- set malware_path = malware_obj.path | replace('%USERNAME%', user.username) -%}
{%- set sha256 = module.rand.string.hex(64) -%}
{%- set md5 = module.rand.string.hex(32) -%}
{%- set file_size = module.rand.number.integer(1024, 52428800) | int -%}
{%- set db_date = (timestamp - module.datetime.timedelta(hours=module.rand.number.integer(1, 48))).strftime('%Y-%m-%dT%H:%M:%S.000Z') -%}
{
    {{ event_base(host, ["malware"], ["info"], threat.severity, "success", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": {{ threat.event_class_id | tojson }},
            "event_type": {{ threat.event_name | tojson }},
            "component": {{ threat.component | tojson }},
            "result": {{ threat.result | tojson }},
            "threat": {
                "name": {{ threat.threat_name | tojson }},
                "level": {{ threat.threat_level | tojson }}
            },
            "object": {
                "type": {{ threat.object_type | tojson }},
                "name": {{ malware_path | tojson }},
                "path": {{ malware_path | tojson }}
            },
            "task": "Real-time protection",
            "database_release_date": {{ db_date | tojson }},
            "group": {{ host.group | tojson }}
        }
    },
    "file": {
        "name": {{ malware_path.split('\\') | last | tojson }},
        "path": {{ malware_path | tojson }},
        "size": {{ file_size }},
        "hash": {
            "sha256": {{ sha256 | tojson }},
            "md5": {{ md5 | tojson }}
        }
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}],
        "hash": [{{ sha256 | tojson }}, {{ md5 | tojson }}]
    }
}