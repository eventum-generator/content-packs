{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set attack = samples.attack_scenarios.pick() -%}
{%- set attacker_obj = samples.attacker_ips.pick() -%}
{%- set attacker_ip = attacker_obj.ip -%}
{%- set blocked = module.rand.chance(0.85) -%}
{
    {{ event_base(host, ["intrusion_detection"], ["info"], 4, "success" if blocked else "failure", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": "GNRL_EV_ATTACK_DETECTED",
            "event_type": "Network attack detected",
            "component": "Network Threat Protection",
            "result": {{ ("Blocked" if blocked else "Allowed") | tojson }},
            "attack": {
                "name": {{ attack.attack_name | tojson }},
                "protocol": {{ attack.protocol | tojson }}
            },
            "object": {
                "type": "Network packet",
                "name": {{ attacker_ip | tojson }}
            },
            "group": {{ host.group | tojson }}
        }
    },
    "source": {
        "ip": {{ attacker_ip | tojson }},
        "port": {{ module.rand.number.integer(1024, 65535) }}
    },
    "destination": {
        "ip": {{ host.ip | tojson }},
        "port": {{ attack.port if attack.port > 0 else module.rand.number.integer(1, 65535) }}
    },
    "network": {
        "transport": {{ attack.protocol | lower | tojson }},
        "direction": "inbound"
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ attacker_ip | tojson }}]
    }
}