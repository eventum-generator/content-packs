{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set status_type = module.rand.weighted_choice(['ok', 'warning', 'critical'], [55, 30, 15]) -%}
{%- if status_type == 'critical' -%}
  {%- set reason = module.rand.choice([
    'Real-time protection is disabled',
    'Device has not connected for a long time',
    'Databases have not been updated for a long time',
    'Full scan has not been performed for a long time',
    'Active threats are not resolved'
  ]) -%}
  {%- set event_class = 'KLSRV_HOST_STATUS_CRITICAL' -%}
  {%- set severity = 4 -%}
{%- elif status_type == 'warning' -%}
  {%- set reason = module.rand.choice([
    'Databases are out of date',
    'Full scan has not been performed recently',
    'License expires soon',
    'Computer restart required',
    'Application is not running'
  ]) -%}
  {%- set event_class = 'KLSRV_HOST_STATUS_WARNING' -%}
  {%- set severity = 2 -%}
{%- else -%}
  {%- set reason = 'Device is operating normally' -%}
  {%- set event_class = 'KLSRV_HOST_STATUS_OK' -%}
  {%- set severity = 1 -%}
{%- endif -%}
{%- set last_seen_offset = module.rand.number.integer(60, 86400) if status_type != 'critical' else module.rand.number.integer(86400, 604800) -%}
{
    {{ event_base(host, ["host"], ["info"], severity, "success", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": {{ event_class | tojson }},
            "event_type": "Device status changed",
            "component": "Administration Server",
            "result": {{ status_type | title | tojson }},
            "device": {
                "status": {{ status_type | tojson }},
                "status_reason": {{ reason | tojson }},
                "last_visible": "{{ (timestamp - module.datetime.timedelta(seconds=last_seen_offset)).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
                "real_time_protection": {{ (status_type != 'critical' or 'disabled' not in reason) | tojson | lower }},
                "encryption_status": {{ module.rand.choice(['Full', 'Partial', 'None']) | tojson }}
            },
            "group": {{ host.group | tojson }}
        }
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}]
    }
}