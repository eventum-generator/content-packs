{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set license_type = module.rand.weighted_choice(['valid', 'expiring_soon', 'exceeded', 'expired'], [45, 30, 15, 10]) -%}
{%- set license_key = module.rand.string.hex(8) | upper ~ '-' ~ module.rand.string.hex(8) | upper ~ '-' ~ module.rand.string.hex(8) | upper -%}
{%- set license_count = params.get('license_count', 500) | int -%}
{%- set used_count = module.rand.number.integer((license_count * 0.7) | int, (license_count * 1.15) | int) -%}
{%- if license_type == 'expired' -%}
  {%- set event_class = 'GNRL_EV_LICENSE_EXPIRATION' -%}
  {%- set event_name = 'License has expired' -%}
  {%- set severity = 4 -%}
  {%- set days_remaining = 0 -%}
{%- elif license_type == 'expiring_soon' -%}
  {%- set event_class = 'KLSRV_EV_LICENSE_SRV_EXPIRE_SOON' -%}
  {%- set event_name = 'License expires soon' -%}
  {%- set severity = 2 -%}
  {%- set days_remaining = module.rand.choice([1, 5, 15, 30]) -%}
{%- elif license_type == 'exceeded' -%}
  {%- set event_class = 'KLSRV_EV_LICENSE_CHECK_MORE_110' -%}
  {%- set event_name = 'License limit has been exceeded' -%}
  {%- set severity = 4 -%}
  {%- set days_remaining = module.rand.number.integer(30, 365) -%}
{%- else -%}
  {%- set event_class = 'GNRL_EV_LICENSE_OK' -%}
  {%- set event_name = 'License check successful' -%}
  {%- set severity = 1 -%}
  {%- set days_remaining = module.rand.number.integer(30, 365) -%}
{%- endif -%}
{
    {{ event_base(host, ["configuration"], ["info"], severity, "success" if license_type == 'valid' else "failure", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": {{ event_class | tojson }},
            "event_type": {{ event_name | tojson }},
            "component": "License Management",
            "result": {{ event_name | tojson }},
            "license": {
                "key": {{ license_key | tojson }},
                "type": {{ params.get('license_type', 'Kaspersky Endpoint Security for Business Advanced') | tojson }},
                "licensed_count": {{ license_count }},
                "used_count": {{ used_count }},
                "usage_percent": {{ ((used_count / license_count) * 100) | round(1) }},
                "days_remaining": {{ days_remaining }},
                "expiration_date": "{{ (timestamp + module.datetime.timedelta(days=days_remaining)).strftime('%Y-%m-%dT00:00:00.000Z') }}"
            },
            "group": {{ host.group | tojson }}
        }
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}]
    }
}