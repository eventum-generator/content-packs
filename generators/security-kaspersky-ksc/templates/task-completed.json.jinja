{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set task = samples.tasks.pick() -%}
{%- set success = module.rand.chance(0.92) -%}
{%- set duration_sec = module.rand.number.integer(30, 7200) -%}
{%- set objects_processed = module.rand.number.integer(100, 500000) if task.task_type == 'scan' else module.rand.number.integer(10, 5000) -%}
{%- set threats_found = module.rand.number.integer(0, 3) if task.task_type == 'scan' and module.rand.chance(0.08) else 0 -%}
{
    {{ event_base(host, ["package"], ["info"], 1 if success else 3, "success" if success else "failure", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": "GNRL_EV_TASK_STATE_CHANGED",
            "event_type": "Task completed",
            "component": {{ task.task_name | tojson }},
            "result": {{ ("Completed successfully" if success else "Completed with errors") | tojson }},
            "task": {
                "name": {{ task.task_name | tojson }},
                "display_name": {{ task.task_display | tojson }},
                "type": {{ task.task_type | tojson }},
                "duration_seconds": {{ duration_sec }},
                "objects_processed": {{ objects_processed }},
                "threats_detected": {{ threats_found }}
            },
            "group": {{ host.group | tojson }}
        }
    },
    "user": {
        "name": "SYSTEM",
        "domain": "NT AUTHORITY"
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": ["SYSTEM"]
    }
}