{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set status_action = module.rand.weighted_choice(['started', 'stopped', 'component_disabled', 'component_enabled', 'self_defense_triggered'], [35, 10, 15, 25, 15]) -%}
{%- set components = ['File Threat Protection', 'Web Threat Protection', 'Mail Threat Protection', 'Network Threat Protection', 'Exploit Prevention', 'Behavior Detection', 'AMSI Protection', 'Firewall'] -%}
{%- set component = module.rand.choice(components) -%}
{%- if status_action == 'started' -%}
  {%- set event_class = 'GNRL_EV_APPLICATION_LAUNCHED' -%}
  {%- set event_name = 'Application started' -%}
  {%- set severity = 1 -%}
{%- elif status_action == 'stopped' -%}
  {%- set event_class = 'GNRL_EV_APPLICATION_TERMINATED' -%}
  {%- set event_name = 'Application stopped' -%}
  {%- set severity = 2 -%}
{%- elif status_action == 'component_disabled' -%}
  {%- set event_class = 'GNRL_EV_PROTECTION_DISABLED' -%}
  {%- set event_name = 'Protection component disabled' -%}
  {%- set severity = 3 -%}
{%- elif status_action == 'component_enabled' -%}
  {%- set event_class = 'GNRL_EV_PROTECTION_ENABLED' -%}
  {%- set event_name = 'Protection component enabled' -%}
  {%- set severity = 1 -%}
{%- else -%}
  {%- set event_class = 'GNRL_EV_SELF_DEFENSE_TRIGGERED' -%}
  {%- set event_name = 'Self-Defense triggered' -%}
  {%- set severity = 4 -%}
{%- endif -%}
{
    {{ event_base(host, ["process"], ["start" if status_action in ['started', 'component_enabled'] else "end"], severity, "success", timestamp, params) }},
    "kaspersky": {
        "ksc": {
            "event_id": {{ next_event_id(shared) }},
            "event_class_id": {{ event_class | tojson }},
            "event_type": {{ event_name | tojson }},
            "component": {{ component | tojson }},
            "result": {{ event_name | tojson }},
            "protection": {
                "action": {{ status_action | tojson }},
                "component": {{ component | tojson }},
                "kes_version": {{ params.get('kes_version', '12.0.0.1131') | tojson }},
                "product_name": "Kaspersky Endpoint Security for Windows"
            },
            "group": {{ host.group | tojson }}
        }
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}