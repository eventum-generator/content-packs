{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set data_action = module.rand.weighted_choice(
  ['secure_erase', 'shadow_copy_print', 'shadow_copy_device', 'print_marked'],
  [25, 30, 20, 25]
) -%}
{%- set file_names = [
  'report_' ~ module.rand.string.digits(4) ~ '.docx',
  'data_export_' ~ module.rand.string.digits(3) ~ '.xlsx',
  'contract_' ~ module.rand.string.digits(4) ~ '.pdf',
  'presentation_' ~ module.rand.string.hex(6) ~ '.pptx',
  'database_backup_' ~ module.rand.string.digits(6) ~ '.bak',
  'confidential_memo_' ~ module.rand.string.digits(3) ~ '.docx'
] -%}
{%- set file_name = module.rand.choice(file_names) -%}
{%- set erase_cycles = module.rand.weighted_choice([1, 3, 7], [30, 50, 20]) -%}
{%- set file_size = module.rand.number.lognormal(12, 1.5) | int -%}
{%- set printers = ['HP LaserJet Pro M404', 'Xerox VersaLink C405', 'Canon imageRUNNER C3025', 'Kyocera ECOSYS P3145dn'] -%}
{%- set action_map = {
  'secure_erase': {
    'desc': 'Гарантированное затирание данных',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_DATA_ERASE',
    'category': 'file',
    'type': 'deletion'
  },
  'shadow_copy_print': {
    'desc': 'Создана теневая копия напечатанного документа',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_DATA_SHADOW_PRINT',
    'category': 'file',
    'type': 'creation'
  },
  'shadow_copy_device': {
    'desc': 'Создана теневая копия файла, скопированного на внешнее устройство',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_DATA_SHADOW_DEVICE',
    'category': 'file',
    'type': 'creation'
  },
  'print_marked': {
    'desc': 'Документ напечатан с маркировкой учетной информации',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_DATA_PRINT_MARKED',
    'category': 'file',
    'type': 'access'
  }
} -%}
{%- set detail = action_map[data_action] -%}
{%- set conf_level = module.rand.choice(['Несекретно', 'Конфиденциально', 'Строго конфиденциально']) -%}
{
    {{ event_base(host, [detail.category], [detail.type], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Защита данных",
        "action": {{ data_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "data_protection": {
            "file_name": {{ file_name | tojson }},
            "file_size": {{ file_size }},
            "confidentiality_level": {{ conf_level | tojson }}
{%- if data_action == 'secure_erase' %},
            "erase_cycles": {{ erase_cycles }},
            "erase_method": {{ module.rand.choice(['DoD 5220.22-M', 'ГОСТ Р 50739-95', 'Random']) | tojson }}
{%- endif %}
{%- if data_action in ['shadow_copy_print', 'print_marked'] %},
            "printer": {{ module.rand.choice(printers) | tojson }}
{%- endif %}
{%- if data_action == 'shadow_copy_device' %},
            "target_device": "USB Flash Drive",
            "target_path": "E:\\{{ file_name }}"
{%- endif %}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "file": {
        "name": {{ file_name | tojson }},
        "size": {{ file_size }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": {{ user.full_name | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}