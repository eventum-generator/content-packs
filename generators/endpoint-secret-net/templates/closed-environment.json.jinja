{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set app = samples.blocked_apps.pick() -%}
{%- set app_path = app.path | replace('%USERNAME%', user.username) -%}
{%- set cse_action = module.rand.weighted_choice(
  ['blocked', 'warning', 'allowed'],
  [40, 35, 25]
) -%}
{%- set action_map = {
  'blocked': {
    'desc': 'Замкнутая программная среда: запуск программы заблокирован',
    'outcome': 'failure',
    'severity': 3,
    'event_id': 'SN_CSE_BLOCKED',
    'mode': 'жесткий'
  },
  'warning': {
    'desc': 'Замкнутая программная среда: предупреждение о запуске неразрешенной программы',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_CSE_WARNING',
    'mode': 'мягкий'
  },
  'allowed': {
    'desc': 'Замкнутая программная среда: запуск разрешенной программы',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_CSE_ALLOWED',
    'mode': 'жесткий'
  }
} -%}
{%- set detail = action_map[cse_action] -%}
{%- set sha256 = module.rand.string.hex(64) -%}
{
    {{ event_base(host, ["process"], ["start" if cse_action != 'blocked' else "denied"], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Замкнутая программная среда",
        "action": {{ cse_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "closed_environment": {
            "mode": {{ detail.mode | tojson }},
            "reason": {{ app.reason | tojson }},
            "publisher": {{ app.publisher | tojson }}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "process": {
        "name": {{ app.name | tojson }},
        "executable": {{ app_path | tojson }},
        "hash": {
            "sha256": {{ sha256 | tojson }}
        }
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": {{ user.full_name | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}],
        "hash": [{{ sha256 | tojson }}]
    }
}