{#- Shared macros for Secret Net Studio events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import event_base, next_event_id %} -#}

{#- Base event envelope with common ECS fields -#}
{%- macro event_base(host, category, type, severity, outcome, ts, p) -%}
    "@timestamp": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "event": {
        "kind": "event",
        "module": "secret_net",
        "dataset": "secret_net.endpoint",
        "category": {{ category | tojson }},
        "type": {{ type | tojson }},
        "severity": {{ severity }},
        "outcome": {{ outcome | tojson }},
        "timezone": "UTC",
        "created": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
    },
    "observer": {
        "vendor": "Security Code",
        "product": "Secret Net Studio",
        "version": {{ p.get('sn_version', '8.10.0.1573') | tojson }},
        "hostname": {{ p.get('sn_server', 'SN-SRV01') | tojson }},
        "ip": [{{ p.get('sn_server_ip', '10.1.0.15') | tojson }}]
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "agent": {
        "type": "secret-net-client",
        "version": {{ p.get('sn_version', '8.10.0.1573') | tojson }}
    }
{%- endmacro -%}

{#- Monotonically increasing event ID via shared state -#}
{%- macro next_event_id(sh) -%}
{%- set eid = sh.get('event_id', 1000000) -%}
{%- do sh.set('event_id', eid + 1) -%}
{{ eid }}
{%- endmacro -%}
