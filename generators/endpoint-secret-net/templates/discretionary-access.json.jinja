{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set access_action = module.rand.weighted_choice(
  ['access_granted', 'access_denied', 'permission_changed', 'owner_changed'],
  [55, 25, 12, 8]
) -%}
{%- set resource_type = module.rand.weighted_choice(['file', 'directory', 'registry'], [50, 35, 15]) -%}
{%- set file_paths = [
  'C:\\Documents\\' ~ user.department ~ '\\report_' ~ module.rand.string.digits(4) ~ '.docx',
  'C:\\Shared\\' ~ user.department ~ '\\data_' ~ module.rand.string.digits(3) ~ '.xlsx',
  'D:\\Projects\\project_' ~ module.rand.string.hex(6) ~ '\\config.xml',
  'C:\\Users\\' ~ user.username ~ '\\Documents\\notes.txt',
  'C:\\Confidential\\' ~ user.department ~ '\\' ~ module.rand.string.hex(8) ~ '.pdf',
  'C:\\Temp\\export_' ~ module.rand.string.digits(6) ~ '.csv'
] -%}
{%- set dir_paths = [
  'C:\\Documents\\' ~ user.department,
  'C:\\Shared\\' ~ user.department,
  'D:\\Projects\\project_' ~ module.rand.string.hex(6),
  'C:\\Confidential\\' ~ user.department,
  'C:\\Users\\' ~ user.username ~ '\\Desktop'
] -%}
{%- set reg_paths = [
  'HKLM\\SOFTWARE\\SecurityCode\\SecretNetStudio',
  'HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies',
  'HKCU\\SOFTWARE\\Microsoft\\Office\\16.0',
  'HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders'
] -%}
{%- set resource_path = module.rand.choice(file_paths) if resource_type == 'file' else (module.rand.choice(dir_paths) if resource_type == 'directory' else module.rand.choice(reg_paths)) -%}
{%- set requested_access = module.rand.weighted_choice(
  ['read', 'write', 'execute', 'delete', 'full_control'],
  [40, 25, 15, 10, 10]
) -%}
{%- set is_success = access_action in ['access_granted', 'permission_changed', 'owner_changed'] -%}
{%- set action_desc = {
  'access_granted': 'Доступ к ресурсу разрешен',
  'access_denied': 'Доступ к ресурсу запрещен',
  'permission_changed': 'Изменены права доступа к ресурсу',
  'owner_changed': 'Изменен владелец ресурса'
} -%}
{
    {{ event_base(host, ["file"], ["access" if access_action in ['access_granted', 'access_denied'] else "change"], (1 if is_success else 3), ("success" if is_success else "failure"), timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": "SN_DAC_{{ access_action | upper }}",
        "subsystem": "Дискреционное управление доступом",
        "action": {{ access_action | tojson }},
        "description": {{ action_desc[access_action] | tojson }},
        "resource": {
            "path": {{ resource_path | tojson }},
            "type": {{ resource_type | tojson }}
        },
        "requested_access": {{ requested_access | tojson }},
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "file": {
{%- if resource_type == 'file' %}
        "name": {{ resource_path.split('\\') | last | tojson }},
{%- endif %}
        "path": {{ resource_path | tojson }},
        "type": {{ resource_type | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": {{ user.full_name | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}