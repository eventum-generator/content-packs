{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set net_action = module.rand.weighted_choice(
  ['connection_allowed', 'connection_blocked', 'rule_match', 'intrusion_attempt'],
  [35, 30, 20, 15]
) -%}
{%- set protocols = module.rand.weighted_choice(['TCP', 'UDP', 'ICMP'], [60, 30, 10]) -%}
{%- set dst_port = module.rand.weighted_choice(
  [80, 443, 22, 3389, 445, 135, 53, 8080, 25, 110],
  [20, 30, 8, 10, 8, 5, 7, 5, 4, 3]
) -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{%- set dst_ip_internal = ['10.1.1.10', '10.1.2.20', '10.1.3.10', '10.1.5.10', '10.1.5.20'] -%}
{%- set dst_ip_external = ['185.12.45.' ~ module.rand.number.integer(1, 254), '91.234.12.' ~ module.rand.number.integer(1, 254), '203.0.113.' ~ module.rand.number.integer(1, 254), '198.51.100.' ~ module.rand.number.integer(1, 254)] -%}
{%- set is_external = module.rand.weighted_choice([true, false], [40, 60]) -%}
{%- set dst_ip = module.rand.choice(dst_ip_external) if is_external else module.rand.choice(dst_ip_internal) -%}
{%- set direction = module.rand.weighted_choice(['outbound', 'inbound'], [65, 35]) -%}
{%- set action_map = {
  'connection_allowed': {
    'desc': 'Сетевое соединение разрешено',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_NET_ALLOWED'
  },
  'connection_blocked': {
    'desc': 'Сетевое соединение заблокировано',
    'outcome': 'failure',
    'severity': 3,
    'event_id': 'SN_NET_BLOCKED'
  },
  'rule_match': {
    'desc': 'Срабатывание правила сетевого экрана',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_NET_RULE'
  },
  'intrusion_attempt': {
    'desc': 'Обнаружена попытка сетевого вторжения',
    'outcome': 'failure',
    'severity': 4,
    'event_id': 'SN_NET_INTRUSION'
  }
} -%}
{%- set detail = action_map[net_action] -%}
{%- set rule_name = module.rand.choice([
  'Allow-DNS', 'Allow-HTTP', 'Allow-HTTPS', 'Block-RDP-External',
  'Block-SMB-External', 'Allow-Internal-All', 'Block-Unknown-Outbound',
  'Allow-KSC-Agent', 'Block-Telnet', 'Allow-ICMP-Internal'
]) -%}
{
    {{ event_base(host, ["network"], ["connection" if net_action != 'intrusion_attempt' else "denied"], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Межсетевой экран",
        "action": {{ net_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "network": {
            "rule_name": {{ rule_name | tojson }},
            "direction": {{ direction | tojson }}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "source": {
        "ip": {{ (host.ip if direction == 'outbound' else dst_ip) | tojson }},
        "port": {{ (src_port if direction == 'outbound' else dst_port) }}
    },
    "destination": {
        "ip": {{ (dst_ip if direction == 'outbound' else host.ip) | tojson }},
        "port": {{ (dst_port if direction == 'outbound' else src_port) }}
    },
    "network": {
        "transport": {{ protocols | lower | tojson }},
        "direction": {{ direction | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ dst_ip | tojson }}]
    }
}