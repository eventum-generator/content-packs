{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set obj = samples.integrity_objects.pick() -%}
{%- set check_result = module.rand.weighted_choice(
  ['passed', 'failed_checksum', 'failed_missing', 'failed_modified', 'check_started', 'check_completed'],
  [40, 12, 5, 13, 15, 15]
) -%}
{%- set result_map = {
  'passed': {
    'desc': 'Контроль целостности: объект не изменен',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_INTEGRITY_OK'
  },
  'failed_checksum': {
    'desc': 'Контроль целостности: обнаружено изменение контрольной суммы',
    'outcome': 'failure',
    'severity': 4,
    'event_id': 'SN_INTEGRITY_CHECKSUM_FAIL'
  },
  'failed_missing': {
    'desc': 'Контроль целостности: объект отсутствует',
    'outcome': 'failure',
    'severity': 4,
    'event_id': 'SN_INTEGRITY_MISSING'
  },
  'failed_modified': {
    'desc': 'Контроль целостности: обнаружено несанкционированное изменение',
    'outcome': 'failure',
    'severity': 4,
    'event_id': 'SN_INTEGRITY_MODIFIED'
  },
  'check_started': {
    'desc': 'Запуск проверки целостности',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_INTEGRITY_START'
  },
  'check_completed': {
    'desc': 'Завершение проверки целостности',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_INTEGRITY_END'
  }
} -%}
{%- set detail = result_map[check_result] -%}
{%- set is_violation = check_result.startswith('failed') -%}
{%- set hash_algo = module.rand.choice(['CRC32', 'MD5', 'SHA-256', 'GOST R 34.11-2012']) -%}
{%- set expected_hash = module.rand.string.hex(64) if is_violation else '' -%}
{%- set actual_hash = module.rand.string.hex(64) if is_violation else '' -%}
{%- set check_trigger = module.rand.weighted_choice(
  ['scheduled', 'boot', 'manual', 'on_access'],
  [40, 30, 15, 15]
) -%}
{
    {{ event_base(host, ["configuration"], ["info" if not is_violation else "change"], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Контроль целостности",
        "action": {{ check_result | tojson }},
        "description": {{ detail.desc | tojson }},
        "integrity": {
            "object_path": {{ obj.path | tojson }},
            "object_type": {{ obj.type | tojson }},
            "object_category": {{ obj.category | tojson }},
            "object_description": {{ obj.description | tojson }},
            "hash_algorithm": {{ hash_algo | tojson }},
{%- if is_violation %}
            "expected_hash": {{ expected_hash | tojson }},
            "actual_hash": {{ actual_hash | tojson }},
{%- endif %}
            "trigger": {{ check_trigger | tojson }}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "file": {
{%- if obj.type == 'file' %}
        "name": {{ obj.path.split('\\') | last | tojson }},
{%- endif %}
        "path": {{ obj.path | tojson }},
        "type": {{ obj.type | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}]
    }
}