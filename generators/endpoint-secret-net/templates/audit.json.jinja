{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set admin_user = module.rand.choice(['sn_admin', 'Administrator', 'ivanov.ai', 'popova.aa']) -%}
{%- set audit_action = module.rand.weighted_choice(
  ['policy_applied', 'policy_changed', 'config_changed', 'user_rights_changed',
   'protection_enabled', 'protection_disabled', 'admin_login', 'key_generated'],
  [20, 15, 15, 12, 10, 8, 12, 8]
) -%}
{%- set action_map = {
  'policy_applied': {
    'desc': 'Применена политика безопасности',
    'type': 'change',
    'cat': 'configuration',
    'severity': 1,
    'event_id': 'SN_AUDIT_POLICY_APPLIED',
    'component': 'Управление политиками'
  },
  'policy_changed': {
    'desc': 'Изменена политика безопасности',
    'type': 'change',
    'cat': 'configuration',
    'severity': 2,
    'event_id': 'SN_AUDIT_POLICY_CHANGED',
    'component': 'Управление политиками'
  },
  'config_changed': {
    'desc': 'Изменена конфигурация защитного механизма',
    'type': 'change',
    'cat': 'configuration',
    'severity': 2,
    'event_id': 'SN_AUDIT_CONFIG_CHANGED',
    'component': 'Настройка защиты'
  },
  'user_rights_changed': {
    'desc': 'Изменены права пользователя в СЗИ',
    'type': 'change',
    'cat': 'iam',
    'severity': 2,
    'event_id': 'SN_AUDIT_RIGHTS_CHANGED',
    'component': 'Управление пользователями'
  },
  'protection_enabled': {
    'desc': 'Включен защитный механизм',
    'type': 'change',
    'cat': 'configuration',
    'severity': 2,
    'event_id': 'SN_AUDIT_PROTECTION_ON',
    'component': 'Управление защитой'
  },
  'protection_disabled': {
    'desc': 'Отключен защитный механизм',
    'type': 'change',
    'cat': 'configuration',
    'severity': 4,
    'event_id': 'SN_AUDIT_PROTECTION_OFF',
    'component': 'Управление защитой'
  },
  'admin_login': {
    'desc': 'Вход администратора СЗИ в центр управления',
    'type': 'start',
    'cat': 'authentication',
    'severity': 1,
    'event_id': 'SN_AUDIT_ADMIN_LOGIN',
    'component': 'Центр управления'
  },
  'key_generated': {
    'desc': 'Сгенерирован ключ шифрования',
    'type': 'creation',
    'cat': 'configuration',
    'severity': 2,
    'event_id': 'SN_AUDIT_KEY_GEN',
    'component': 'Шифрование'
  }
} -%}
{%- set detail = action_map[audit_action] -%}
{%- set src_ip = module.rand.choice(['10.1.20.50', '10.1.20.55', '10.1.30.5', '10.1.0.15']) -%}
{%- set policy_names = [
  'Политика рабочих станций',
  'Политика серверов',
  'Политика мобильных устройств',
  'Политика конфиденциальных данных',
  'Политика сетевой защиты'
] -%}
{%- set subsystems = [
  'Контроль целостности',
  'Контроль устройств',
  'Замкнутая программная среда',
  'Межсетевой экран',
  'Мандатное управление доступом',
  'Дискреционное управление доступом',
  'Защита данных'
] -%}
{
    {{ event_base(host, [detail.cat], [detail.type], detail.severity, "success", timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Аудит",
        "action": {{ audit_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "audit": {
            "component": {{ detail.component | tojson }},
            "admin_user": {{ admin_user | tojson }},
            "source_ip": {{ src_ip | tojson }}
{%- if audit_action in ['policy_applied', 'policy_changed'] %},
            "policy_name": {{ module.rand.choice(policy_names) | tojson }}
{%- endif %}
{%- if audit_action in ['protection_enabled', 'protection_disabled', 'config_changed'] %},
            "target_subsystem": {{ module.rand.choice(subsystems) | tojson }}
{%- endif %}
{%- if audit_action == 'user_rights_changed' %},
            "target_user": {{ module.rand.choice(['petrov.sv', 'sidorova.en', 'kuznetsov.da', 'fedorov.mk']) | tojson }}
{%- endif %}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "source": {
        "ip": {{ src_ip | tojson }}
    },
    "user": {
        "name": {{ admin_user | tojson }},
        "domain": "CORP",
        "roles": ["Администратор СЗИ"]
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}, {{ params.get('sn_server', 'SN-SRV01') | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ src_ip | tojson }}],
        "user": [{{ admin_user | tojson }}]
    }
}