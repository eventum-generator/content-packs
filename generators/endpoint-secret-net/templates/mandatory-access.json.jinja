{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set mac_action = module.rand.weighted_choice(
  ['access_granted', 'access_denied', 'level_changed', 'label_set', 'label_mismatch'],
  [30, 25, 15, 15, 15]
) -%}
{%- set conf_levels = ['Несекретно', 'Конфиденциально', 'Строго конфиденциально'] -%}
{%- set resource_level = module.rand.choice(conf_levels) -%}
{%- set resource_paths = [
  'C:\\Confidential\\Finance\\budget_2026.xlsx',
  'C:\\Confidential\\HR\\salary_report.docx',
  'C:\\SecretDocs\\project_alpha\\specs.pdf',
  'D:\\Restricted\\contracts\\contract_' ~ module.rand.string.digits(4) ~ '.pdf',
  'C:\\Confidential\\Legal\\case_' ~ module.rand.string.digits(3) ~ '.docx',
  'C:\\Shared\\Management\\strategy_2026.pptx',
  'C:\\Confidential\\Security\\audit_results.xlsx',
  'D:\\Restricted\\accounting\\report_q' ~ module.rand.number.integer(1, 4) ~ '.xlsx'
] -%}
{%- set resource_path = module.rand.choice(resource_paths) -%}
{%- set action_map = {
  'access_granted': {
    'desc': 'Мандатный доступ: доступ разрешен',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_MAC_ACCESS_OK'
  },
  'access_denied': {
    'desc': 'Мандатный доступ: доступ запрещен — уровень допуска недостаточен',
    'outcome': 'failure',
    'severity': 3,
    'event_id': 'SN_MAC_ACCESS_DENIED'
  },
  'level_changed': {
    'desc': 'Изменен уровень конфиденциальности сессии',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_MAC_LEVEL_CHANGED'
  },
  'label_set': {
    'desc': 'Установлена метка конфиденциальности ресурса',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_MAC_LABEL_SET'
  },
  'label_mismatch': {
    'desc': 'Мандатный доступ: несоответствие меток конфиденциальности',
    'outcome': 'failure',
    'severity': 3,
    'event_id': 'SN_MAC_LABEL_MISMATCH'
  }
} -%}
{%- set detail = action_map[mac_action] -%}
{
    {{ event_base(host, ["file"], ["access" if mac_action.startswith('access') else "change"], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Мандатное управление доступом",
        "action": {{ mac_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "mandatory_access": {
            "resource_path": {{ resource_path | tojson }},
            "resource_level": {{ resource_level | tojson }},
            "user_clearance": {{ user.clearance_level | tojson }},
            "session_level": {{ module.rand.choice(conf_levels) | tojson }}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "file": {
        "name": {{ resource_path.split('\\') | last | tojson }},
        "path": {{ resource_path | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": {{ user.full_name | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}