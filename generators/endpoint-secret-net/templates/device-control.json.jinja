{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set device = samples.devices.pick() -%}
{%- set dev_action = module.rand.weighted_choice(
  ['connected', 'disconnected', 'blocked', 'allowed', 'read_only'],
  [30, 25, 20, 15, 10]
) -%}
{%- set action_map = {
  'connected': {
    'desc': 'Устройство подключено',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_DEVICE_CONNECTED',
    'type': 'connection'
  },
  'disconnected': {
    'desc': 'Устройство отключено',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_DEVICE_DISCONNECTED',
    'type': 'end'
  },
  'blocked': {
    'desc': 'Подключение устройства заблокировано',
    'outcome': 'failure',
    'severity': 3,
    'event_id': 'SN_DEVICE_BLOCKED',
    'type': 'denied'
  },
  'allowed': {
    'desc': 'Подключение устройства разрешено по белому списку',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_DEVICE_ALLOWED',
    'type': 'allowed'
  },
  'read_only': {
    'desc': 'Устройство подключено в режиме только чтение',
    'outcome': 'success',
    'severity': 2,
    'event_id': 'SN_DEVICE_READONLY',
    'type': 'connection'
  }
} -%}
{%- set detail = action_map[dev_action] -%}
{
    {{ event_base(host, ["host"], [detail.type], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Контроль устройств",
        "action": {{ dev_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "device": {
            "type": {{ device.type | tojson }},
            "class": {{ device.class | tojson }},
            "vendor": {{ device.vendor | tojson }},
            "model": {{ device.model | tojson }},
            "serial": {{ device.serial | tojson }},
            "vid_pid": {{ device.vid_pid | tojson }}
        },
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": {{ user.full_name | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}