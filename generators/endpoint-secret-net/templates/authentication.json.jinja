{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set auth_action = module.rand.weighted_choice(
  ['login_success', 'login_failure', 'logout', 'lock', 'unlock', 'token_auth'],
  [35, 15, 25, 10, 10, 5]
) -%}
{%- set action_map = {
  'login_success': {
    'desc': 'Успешный вход в систему',
    'type': 'start',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_AUTH_LOGIN_OK',
    'method': module.rand.weighted_choice(['password', 'token', 'password+token'], [50, 20, 30])
  },
  'login_failure': {
    'desc': 'Неудачная попытка входа в систему',
    'type': 'start',
    'outcome': 'failure',
    'severity': 3,
    'event_id': 'SN_AUTH_LOGIN_FAIL',
    'method': 'password'
  },
  'logout': {
    'desc': 'Выход из системы',
    'type': 'end',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_AUTH_LOGOUT',
    'method': ''
  },
  'lock': {
    'desc': 'Блокировка рабочей станции',
    'type': 'info',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_AUTH_LOCK',
    'method': ''
  },
  'unlock': {
    'desc': 'Разблокировка рабочей станции',
    'type': 'info',
    'outcome': 'success',
    'severity': 1,
    'event_id': 'SN_AUTH_UNLOCK',
    'method': module.rand.weighted_choice(['password', 'token'], [70, 30])
  },
  'token_auth': {
    'desc': 'Аутентификация по аппаратному идентификатору',
    'type': 'start',
    'outcome': module.rand.weighted_choice(['success', 'failure'], [85, 15]),
    'severity': 2,
    'event_id': 'SN_AUTH_TOKEN',
    'method': module.rand.choice(['Rutoken S', 'JaCarta PKI', 'eToken PRO'])
  }
} -%}
{%- set detail = action_map[auth_action] -%}
{%- set failure_reason = module.rand.choice([
  'Неверный пароль',
  'Учетная запись заблокирована',
  'Истек срок действия пароля',
  'Превышено число попыток входа',
  'Нарушение расписания входа'
]) if detail.outcome == 'failure' else '' -%}
{%- set logon_type = module.rand.weighted_choice([2, 3, 7, 10, 11], [40, 20, 15, 15, 10]) -%}
{
    {{ event_base(host, ["authentication"], [detail.type], detail.severity, detail.outcome, timestamp, params) }},
    "secret_net": {
        "event_id": {{ next_event_id(shared) }},
        "event_class": {{ detail.event_id | tojson }},
        "subsystem": "Идентификация и аутентификация",
        "action": {{ auth_action | tojson }},
        "description": {{ detail.desc | tojson }},
        "auth_method": {{ detail.method | tojson }},
        "logon_type": {{ logon_type }},
{%- if failure_reason %}
        "failure_reason": {{ failure_reason | tojson }},
{%- endif %}
        "computer_level": {{ host.confidentiality_level | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": {{ user.full_name | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}