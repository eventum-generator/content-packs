{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set fqdn = hostname ~ '.' ~ params.fqdn_suffix -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set u = samples.usernames | random -%}
{%- set user = u.username -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set tty = 'pts/' ~ module.rand.number.integer(0, 9) -%}
{#- Pick variant -#}
{%- set variant = module.rand.weighted_choice(['success', 'failure'], [80, 20]) -%}
{%- if variant == 'success' -%}
  {%- set msg = 'Successful su for root by ' ~ user -%}
{%- else -%}
  {%- set msg = 'FAILED su for root by ' ~ user -%}
{%- endif -%}
{#- PRI: facility=auth(4) * 8 + severity=notice(5) = 37 -#}
{%- set pri = 37 -%}
{%- set event_outcome = 'success' if variant == 'success' else 'failure' -%}
{%- set syslog_msg = '<' ~ pri ~ '>' ~ timestamp.strftime('%b %e %H:%M:%S') ~ ' ' ~ hostname ~ ' su[' ~ pid ~ ']: ' ~ msg -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "event": {
        "original": {{ syslog_msg | tojson }},
        "dataset": "system.syslog",
        "module": "system",
        "kind": "event",
        "category": ["authentication"],
        "type": ["info"]
    },
    "message": {{ msg | tojson }},
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "os": {
            "name": "{{ host.os_name }}",
            "version": "{{ host.os_version }}",
            "kernel": "{{ host.os_kernel }}",
            "platform": "{{ host.os_platform }}"
        }
    },
    "process": {
        "name": "su",
        "pid": {{ pid }}
    },
    "agent": {
        "type": "filebeat",
        "version": "{{ params.agent_version }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ fqdn }}",
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}"
    },
    "log": {
        "file": {
            "path": "{{ host.syslog_path }}"
        },
        "offset": {{ seq }}
    },
    "data_stream": {
        "type": "logs",
        "dataset": "system.syslog",
        "namespace": "default"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "user": ["{{ user }}", "root"]
    },
    "user": {
        "name": "{{ user }}"
    },
    "system": {
        "syslog": {}
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}
