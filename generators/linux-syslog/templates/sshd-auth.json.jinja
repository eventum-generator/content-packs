{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set fqdn = hostname ~ '.' ~ params.fqdn_suffix -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{#- Pick user -#}
{%- set u = samples.usernames | random -%}
{%- set user = u.username -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set src_ip = module.rand.weighted_choice([params.network_prefix ~ '.' ~ module.rand.number.integer(1, 254) ~ '.' ~ module.rand.number.integer(1, 254), module.rand.network.ip_v4_public()], [60, 40]) -%}
{%- set src_port = module.rand.number.integer(32768, 60999) -%}
{#- Pick variant -#}
{%- set variant = module.rand.weighted_choice(['accepted_pubkey', 'accepted_password', 'failed_password', 'invalid_user', 'closed_preauth'], [40, 25, 20, 10, 5]) -%}
{%- if variant == 'accepted_pubkey' -%}
  {%- set msg = 'Accepted publickey for ' ~ user ~ ' from ' ~ src_ip ~ ' port ' ~ src_port ~ ' ssh2' -%}
  {%- set event_type = ['info'] -%}
  {%- set event_outcome = 'success' -%}
{%- elif variant == 'accepted_password' -%}
  {%- set msg = 'Accepted password for ' ~ user ~ ' from ' ~ src_ip ~ ' port ' ~ src_port ~ ' ssh2' -%}
  {%- set event_type = ['info'] -%}
  {%- set event_outcome = 'success' -%}
{%- elif variant == 'failed_password' -%}
  {%- set msg = 'Failed password for ' ~ user ~ ' from ' ~ src_ip ~ ' port ' ~ src_port ~ ' ssh2' -%}
  {%- set event_type = ['info'] -%}
  {%- set event_outcome = 'failure' -%}
{%- elif variant == 'invalid_user' -%}
  {%- set invalid_name = module.rand.choice(['admin', 'test', 'guest', 'oracle', 'ftpuser', 'user1', 'pi', 'ubnt']) -%}
  {%- set msg = 'Invalid user ' ~ invalid_name ~ ' from ' ~ src_ip ~ ' port ' ~ src_port -%}
  {%- set user = invalid_name -%}
  {%- set event_type = ['info'] -%}
  {%- set event_outcome = 'failure' -%}
{%- else -%}
  {%- set msg = 'Connection closed by ' ~ src_ip ~ ' port ' ~ src_port ~ ' [preauth]' -%}
  {%- set event_type = ['info'] -%}
  {%- set event_outcome = 'failure' -%}
{%- endif -%}
{#- PRI: facility=authpriv(10) * 8 + severity=info(6) = 86 -#}
{%- set pri = 86 -%}
{%- set syslog_msg = '<' ~ pri ~ '>' ~ timestamp.strftime('%b %e %H:%M:%S') ~ ' ' ~ hostname ~ ' sshd[' ~ pid ~ ']: ' ~ msg -%}
{#- On success: push to ssh_sessions for sshd-session correlation -#}
{%- if event_outcome == 'success' -%}
  {%- set ssh_sessions = shared.get('ssh_sessions:' ~ hostname, []) -%}
  {%- do ssh_sessions.append({'user': user, 'pid': pid, 'ip': src_ip, 'port': src_port}) -%}
  {%- if ssh_sessions | length > 30 -%}{%- do ssh_sessions.pop(0) -%}{%- endif -%}
  {%- do shared.set('ssh_sessions:' ~ hostname, ssh_sessions) -%}
{%- endif -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "event": {
        "original": {{ syslog_msg | tojson }},
        "dataset": "system.syslog",
        "module": "system",
        "kind": "event",
        "category": ["authentication"],
        "type": {{ event_type | tojson }}
    },
    "message": {{ msg | tojson }},
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "os": {
            "name": "{{ host.os_name }}",
            "version": "{{ host.os_version }}",
            "kernel": "{{ host.os_kernel }}",
            "platform": "{{ host.os_platform }}"
        }
    },
    "process": {
        "name": "sshd",
        "pid": {{ pid }}
    },
    "agent": {
        "type": "filebeat",
        "version": "{{ params.agent_version }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ fqdn }}",
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}"
    },
    "log": {
        "file": {
            "path": "{{ host.syslog_path }}"
        },
        "offset": {{ seq }}
    },
    "data_stream": {
        "type": "logs",
        "dataset": "system.syslog",
        "namespace": "default"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_ip }}"],
        "user": ["{{ user }}"]
    },
    "source": {
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "user": {
        "name": "{{ user }}"
    },
    "system": {
        "syslog": {}
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}
