{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set fqdn = hostname ~ '.' ~ params.fqdn_suffix -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set client_ip = host.ip -%}
{%- set server_ip = params.network_prefix ~ '.0.1' -%}
{%- set iface = module.rand.choice(['eth0', 'ens18', 'ens192', 'enp0s3']) -%}
{#- Pick variant -#}
{%- set variant = module.rand.weighted_choice(['dhcpack', 'dhcprequest', 'dhcpdiscover'], [50, 30, 20]) -%}
{%- if variant == 'dhcpack' -%}
  {%- set msg = 'DHCPACK of ' ~ client_ip ~ ' from ' ~ server_ip -%}
{%- elif variant == 'dhcprequest' -%}
  {%- set msg = 'DHCPREQUEST for ' ~ client_ip ~ ' on ' ~ iface ~ ' to ' ~ server_ip -%}
{%- else -%}
  {%- set interval = module.rand.number.integer(3, 30) -%}
  {%- set msg = 'DHCPDISCOVER on ' ~ iface ~ ' to 255.255.255.255 port 67 interval ' ~ interval -%}
{%- endif -%}
{#- PRI: facility=daemon(3) * 8 + severity=info(6) = 30 -#}
{%- set pri = 30 -%}
{%- set syslog_msg = '<' ~ pri ~ '>' ~ timestamp.strftime('%b %e %H:%M:%S') ~ ' ' ~ hostname ~ ' dhclient[' ~ pid ~ ']: ' ~ msg -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "event": {
        "original": {{ syslog_msg | tojson }},
        "dataset": "system.syslog",
        "module": "system",
        "kind": "event",
        "category": ["network"],
        "type": ["info"]
    },
    "message": {{ msg | tojson }},
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "os": {
            "name": "{{ host.os_name }}",
            "version": "{{ host.os_version }}",
            "kernel": "{{ host.os_kernel }}",
            "platform": "{{ host.os_platform }}"
        }
    },
    "process": {
        "name": "dhclient",
        "pid": {{ pid }}
    },
    "agent": {
        "type": "filebeat",
        "version": "{{ params.agent_version }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ fqdn }}",
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}"
    },
    "log": {
        "file": {
            "path": "{{ host.syslog_path }}"
        },
        "offset": {{ seq }}
    },
    "data_stream": {
        "type": "logs",
        "dataset": "system.syslog",
        "namespace": "default"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "related": {
        "hosts": ["{{ hostname }}"]
    },
    "system": {
        "syslog": {}
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}
