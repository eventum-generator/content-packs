{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set fqdn = hostname ~ '.' ~ params.fqdn_suffix -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set rule = samples.firewall_rules | random -%}
{%- set action = module.rand.weighted_choice(['BLOCK', 'ALLOW'], [70, 30]) -%}
{%- set src_ip = module.rand.network.ip_v4_public() -%}
{%- set dst_ip = host.ip -%}
{%- set iface = module.rand.choice(['eth0', 'ens18', 'ens192', 'enp0s3']) -%}
{%- set src_mac = module.rand.network.mac() -%}
{%- set dst_mac = host.mac -%}
{%- set pkt_len = module.rand.number.integer(40, 1500) -%}
{%- set ttl = module.rand.number.integer(32, 128) -%}
{%- set pkt_id = module.rand.number.integer(1, 65535) -%}
{%- set spt = module.rand.number.integer(1024, 65535) -%}
{%- set dpt = rule.dpt -%}
{%- set proto = rule.proto -%}
{%- set window = module.rand.number.integer(512, 65535) -%}
{%- if proto == 'TCP' -%}
  {%- set proto_fields = 'PROTO=TCP SPT=' ~ spt ~ ' DPT=' ~ dpt ~ ' WINDOW=' ~ window ~ ' RES=0x00 SYN URGP=0' -%}
{%- else -%}
  {%- set proto_fields = 'PROTO=UDP SPT=' ~ spt ~ ' DPT=' ~ dpt ~ ' LEN=' ~ module.rand.number.integer(8, 512) -%}
{%- endif -%}
{%- set msg = '[UFW ' ~ action ~ '] IN=' ~ iface ~ ' OUT= MAC=' ~ dst_mac ~ ':' ~ src_mac ~ ':08:00 SRC=' ~ src_ip ~ ' DST=' ~ dst_ip ~ ' LEN=' ~ pkt_len ~ ' TOS=0x00 PREC=0x00 TTL=' ~ ttl ~ ' ID=' ~ pkt_id ~ ' DF ' ~ proto_fields -%}
{#- PRI: facility=kern(0) * 8 + severity=warning(4) = 4 -#}
{%- set pri = 4 -%}
{%- set syslog_msg = '<' ~ pri ~ '>' ~ timestamp.strftime('%b %e %H:%M:%S') ~ ' ' ~ hostname ~ ' kernel: ' ~ msg -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "event": {
        "original": {{ syslog_msg | tojson }},
        "dataset": "system.syslog",
        "module": "system",
        "kind": "event",
        "category": ["network"],
        "type": ["info"]
    },
    "message": {{ msg | tojson }},
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "os": {
            "name": "{{ host.os_name }}",
            "version": "{{ host.os_version }}",
            "kernel": "{{ host.os_kernel }}",
            "platform": "{{ host.os_platform }}"
        }
    },
    "process": {
        "name": "kernel"
    },
    "agent": {
        "type": "filebeat",
        "version": "{{ params.agent_version }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ fqdn }}",
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}"
    },
    "log": {
        "file": {
            "path": "{{ host.syslog_path }}"
        },
        "offset": {{ seq }}
    },
    "data_stream": {
        "type": "logs",
        "dataset": "system.syslog",
        "namespace": "default"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "source": {
        "ip": "{{ src_ip }}",
        "port": {{ spt }}
    },
    "destination": {
        "ip": "{{ dst_ip }}",
        "port": {{ dpt }}
    },
    "system": {
        "syslog": {}
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}
