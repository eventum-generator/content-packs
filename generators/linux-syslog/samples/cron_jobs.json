[
  {"user": "root", "command": "/usr/lib/apt/apt.systemd.daily install"},
  {"user": "root", "command": "/usr/lib/apt/apt.systemd.daily update"},
  {"user": "root", "command": "/usr/sbin/logrotate /etc/logrotate.conf"},
  {"user": "root", "command": "test -x /usr/sbin/anacron || ( cd / && run-parts --report /etc/cron.daily )"},
  {"user": "root", "command": "/usr/bin/certbot renew --quiet"},
  {"user": "root", "command": "/opt/scripts/backup.sh --daily"},
  {"user": "root", "command": "/usr/bin/find /tmp -type f -mtime +7 -delete"},
  {"user": "root", "command": "/opt/monitoring/check_disk_usage.sh"},
  {"user": "root", "command": "/usr/bin/apt-get -qq update"},
  {"user": "prometheus", "command": "/opt/prometheus/collect_metrics.sh"},
  {"user": "www-data", "command": "/opt/app/cleanup_sessions.sh"},
  {"user": "root", "command": "/usr/sbin/ntpdate -s ntp.ubuntu.com"},
  {"user": "root", "command": "cd / && run-parts --report /etc/cron.hourly"},
  {"user": "deploy", "command": "/opt/deploy/healthcheck.sh"},
  {"user": "root", "command": "/usr/lib/php/sessionclean"}
]
