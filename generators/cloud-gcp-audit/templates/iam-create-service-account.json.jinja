{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_global, pick_caller, pick_user_agent, pick_source_ip, pick_error, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set sa_name = module.rand.choice(["api-gateway", "data-pipeline", "backup-agent", "monitoring-bot", "ci-runner", "app-deploy"]) ~ "-sa" -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("google.iam.admin.v1.CreateServiceAccount", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_global(project) }},
    {{ ecs_block() }},
    "event": {
        "action": "google.iam.admin.v1.CreateServiceAccount",
        "category": ["iam", "configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["creation", "{{ 'denied' if is_error else 'allowed' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": {{ 'false' if is_error else 'true' }},
                    "permission": "iam.serviceAccounts.create",
                    "resource_attributes": {
                        "name": "projects/{{ project.project_id }}",
                        "service": "resourcemanager",
                        "type": "resourcemanager.projects"
                    }
                }
            ],
            "method_name": "google.iam.admin.v1.CreateServiceAccount",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.iam.admin.v1.CreateServiceAccountRequest",
                "account_id": "{{ sa_name }}",
                "name": "projects/{{ project.project_id }}",
                "service_account": {
                    "display_name": "{{ sa_name | replace('-', ' ') | title }}"
                }
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "email_id": "{{ sa_name }}@{{ project.project_id }}.iam.gserviceaccount.com",
                    "project_id": "{{ project.project_id }}"
                },
                "type": "service_account"
            },
            "resource_location": {
                "current_locations": ["global"]
            },
            "resource_name": "projects/{{ project.project_id }}/serviceAccounts/{{ sa_name }}@{{ project.project_id }}.iam.gserviceaccount.com",
{%- if is_error %}
            "status": {
                "code": {{ error_code }},
                "message": {{ error_message | tojson }}
            },
{%- else %}
            "response": {
                "@type": "type.googleapis.com/google.iam.admin.v1.ServiceAccount",
                "email": "{{ sa_name }}@{{ project.project_id }}.iam.gserviceaccount.com",
                "name": "projects/{{ project.project_id }}/serviceAccounts/{{ sa_name }}@{{ project.project_id }}.iam.gserviceaccount.com",
                "project_id": "{{ project.project_id }}",
                "unique_id": "{{ module.rand.string.digits(21) }}"
            },
{%- endif %}
            "service_name": "iam.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if is_error else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}"]
    },
    "service": {
        "name": "iam.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
