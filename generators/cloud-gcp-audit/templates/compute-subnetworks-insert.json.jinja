{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_regional, pick_caller, pick_user_agent, pick_source_ip, pick_error, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set zone = samples.zones | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set network = samples.networks | random -%}
{%- set subnet_name = module.rand.choice(["app", "data", "mgmt", "dmz", "web"]) ~ "-subnet-" ~ module.rand.string.hex(4) -%}
{%- set cidr = "10." ~ module.rand.choice([0, 1, 2, 3, 4, 5]) ~ "." ~ module.rand.choice([0, 16, 32, 48, 64]) ~ ".0/" ~ module.rand.choice([20, 22, 24]) -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("v1.compute.subnetworks.insert", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_regional(project, zone.region) }},
    {{ ecs_block() }},
    "event": {
        "action": "v1.compute.subnetworks.insert",
        "category": ["network", "configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["creation", "{{ 'denied' if is_error else 'allowed' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": {{ 'false' if is_error else 'true' }},
                    "permission": "compute.subnetworks.create",
                    "resource_attributes": {
                        "name": "projects/{{ project.project_id }}/regions/{{ zone.region }}/subnetworks/{{ subnet_name }}",
                        "service": "compute",
                        "type": "compute.subnetworks"
                    }
                }
            ],
            "method_name": "v1.compute.subnetworks.insert",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/compute.subnetworks.insert",
                "name": "{{ subnet_name }}",
                "network": "projects/{{ project.project_id }}/global/networks/{{ network.network_name }}",
                "ipCidrRange": "{{ cidr }}",
                "region": "projects/{{ project.project_id }}/regions/{{ zone.region }}",
                "privateIpGoogleAccess": true
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "project_id": "{{ project.project_id }}"
                },
                "type": "gce_subnetwork"
            },
            "resource_location": {
                "current_locations": ["{{ zone.region }}"]
            },
            "resource_name": "projects/{{ project.project_id }}/regions/{{ zone.region }}/subnetworks/{{ subnet_name }}",
{%- if is_error %}
            "status": {
                "code": {{ error_code }},
                "message": {{ error_message | tojson }}
            },
{%- else %}
            "response": {
                "@type": "type.googleapis.com/operation",
                "id": "{{ module.rand.string.digits(19) }}",
                "name": "operation-{{ module.rand.string.hex(12) }}",
                "operationType": "insert",
                "status": "RUNNING"
            },
{%- endif %}
            "service_name": "compute.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if is_error else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}"]
    },
    "service": {
        "name": "compute.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
