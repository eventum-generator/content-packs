{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_global, pick_caller, pick_user_agent, pick_source_ip, pick_error, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set dataset = samples.datasets | random -%}
{%- set table_name = module.rand.choice(["events", "metrics", "sessions", "conversions", "page_views", "transactions"]) ~ "_" ~ module.rand.string.hex(4) -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("google.cloud.bigquery.v2.TableService.InsertTable", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_global(project) }},
    {{ ecs_block() }},
    "event": {
        "action": "google.cloud.bigquery.v2.TableService.InsertTable",
        "category": ["database", "configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["creation", "{{ 'denied' if is_error else 'allowed' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": {{ 'false' if is_error else 'true' }},
                    "permission": "bigquery.tables.create",
                    "resource_attributes": {
                        "name": "projects/{{ dataset.project_id }}/datasets/{{ dataset.dataset_id }}",
                        "service": "bigquery",
                        "type": "bigquery.datasets"
                    }
                }
            ],
            "method_name": "google.cloud.bigquery.v2.TableService.InsertTable",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.cloud.bigquery.v2.Table",
                "tableReference": {
                    "projectId": "{{ dataset.project_id }}",
                    "datasetId": "{{ dataset.dataset_id }}",
                    "tableId": "{{ table_name }}"
                }
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "project_id": "{{ dataset.project_id }}"
                },
                "type": "bigquery_dataset"
            },
            "resource_location": {
                "current_locations": ["{{ dataset.location }}"]
            },
            "resource_name": "projects/{{ dataset.project_id }}/datasets/{{ dataset.dataset_id }}/tables/{{ table_name }}",
{%- if is_error %}
            "status": {
                "code": {{ error_code }},
                "message": {{ error_message | tojson }}
            },
{%- else %}
            "response": {
                "@type": "type.googleapis.com/google.cloud.bigquery.v2.Table",
                "tableReference": {
                    "projectId": "{{ dataset.project_id }}",
                    "datasetId": "{{ dataset.dataset_id }}",
                    "tableId": "{{ table_name }}"
                },
                "creationTime": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%SZ') }}"
            },
{%- endif %}
            "service_name": "bigquery.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if is_error else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}"]
    },
    "service": {
        "name": "bigquery.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
