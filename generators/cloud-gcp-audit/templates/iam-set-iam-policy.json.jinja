{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_global, pick_caller, pick_user_agent, pick_source_ip, pick_error, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set target_user = (samples.users | random).email -%}
{%- set role = module.rand.choice(["roles/viewer", "roles/editor", "roles/storage.objectViewer", "roles/compute.instanceAdmin.v1", "roles/container.developer", "roles/bigquery.dataViewer", "roles/iam.serviceAccountUser", "roles/logging.viewer"]) -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("SetIamPolicy", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_global(project) }},
    {{ ecs_block() }},
    "event": {
        "action": "SetIamPolicy",
        "category": ["iam", "configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["admin", "{{ 'denied' if is_error else 'allowed' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": {{ 'false' if is_error else 'true' }},
                    "permission": "resourcemanager.projects.setIamPolicy",
                    "resource_attributes": {
                        "name": "projects/{{ project.project_id }}",
                        "service": "resourcemanager",
                        "type": "resourcemanager.projects"
                    }
                }
            ],
            "method_name": "SetIamPolicy",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.iam.v1.SetIamPolicyRequest",
                "policy": {
                    "bindings": [
                        {
                            "role": "{{ role }}",
                            "members": ["user:{{ target_user }}"]
                        }
                    ]
                }
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "project_id": "{{ project.project_id }}"
                },
                "type": "project"
            },
            "resource_location": {
                "current_locations": ["global"]
            },
            "resource_name": "projects/{{ project.project_id }}",
{%- if is_error %}
            "status": {
                "code": {{ error_code }},
                "message": {{ error_message | tojson }}
            },
{%- else %}
            "response": {
                "@type": "type.googleapis.com/google.iam.v1.Policy",
                "etag": "BwY{{ module.rand.string.hex(8) }}="
            },
{%- endif %}
            "service_name": "cloudresourcemanager.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if is_error else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}", "{{ target_user }}"]
    },
    "service": {
        "name": "cloudresourcemanager.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
