{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_regional, pick_caller, pick_user_agent, pick_source_ip, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set cluster = samples.gke_clusters | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_regional(project, cluster.location) }},
    {{ ecs_block() }},
    "event": {
        "action": "google.container.v1.ClusterManager.GetCluster",
        "category": ["configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "success",
        "provider": "data_access",
        "type": ["access", "allowed"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": true,
                    "permission": "container.clusters.get",
                    "resource_attributes": {
                        "name": "projects/{{ project.project_id }}/locations/{{ cluster.location }}/clusters/{{ cluster.cluster_name }}",
                        "service": "container",
                        "type": "container.projects.locations.clusters"
                    }
                }
            ],
            "method_name": "google.container.v1.ClusterManager.GetCluster",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.container.v1.GetClusterRequest",
                "name": "projects/{{ project.project_id }}/locations/{{ cluster.location }}/clusters/{{ cluster.cluster_name }}"
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "cluster_name": "{{ cluster.cluster_name }}",
                    "location": "{{ cluster.location }}",
                    "project_id": "{{ project.project_id }}"
                },
                "type": "gke_cluster"
            },
            "resource_location": {
                "current_locations": ["{{ cluster.location }}"]
            },
            "resource_name": "projects/{{ project.project_id }}/locations/{{ cluster.location }}/clusters/{{ cluster.cluster_name }}",
            "service_name": "container.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "INFO",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Fdata_access"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}"]
    },
    "service": {
        "name": "container.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
