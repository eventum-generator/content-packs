{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_global, pick_source_ip, pick_user_agent, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set user = samples.users | random -%}
{%- set login_success = module.rand.chance(0.95) -%}
{%- set outcome = "success" if login_success else "failure" -%}
{%- set ua_value = pick_user_agent("console", samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_global(project) }},
    {{ ecs_block() }},
    "event": {
        "action": "google.login.LoginService.{{ 'loginSuccess' if login_success else 'loginFailure' }}",
        "category": ["authentication"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["start", "{{ 'allowed' if login_success else 'denied' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(user.email) }},
            "method_name": "google.login.LoginService.{{ 'loginSuccess' if login_success else 'loginFailure' }}",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.login.LoginService"
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "project_id": "{{ project.project_id }}"
                },
                "type": "project"
            },
            "resource_location": {
                "current_locations": ["global"]
            },
            "resource_name": "projects/{{ project.project_id }}",
{%- if not login_success %}
            "status": {
                "code": 403,
                "message": "Login failed: invalid credentials or MFA challenge not met."
            },
{%- endif %}
            "service_name": "login.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if not login_success else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ user.email }}"]
    },
    "service": {
        "name": "login.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
