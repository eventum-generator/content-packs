{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_global, pick_caller, pick_user_agent, pick_source_ip, pick_error, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set bucket_name = project.project_id ~ "-" ~ module.rand.choice(["data", "exports", "tmp", "artifacts", "media", "cache"]) ~ "-" ~ module.rand.string.hex(4) -%}
{%- set location = module.rand.choice(["US", "EU", "US-CENTRAL1", "US-EAST1", "EUROPE-WEST1"]) -%}
{%- set storage_class = module.rand.weighted_choice(["STANDARD", "NEARLINE", "COLDLINE"], [70, 20, 10]) -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("google.storage.buckets.create", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_global(project) }},
    {{ ecs_block() }},
    "event": {
        "action": "storage.buckets.create",
        "category": ["file", "configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["creation", "{{ 'denied' if is_error else 'allowed' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": {{ 'false' if is_error else 'true' }},
                    "permission": "storage.buckets.create",
                    "resource_attributes": {
                        "name": "projects/_/buckets/{{ bucket_name }}",
                        "service": "storage",
                        "type": "storage.buckets"
                    }
                }
            ],
            "method_name": "storage.buckets.create",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/storage.buckets.create",
                "name": "{{ bucket_name }}",
                "location": "{{ location }}",
                "storageClass": "{{ storage_class }}"
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "bucket_name": "{{ bucket_name }}",
                    "project_id": "{{ project.project_id }}"
                },
                "type": "gcs_bucket"
            },
            "resource_location": {
                "current_locations": ["{{ location }}"]
            },
            "resource_name": "projects/_/buckets/{{ bucket_name }}",
{%- if is_error %}
            "status": {
                "code": {{ error_code }},
                "message": {{ error_message | tojson }}
            },
{%- else %}
            "response": {
                "@type": "type.googleapis.com/storage.buckets",
                "name": "{{ bucket_name }}",
                "location": "{{ location }}",
                "storageClass": "{{ storage_class }}",
                "timeCreated": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%SZ') }}"
            },
{%- endif %}
            "service_name": "storage.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if is_error else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}"]
    },
    "service": {
        "name": "storage.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
