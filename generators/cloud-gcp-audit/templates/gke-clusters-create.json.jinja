{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_regional, pick_caller, pick_user_agent, pick_source_ip, pick_error, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set zone = samples.zones | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set cluster_name = module.rand.choice(["prod", "staging", "dev", "test", "preview"]) ~ "-cluster-" ~ module.rand.string.hex(4) -%}
{%- set node_count = module.rand.choice([3, 5, 6, 10]) -%}
{%- set machine_type = module.rand.choice(["n2-standard-4", "n2-standard-8", "e2-standard-4", "e2-medium"]) -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("google.container.v1.ClusterManager.CreateCluster", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_regional(project, zone.region) }},
    {{ ecs_block() }},
    "event": {
        "action": "google.container.v1.ClusterManager.CreateCluster",
        "category": ["configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "{{ outcome }}",
        "provider": "activity",
        "type": ["creation", "{{ 'denied' if is_error else 'allowed' }}"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": {{ 'false' if is_error else 'true' }},
                    "permission": "container.clusters.create",
                    "resource_attributes": {
                        "name": "projects/{{ project.project_id }}/locations/{{ zone.region }}",
                        "service": "container",
                        "type": "container.projects.locations"
                    }
                }
            ],
            "method_name": "google.container.v1.ClusterManager.CreateCluster",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.container.v1.CreateClusterRequest",
                "cluster": {
                    "name": "{{ cluster_name }}",
                    "initial_node_count": {{ node_count }},
                    "node_config": {
                        "machine_type": "{{ machine_type }}",
                        "disk_size_gb": {{ module.rand.choice([50, 100, 200]) }},
                        "oauth_scopes": ["https://www.googleapis.com/auth/cloud-platform"]
                    },
                    "network": "projects/{{ project.project_id }}/global/networks/{{ (samples.networks | random).network_name }}",
                    "locations": ["{{ zone.zone }}"]
                },
                "parent": "projects/{{ project.project_id }}/locations/{{ zone.region }}"
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "cluster_name": "{{ cluster_name }}",
                    "location": "{{ zone.region }}",
                    "project_id": "{{ project.project_id }}"
                },
                "type": "gke_cluster"
            },
            "resource_location": {
                "current_locations": ["{{ zone.region }}"]
            },
            "resource_name": "projects/{{ project.project_id }}/locations/{{ zone.region }}/clusters/{{ cluster_name }}",
{%- if is_error %}
            "status": {
                "code": {{ error_code }},
                "message": {{ error_message | tojson }}
            },
{%- else %}
            "response": {
                "@type": "type.googleapis.com/google.container.v1.Operation",
                "name": "operation-{{ module.rand.string.hex(16) }}",
                "operationType": "CREATE_CLUSTER",
                "status": "RUNNING",
                "targetLink": "https://container.googleapis.com/v1/projects/{{ project.project_id }}/locations/{{ zone.region }}/clusters/{{ cluster_name }}"
            },
{%- endif %}
            "service_name": "container.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "{{ 'WARNING' if is_error else 'NOTICE' }}",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}"]
    },
    "service": {
        "name": "container.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
