{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block_global, pick_caller, pick_user_agent, pick_source_ip, authentication_info_block, request_metadata_block -%}
{%- set project = samples.projects | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set event_id = module.rand.string.hex(16) -%}
{%- set caller_data = pick_caller(samples.users, samples.service_accounts) -%}
{%- set caller_type = caller_data.split("|||")[0] -%}
{%- set caller_email = caller_data.split("|||")[1] -%}
{%- set target_sa = (samples.service_accounts | random) -%}
{%- set key_id = module.rand.string.hex(40) -%}
{%- set ua_value = pick_user_agent(caller_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block_global(project) }},
    {{ ecs_block() }},
    "event": {
        "action": "google.iam.admin.v1.CreateServiceAccountKey",
        "category": ["iam", "configuration"],
        "dataset": "gcp.audit",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "gcp",
        "outcome": "success",
        "provider": "activity",
        "type": ["creation", "allowed"]
    },
    "gcp": {
        "audit": {
            {{ authentication_info_block(caller_email) }},
            "authorization_info": [
                {
                    "granted": true,
                    "permission": "iam.serviceAccountKeys.create",
                    "resource_attributes": {
                        "name": "projects/{{ project.project_id }}/serviceAccounts/{{ target_sa.email }}",
                        "service": "iam",
                        "type": "iam.serviceAccounts"
                    }
                }
            ],
            "method_name": "google.iam.admin.v1.CreateServiceAccountKey",
            "receive_timestamp": "{{ timestamp.isoformat() }}",
            "request": {
                "@type": "type.googleapis.com/google.iam.admin.v1.CreateServiceAccountKeyRequest",
                "name": "projects/{{ project.project_id }}/serviceAccounts/{{ target_sa.email }}",
                "private_key_type": "TYPE_GOOGLE_CREDENTIALS_FILE"
            },
            {{ request_metadata_block(src_ip, ua_value) }},
            "resource": {
                "labels": {
                    "email_id": "{{ target_sa.email }}",
                    "project_id": "{{ project.project_id }}"
                },
                "type": "service_account"
            },
            "resource_location": {
                "current_locations": ["global"]
            },
            "resource_name": "projects/{{ project.project_id }}/serviceAccounts/{{ target_sa.unique_id }}/keys/{{ key_id }}",
            "response": {
                "@type": "type.googleapis.com/google.iam.admin.v1.ServiceAccountKey",
                "key_algorithm": "KEY_ALG_RSA_2048",
                "key_origin": "GOOGLE_PROVIDED",
                "key_type": "USER_MANAGED",
                "name": "projects/{{ project.project_id }}/serviceAccounts/{{ target_sa.email }}/keys/{{ key_id }}",
                "valid_after_time": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%SZ') }}",
                "valid_before_time": "{{ (timestamp + module.datetime.timedelta(days=365)).strftime('%Y-%m-%dT%H:%M:%SZ') }}"
            },
            "service_name": "iam.googleapis.com",
            "type": "type.googleapis.com/google.cloud.audit.AuditLog"
        }
    },
    "log": {
        "level": "NOTICE",
        "logger": "projects/{{ project.project_id }}/logs/cloudaudit.googleapis.com%2Factivity"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ caller_email }}", "{{ target_sa.email }}"]
    },
    "service": {
        "name": "iam.googleapis.com"
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "gcp-audit"],
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
