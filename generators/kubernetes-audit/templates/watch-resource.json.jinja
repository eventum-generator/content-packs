{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, pick_user, pick_source_ip, pick_user_agent, pick_resource, response_status_block, annotations_block -%}
{#- WATCH resource — long-running connections from controllers and operators -#}
{%- set user_type = module.rand.weighted_choice(["user", "serviceaccount", "system"], [5, 45, 50]) -%}
{%- set user_data = pick_user(samples.users, user_type) -%}
{%- set username = user_data.split("|||")[0] -%}
{%- set groups = user_data.split("|||")[1] -%}
{%- set uid = user_data.split("|||")[2] -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set ua_value = pick_user_agent(user_type, samples.user_agents) -%}
{%- set ns = (samples.namespaces | random).name -%}
{%- set resource_type = module.rand.weighted_choice(
    ["pods", "services", "configmaps", "deployments", "replicasets", "endpoints", "secrets", "namespaces"],
    [20, 15, 15, 15, 10, 10, 10, 5]
) -%}
{%- set res_data = pick_resource(samples.resources, resource_type) -%}
{%- set res_resource = res_data.split("|||")[0] -%}
{%- set res_api_group = res_data.split("|||")[1] -%}
{%- set res_api_version = res_data.split("|||")[2] -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set stage = module.rand.weighted_choice(["ResponseStarted", "ResponseComplete"], [40, 60]) -%}
{%- set rbac_reason = "RBAC: allowed by ClusterRoleBinding \"system:controller:resourcequota-controller\" of ClusterRole \"system:controller:resourcequota-controller\" to User \"" ~ username ~ "\"" -%}
{%- if res_api_group == "" -%}
    {%- set base_uri = "/api/v1" -%}
{%- else -%}
    {%- set base_uri = "/apis/" ~ res_api_group ~ "/v1" -%}
{%- endif -%}
{%- if res_resource in ["namespaces", "nodes"] -%}
    {%- set request_uri = base_uri ~ "/" ~ res_resource ~ "?watch=true&resourceVersion=" ~ module.rand.number.integer(10000, 99999) ~ "&timeout=" ~ module.rand.choice(["300s", "600s", "360s"]) -%}
{%- else -%}
    {%- set request_uri = base_uri ~ "/namespaces/" ~ ns ~ "/" ~ res_resource ~ "?watch=true&resourceVersion=" ~ module.rand.number.integer(10000, 99999) ~ "&timeout=" ~ module.rand.choice(["300s", "600s", "360s"]) -%}
{%- endif -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ ecs_block() }},
    "data_stream": {
        "dataset": "kubernetes.audit_logs",
        "namespace": "default",
        "type": "logs"
    },
    "event": {
        "action": "watch",
        "category": ["web"],
        "dataset": "kubernetes.audit_logs",
        "kind": "event",
        "module": "kubernetes",
        "outcome": "success",
        "type": ["access"]
    },
    "kubernetes": {
        "audit": {
            "auditID": "{{ audit_id }}",
            "apiVersion": "audit.k8s.io/v1",
            "kind": "Event",
            "level": "Metadata",
            "stage": "{{ stage }}",
            "verb": "watch",
            "requestURI": "{{ request_uri }}",
            "user": {
                "username": "{{ username }}",
                "uid": "{{ uid }}",
                "groups": {{ groups.split(",") | tojson }}
            },
            "sourceIPs": ["{{ src_ip }}"],
            "userAgent": {{ ua_value | tojson }},
            "objectRef": {
                "resource": "{{ res_resource }}",
{%- if res_resource not in ["namespaces", "nodes"] %}
                "namespace": "{{ ns }}",
{%- endif %}
{%- if res_api_group != "" %}
                "apiGroup": "{{ res_api_group }}",
{%- endif %}
                "apiVersion": "{{ res_api_version }}"
            },
            {{ response_status_block(200) }},
            {{ annotations_block(true, rbac_reason) }},
            "requestReceivedTimestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.') }}{{ '%06d' | format(module.rand.number.integer(0, 999999)) }}Z",
            "stageTimestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.') }}{{ '%06d' | format(module.rand.number.integer(0, 999999)) }}Z"
        }
    },
    "log": {
        "file": {
            "path": "/var/log/kubernetes/kube-apiserver-audit.log"
        }
    },
    "orchestrator": {
        "cluster": {
            "name": "{{ params.get('cluster_name', 'production-cluster') }}"
        },
        "namespace": "{{ ns }}",
        "resource": {
            "type": "{{ res_resource }}"
        },
        "type": "kubernetes"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ username }}"]
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "kubernetes-audit"],
    "user": {
        "name": "{{ username }}",
        "id": "{{ uid }}",
        "group": {
            "name": "{{ groups.split(',')[0] }}"
        }
    },
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
