{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, pick_user, pick_source_ip, pick_user_agent, pick_resource, build_request_uri, response_status_block, object_ref_block, annotations_block -%}
{#- CREATE resource — pods, deployments, services, configmaps, secrets -#}
{%- set user_type = module.rand.weighted_choice(["user", "serviceaccount", "system"], [40, 45, 15]) -%}
{%- set user_data = pick_user(samples.users, user_type) -%}
{%- set username = user_data.split("|||")[0] -%}
{%- set groups = user_data.split("|||")[1] -%}
{%- set uid = user_data.split("|||")[2] -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set ua_value = pick_user_agent(user_type, samples.user_agents) -%}
{%- set ns = module.rand.weighted_choice(
    ["default", "production", "staging", "development", "monitoring", "kube-system"],
    [15, 30, 20, 15, 10, 10]
) -%}
{%- set resource_type = module.rand.weighted_choice(
    ["pods", "deployments", "services", "configmaps", "secrets", "serviceaccounts", "ingresses"],
    [25, 20, 15, 15, 10, 10, 5]
) -%}
{%- set res_data = pick_resource(samples.resources, resource_type) -%}
{%- set res_resource = res_data.split("|||")[0] -%}
{%- set res_api_group = res_data.split("|||")[1] -%}
{%- set res_api_version = res_data.split("|||")[2] -%}
{%- set res_name = res_data.split("|||")[3] -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 3) / 100.0) -%}
{%- if is_error -%}
    {%- set status_code = module.rand.weighted_choice([403, 409, 422], [40, 30, 30]) -%}
    {%- set outcome = "failure" -%}
    {%- set is_allowed = status_code != 403 -%}
{%- else -%}
    {%- set status_code = 201 -%}
    {%- set outcome = "success" -%}
    {%- set is_allowed = true -%}
{%- endif -%}
{%- set rbac_reason = "RBAC: allowed by ClusterRoleBinding \"admin\" of ClusterRole \"admin\" to User \"" ~ username ~ "\"" if is_allowed else "RBAC: no rules matched" -%}
{%- set request_uri = build_request_uri("create", res_resource, res_api_group, res_name, ns) -%}
{%- set resource_uid = module.rand.crypto.uuid4() -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ ecs_block() }},
    "data_stream": {
        "dataset": "kubernetes.audit_logs",
        "namespace": "default",
        "type": "logs"
    },
    "event": {
        "action": "create",
        "category": ["web"],
        "dataset": "kubernetes.audit_logs",
        "kind": "event",
        "module": "kubernetes",
        "outcome": "{{ outcome }}",
        "type": ["creation"]
    },
    "kubernetes": {
        "audit": {
            "auditID": "{{ audit_id }}",
            "apiVersion": "audit.k8s.io/v1",
            "kind": "Event",
            "level": "RequestResponse",
            "stage": "ResponseComplete",
            "verb": "create",
            "requestURI": "{{ request_uri }}",
            "user": {
                "username": "{{ username }}",
                "uid": "{{ uid }}",
                "groups": {{ groups.split(",") | tojson }}
            },
            "sourceIPs": ["{{ src_ip }}"],
            "userAgent": {{ ua_value | tojson }},
            {{ object_ref_block(res_resource, res_api_group, res_api_version, res_name, ns) }},
            "responseObject": {
{%- set kind_map = {"pods": "Pod", "deployments": "Deployment", "services": "Service", "configmaps": "ConfigMap", "secrets": "Secret", "serviceaccounts": "ServiceAccount", "ingresses": "Ingress", "namespaces": "Namespace"} -%}
                "kind": "{{ kind_map.get(res_resource, res_resource) }}",
                "apiVersion": "{{ res_api_version }}",
                "metadata": {
                    "name": "{{ res_name }}",
                    "namespace": "{{ ns }}",
                    "uid": "{{ resource_uid }}",
                    "creationTimestamp": "{{ timestamp.isoformat() }}"
                }
            },
            {{ response_status_block(status_code) }},
            {{ annotations_block(is_allowed, rbac_reason) }},
            "requestReceivedTimestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.') }}{{ '%06d' | format(module.rand.number.integer(0, 999999)) }}Z",
            "stageTimestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.') }}{{ '%06d' | format(module.rand.number.integer(0, 999999)) }}Z"
        }
    },
    "log": {
        "file": {
            "path": "/var/log/kubernetes/kube-apiserver-audit.log"
        }
    },
    "orchestrator": {
        "cluster": {
            "name": "{{ params.get('cluster_name', 'production-cluster') }}"
        },
        "namespace": "{{ ns }}",
        "resource": {
            "name": "{{ res_name }}",
            "type": "{{ res_resource }}"
        },
        "type": "kubernetes"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ username }}"]
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "kubernetes-audit"],
    "user": {
        "name": "{{ username }}",
        "id": "{{ uid }}",
        "group": {
            "name": "{{ groups.split(',')[0] }}"
        }
    },
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
