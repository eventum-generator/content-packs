{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, pick_user, pick_source_ip, pick_user_agent, pick_resource, response_status_block, annotations_block -%}
{#- EXEC / ATTACH to pods — security-sensitive subresource operations -#}
{%- set user_type = module.rand.weighted_choice(["user", "serviceaccount"], [70, 30]) -%}
{%- set user_data = pick_user(samples.users, user_type) -%}
{%- set username = user_data.split("|||")[0] -%}
{%- set groups = user_data.split("|||")[1] -%}
{%- set uid = user_data.split("|||")[2] -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set ua_value = pick_user_agent(user_type, samples.user_agents) -%}
{%- set ns = module.rand.weighted_choice(
    ["default", "production", "staging", "development", "monitoring", "kube-system"],
    [10, 30, 20, 20, 10, 10]
) -%}
{%- set res_data = pick_resource(samples.resources, "pods") -%}
{%- set pod_name = res_data.split("|||")[3] -%}
{%- set subresource = module.rand.weighted_choice(["exec", "attach", "portforward", "log"], [40, 20, 20, 20]) -%}
{%- set audit_id = module.rand.crypto.uuid4() -%}
{%- set is_error = module.rand.chance(params.get('error_rate', 3) / 100.0) -%}
{%- if is_error -%}
    {%- set status_code = 403 -%}
    {%- set outcome = "failure" -%}
    {%- set is_allowed = false -%}
{%- else -%}
    {%- set status_code = 200 -%}
    {%- set outcome = "success" -%}
    {%- set is_allowed = true -%}
{%- endif -%}
{%- set rbac_reason = "RBAC: allowed by RoleBinding \"namespace-admin\" of Role \"namespace-admin\" to User \"" ~ username ~ "\"" if is_allowed else "RBAC: no rules matched; user cannot exec into pods" -%}
{%- set container = module.rand.choice(["nginx", "api-server", "worker", "sidecar", "redis", "app"]) -%}
{%- if subresource == "exec" -%}
    {%- set command = module.rand.choice(["sh", "/bin/bash", "cat /etc/resolv.conf", "env", "ls -la", "whoami"]) -%}
    {%- set request_uri = "/api/v1/namespaces/" ~ ns ~ "/pods/" ~ pod_name ~ "/exec?command=" ~ command | urlencode ~ "&container=" ~ container ~ "&stdin=true&stdout=true&tty=true" -%}
{%- elif subresource == "attach" -%}
    {%- set request_uri = "/api/v1/namespaces/" ~ ns ~ "/pods/" ~ pod_name ~ "/attach?container=" ~ container ~ "&stdin=true&stdout=true&tty=true" -%}
{%- elif subresource == "portforward" -%}
    {%- set port = module.rand.choice([8080, 3000, 5432, 6379, 9090, 443]) -%}
    {%- set request_uri = "/api/v1/namespaces/" ~ ns ~ "/pods/" ~ pod_name ~ "/portforward?ports=" ~ port -%}
{%- else -%}
    {%- set request_uri = "/api/v1/namespaces/" ~ ns ~ "/pods/" ~ pod_name ~ "/log?container=" ~ container ~ "&tailLines=100" -%}
{%- endif -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ ecs_block() }},
    "data_stream": {
        "dataset": "kubernetes.audit_logs",
        "namespace": "default",
        "type": "logs"
    },
    "event": {
        "action": "{{ subresource }}",
        "category": ["web", "process"],
        "dataset": "kubernetes.audit_logs",
        "kind": "event",
        "module": "kubernetes",
        "outcome": "{{ outcome }}",
        "type": ["access", "connection"]
    },
    "kubernetes": {
        "audit": {
            "auditID": "{{ audit_id }}",
            "apiVersion": "audit.k8s.io/v1",
            "kind": "Event",
            "level": "RequestResponse",
            "stage": "ResponseComplete",
            "verb": "create",
            "requestURI": "{{ request_uri }}",
            "user": {
                "username": "{{ username }}",
                "uid": "{{ uid }}",
                "groups": {{ groups.split(",") | tojson }}
            },
            "sourceIPs": ["{{ src_ip }}"],
            "userAgent": {{ ua_value | tojson }},
            "objectRef": {
                "resource": "pods",
                "namespace": "{{ ns }}",
                "name": "{{ pod_name }}",
                "apiVersion": "v1",
                "subresource": "{{ subresource }}"
            },
            {{ response_status_block(status_code) }},
            {{ annotations_block(is_allowed, rbac_reason) }},
            "requestReceivedTimestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.') }}{{ '%06d' | format(module.rand.number.integer(0, 999999)) }}Z",
            "stageTimestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.') }}{{ '%06d' | format(module.rand.number.integer(0, 999999)) }}Z"
        }
    },
    "log": {
        "file": {
            "path": "/var/log/kubernetes/kube-apiserver-audit.log"
        }
    },
    "orchestrator": {
        "cluster": {
            "name": "{{ params.get('cluster_name', 'production-cluster') }}"
        },
        "namespace": "{{ ns }}",
        "resource": {
            "name": "{{ pod_name }}",
            "type": "pods"
        },
        "type": "kubernetes"
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ username }}"]
    },
    "source": {
        "ip": "{{ src_ip }}"
    },
    "tags": ["forwarded", "kubernetes-audit"],
    "user": {
        "name": "{{ username }}",
        "id": "{{ uid }}",
        "group": {
            "name": "{{ groups.split(',')[0] }}"
        }
    },
    "user_agent": {
        "original": {{ ua_value | tojson }}
    }
}
