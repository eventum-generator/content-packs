{%- set record_id = shared.get('record_id', 1) -%}
{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set user = (samples.usernames | random).username -%}
{%- set client_ip = module.rand.network.ip_v4_public() -%}
{%- set session_id = module.rand.number.integer(100000, 9999999) -%}
{%- set ppe = module.rand.weighted_choice(["0-PPE-0", "1-PPE-1", "2-PPE-2"], [50, 30, 20]) -%}
{#- Groups -#}
{%- set group = module.rand.weighted_choice(
  ["Domain Users", "VPN_Users", "VPN_Contractors", "VPN_Admins", "VPN_FullAccess"],
  [35, 30, 15, 10, 10]
) -%}
{#- HTTP method -#}
{%- set method = module.rand.weighted_choice(["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD"], [60, 25, 5, 2, 5, 3]) -%}
{#- Internal URLs accessed through VPN -#}
{%- set url_path = module.rand.weighted_choice(
  ["/intranet/portal/home",
   "/sharepoint/sites/engineering",
   "/owa/auth/logon.aspx",
   "/confluence/display/TEAM",
   "/jira/browse/PROJ",
   "/internal-api/v2/users",
   "/wiki/Main_Page",
   "/hr-portal/dashboard",
   "/it-helpdesk/tickets",
   "/finance/reports/quarterly"],
  [15, 12, 18, 10, 8, 10, 7, 8, 7, 5]
) -%}
{%- set url_host = module.rand.weighted_choice(
  ["intranet." ~ params.domain,
   "sharepoint." ~ params.domain,
   "mail." ~ params.domain,
   "confluence." ~ params.domain,
   "jira." ~ params.domain,
   "api." ~ params.domain,
   "wiki." ~ params.domain],
  [20, 15, 25, 12, 10, 10, 8]
) -%}
{%- set url_full = "https://" ~ url_host ~ url_path -%}
{%- set response_code = module.rand.weighted_choice([200, 301, 302, 304, 400, 401, 403, 404, 500, 503], [60, 5, 8, 10, 3, 4, 3, 4, 2, 1]) -%}
{%- set syslog_ts = timestamp.strftime('%m/%d/%Y:%H:%M:%S') ~ " GMT" -%}
{%- set syslog_msg = syslog_ts ~ " " ~ hostname ~ " " ~ ppe ~ " : default SSLVPN HTTPREQUEST " ~ record_id ~ " 0 : [TECHSUPPORT][ENUMERATION] - User " ~ user ~ ":Group(s) " ~ group ~ ":Vserver " ~ params.vserver_ip ~ ":" ~ params.vserver_port ~ ":Method " ~ method ~ " - URL " ~ url_full ~ " - Response_code " ~ response_code -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "citrix": {
        "cef_format": false,
        "device_product": "NetScaler",
        "device_vendor": "Citrix",
        "device_version": "NS14.1",
        "facility": "local0",
        "hostname": "{{ hostname }}",
        "name": "SSLVPN HTTPREQUEST",
        "ppe_id": "{{ ppe }}",
        "priority": "info",
        "session_id": "{{ session_id }}"
    },
    "citrix_adc": {
        "log": {
            "client_ip": "{{ client_ip }}",
            "group": "{{ group }}",
            "groups": "{{ group }}",
            "http_resources_accessed": "{{ url_full }}",
            "method": "{{ method }}",
            "response": {
                "code": {{ response_code }}
            },
            "session_id": "{{ session_id }}",
            "url": "{{ url_full }}",
            "user": "{{ user }}",
            "username": "{{ user }}",
            "vserver": {
                "ip": "{{ params.vserver_ip }}",
                "port": {{ params.vserver_port }}
            }
        }
    },
    "client": {
        "ip": "{{ client_ip }}"
    },
    "data_stream": {
        "dataset": "citrix_adc.log",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "http-request",
        "category": ["network", "web"],
        "dataset": "citrix_adc.log",
        "kind": "event",
        "module": "citrix_adc",
        "original": "{{ syslog_msg }}",
        "outcome": "{{ 'success' if response_code < 400 else 'failure' }}",
        "severity": 6,
        "type": ["access"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "http": {
        "request": {
            "method": "{{ method }}"
        },
        "response": {
            "status_code": {{ response_code }}
        }
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 16
            },
            "priority": 134,
            "severity": {
                "code": 6
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "Netscaler",
        "type": "firewall",
        "vendor": "Citrix"
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ url_host }}"],
        "ip": ["{{ client_ip }}"],
        "user": ["{{ user }}"]
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "user": {
            "group": {
                "name": "{{ group }}"
            },
            "name": "{{ user }}"
        }
    },
    "url": {
        "domain": "{{ url_host }}",
        "full": "{{ url_full }}",
        "original": "{{ url_full }}",
        "path": "{{ url_path }}",
        "scheme": "https"
    },
    "user": {
        "name": "{{ user }}",
        "domain": "{{ params.domain }}"
    },
    "tags": ["citrix_adc.log", "forwarded"]
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}