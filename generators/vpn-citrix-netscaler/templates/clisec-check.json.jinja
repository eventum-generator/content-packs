{%- set record_id = shared.get('record_id', 1) -%}
{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set user = (samples.usernames | random).username -%}
{%- set client_ip = module.rand.network.ip_v4_public() -%}
{%- set session_id = module.rand.number.integer(100000, 9999999) -%}
{%- set ppe = module.rand.weighted_choice(["0-PPE-0", "1-PPE-1", "2-PPE-2"], [50, 30, 20]) -%}
{#- Client security check status -#}
{%- set check_status = module.rand.weighted_choice(
  ["Passed", "Failed"],
  [70, 30]
) -%}
{%- set check_expression = module.rand.weighted_choice(
  ["CLIENT.APPLICATION.AV(McAfee).VERSION >= 4.0",
   "CLIENT.APPLICATION.AV(Symantec).VERSION >= 14.0",
   "CLIENT.APPLICATION.PROCESS(CrowdStrike*) EXISTS",
   "CLIENT.OS.VERSION >= 10.0",
   "CLIENT.APPLICATION.FW(Windows) EXISTS",
   "CLIENT.DOMAIN EQUALS corp.example.com"],
  [20, 20, 15, 20, 15, 10]
) -%}
{%- set syslog_ts = timestamp.strftime('%m/%d/%Y:%H:%M:%S') ~ " GMT" -%}
{%- set syslog_msg = syslog_ts ~ " " ~ hostname ~ " " ~ ppe ~ " : default SSLVPN CLISEC_CHECK " ~ record_id ~ " 0 : " ~ check_status ~ ":" ~ check_expression ~ " - ClientIP " ~ client_ip ~ " - Vserver " ~ params.vserver_ip ~ ":" ~ params.vserver_port ~ " - User " ~ user ~ " - SessionId: " ~ session_id -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "citrix": {
        "cef_format": false,
        "device_product": "NetScaler",
        "device_vendor": "Citrix",
        "device_version": "NS14.1",
        "facility": "local0",
        "hostname": "{{ hostname }}",
        "name": "SSLVPN CLISEC_CHECK",
        "ppe_id": "{{ ppe }}",
        "priority": "{{ 'error' if check_status == 'Failed' else 'info' }}",
        "session_id": "{{ session_id }}"
    },
    "citrix_adc": {
        "log": {
            "client_ip": "{{ client_ip }}",
            "client_security_check_status": "{{ check_status }}",
            "client_security_expression": "{{ check_expression }}",
            "session_id": "{{ session_id }}",
            "user": "{{ user }}",
            "username": "{{ user }}",
            "vserver": {
                "ip": "{{ params.vserver_ip }}",
                "port": {{ params.vserver_port }}
            }
        }
    },
    "client": {
        "ip": "{{ client_ip }}"
    },
    "data_stream": {
        "dataset": "citrix_adc.log",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "client-security-check",
        "category": ["host", "network"],
        "dataset": "citrix_adc.log",
        "kind": "event",
        "module": "citrix_adc",
        "original": "{{ syslog_msg }}",
        "outcome": "{{ 'success' if check_status == 'Passed' else 'failure' }}",
        "severity": {{ 3 if check_status == 'Failed' else 6 }},
        "type": ["info"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "{{ 'error' if check_status == 'Failed' else 'informational' }}",
        "syslog": {
            "facility": {
                "code": 16
            },
            "priority": {{ 131 if check_status == 'Failed' else 134 }},
            "severity": {
                "code": {{ 3 if check_status == 'Failed' else 6 }}
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "Netscaler",
        "type": "firewall",
        "vendor": "Citrix"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ client_ip }}"],
        "user": ["{{ user }}"]
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "user": {
            "name": "{{ user }}"
        }
    },
    "user": {
        "name": "{{ user }}",
        "domain": "{{ params.domain }}"
    },
    "tags": ["citrix_adc.log", "forwarded"]
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}