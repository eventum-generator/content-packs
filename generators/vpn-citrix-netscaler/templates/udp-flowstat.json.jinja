{%- set record_id = shared.get('record_id', 1) -%}
{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set user = (samples.usernames | random).username -%}
{%- set client_ip = module.rand.network.ip_v4_public() -%}
{%- set client_port = module.rand.number.integer(49152, 65535) -%}
{%- set session_id = module.rand.number.integer(100000, 9999999) -%}
{%- set ppe = module.rand.weighted_choice(["0-PPE-0", "1-PPE-1", "2-PPE-2"], [50, 30, 20]) -%}
{#- Internal destination — UDP services like DNS, NTP, SNMP -#}
{%- set dest_ip = params.internal_network ~ "." ~ module.rand.number.integer(1, 254) ~ "." ~ module.rand.number.integer(1, 254) -%}
{%- set dest_port = module.rand.weighted_choice([53, 123, 161, 514, 1812, 443], [35, 15, 10, 15, 15, 10]) -%}
{#- Bytes -#}
{%- set bytes_sent = module.rand.number.integer(100, 500000) -%}
{%- set bytes_rcv = module.rand.number.integer(200, 1000000) -%}
{%- set syslog_ts = timestamp.strftime('%m/%d/%Y:%H:%M:%S') ~ " GMT" -%}
{%- set syslog_msg = syslog_ts ~ " " ~ hostname ~ " " ~ ppe ~ " : default SSLVPN UDPFLOWSTAT " ~ record_id ~ " 0 : [TECHSUPPORT] User " ~ user ~ " - Client_ip " ~ client_ip ~ " - Nat_ip " ~ params.nat_ip ~ " - Vserver " ~ params.vserver_ip ~ ":" ~ params.vserver_port ~ " - Source " ~ client_ip ~ ":" ~ client_port ~ " - Destination " ~ dest_ip ~ ":" ~ dest_port ~ " - Total_bytes_send " ~ bytes_sent ~ " - Total_bytes_recv " ~ bytes_rcv -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "citrix": {
        "cef_format": false,
        "device_product": "NetScaler",
        "device_vendor": "Citrix",
        "device_version": "NS14.1",
        "facility": "local0",
        "hostname": "{{ hostname }}",
        "name": "SSLVPN UDPFLOWSTAT",
        "ppe_id": "{{ ppe }}",
        "priority": "info",
        "session_id": "{{ session_id }}"
    },
    "citrix_adc": {
        "log": {
            "bytes": {
                "received": {{ bytes_rcv }},
                "sent": {{ bytes_sent }}
            },
            "client_ip": "{{ client_ip }}",
            "client_port": {{ client_port }},
            "destination": {
                "ip": "{{ dest_ip }}",
                "port": {{ dest_port }}
            },
            "nat": {
                "ip": "{{ params.nat_ip }}"
            },
            "session_id": "{{ session_id }}",
            "source": {
                "ip": "{{ client_ip }}",
                "port": {{ client_port }}
            },
            "total_bytes_send": {{ bytes_sent }},
            "total_bytes_received": {{ bytes_rcv }},
            "user": "{{ user }}",
            "username": "{{ user }}",
            "vserver": {
                "ip": "{{ params.vserver_ip }}",
                "port": {{ params.vserver_port }}
            }
        }
    },
    "client": {
        "ip": "{{ client_ip }}",
        "port": {{ client_port }}
    },
    "data_stream": {
        "dataset": "citrix_adc.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ dest_ip }}",
        "bytes": {{ bytes_rcv }},
        "ip": "{{ dest_ip }}",
        "port": {{ dest_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "flow-statistics",
        "category": ["network"],
        "dataset": "citrix_adc.log",
        "kind": "event",
        "module": "citrix_adc",
        "original": "{{ syslog_msg }}",
        "outcome": "success",
        "severity": 6,
        "type": ["connection", "info"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 16
            },
            "priority": 134,
            "severity": {
                "code": 6
            }
        }
    },
    "network": {
        "bytes": {{ bytes_sent + bytes_rcv }},
        "transport": "udp"
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "Netscaler",
        "type": "firewall",
        "vendor": "Citrix"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ client_ip }}", "{{ dest_ip }}", "{{ params.nat_ip }}"],
        "user": ["{{ user }}"]
    },
    "source": {
        "address": "{{ client_ip }}",
        "bytes": {{ bytes_sent }},
        "ip": "{{ client_ip }}",
        "port": {{ client_port }},
        "user": {
            "name": "{{ user }}"
        }
    },
    "user": {
        "name": "{{ user }}",
        "domain": "{{ params.domain }}"
    },
    "tags": ["citrix_adc.log", "forwarded"]
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}