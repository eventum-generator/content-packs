{%- set record_id = shared.get('record_id', 1) -%}
{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set ppe = module.rand.weighted_choice(["0-PPE-0", "1-PPE-1", "2-PPE-2"], [50, 30, 20]) -%}
{%- set license_limit = module.rand.weighted_choice([100, 250, 500, 1000, 2500], [10, 25, 30, 25, 10]) -%}
{%- set syslog_ts = timestamp.strftime('%m/%d/%Y:%H:%M:%S') ~ " GMT" -%}
{%- set syslog_msg = syslog_ts ~ " " ~ hostname ~ " " ~ ppe ~ " : default SSLVPN LICLMT_REACHED " ~ record_id ~ " 0 : Vserver " ~ params.vserver_ip ~ ":" ~ params.vserver_port ~ " - License_limit " ~ license_limit -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "citrix": {
        "cef_format": false,
        "device_product": "NetScaler",
        "device_vendor": "Citrix",
        "device_version": "NS14.1",
        "facility": "local0",
        "hostname": "{{ hostname }}",
        "name": "SSLVPN LICLMT_REACHED",
        "ppe_id": "{{ ppe }}",
        "priority": "info",
        "session_id": "0"
    },
    "citrix_adc": {
        "log": {
            "license_limit": {{ license_limit }},
            "vserver": {
                "ip": "{{ params.vserver_ip }}",
                "port": {{ params.vserver_port }}
            }
        }
    },
    "data_stream": {
        "dataset": "citrix_adc.log",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "license-limit-reached",
        "category": ["network"],
        "dataset": "citrix_adc.log",
        "kind": "alert",
        "module": "citrix_adc",
        "original": "{{ syslog_msg }}",
        "severity": 6,
        "type": ["info"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 16
            },
            "priority": 134,
            "severity": {
                "code": 6
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "Netscaler",
        "type": "firewall",
        "vendor": "Citrix"
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ params.vserver_ip }}"]
    },
    "tags": ["citrix_adc.log", "forwarded"]
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}