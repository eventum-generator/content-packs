{%- set record_id = shared.get('record_id', 1) -%}
{%- set hostname = params.hostname -%}
{%- set fqdn = hostname ~ '.' ~ params.domain -%}
{%- set ppe = module.rand.weighted_choice(["0-PPE-0", "1-PPE-1", "2-PPE-2"], [50, 30, 20]) -%}
{#- Consume from ICA sessions pool for correlation -#}
{%- set ica_sessions = shared.get('ica_sessions', []) -%}
{%- if ica_sessions | length > 0 -%}
  {%- set session = ica_sessions.pop(0) -%}
  {%- do shared.set('ica_sessions', ica_sessions) -%}
  {%- set user = session.user -%}
  {%- set client_ip = session.client_ip -%}
  {%- set client_port = session.client_port -%}
  {%- set dest_ip = session.dest_ip -%}
  {%- set dest_port = session.dest_port -%}
  {%- set app_name = session.app_name -%}
  {%- set app_server = session.app_server -%}
  {%- set ica_uuid = session.ica_uuid -%}
  {%- set session_id = session.session_id -%}
{%- else -%}
  {%- set user = (samples.usernames | random).username -%}
  {%- set client_ip = module.rand.network.ip_v4_public() -%}
  {%- set client_port = module.rand.number.integer(49152, 65535) -%}
  {%- set dest_ip = params.internal_network ~ "." ~ module.rand.number.integer(1, 254) ~ "." ~ module.rand.number.integer(1, 254) -%}
  {%- set dest_port = module.rand.weighted_choice([1494, 2598, 443], [40, 45, 15]) -%}
  {%- set app_weights = samples.ica_apps | map(attribute='weight') | list -%}
  {%- set app = module.rand.weighted_choice(samples.ica_apps, app_weights) -%}
  {%- set app_name = app.name -%}
  {%- set app_server = app.server -%}
  {%- set ica_uuid = module.rand.crypto.uuid4() -%}
  {%- set session_id = module.rand.number.integer(100000, 9999999) -%}
{%- endif -%}
{#- Connection duration and bytes -#}
{%- set duration_secs = module.rand.number.integer(60, 28800) -%}
{%- set dur_hours = duration_secs // 3600 -%}
{%- set dur_minutes = (duration_secs % 3600) // 60 -%}
{%- set dur_seconds = duration_secs % 60 -%}
{%- set duration_str = "%02d:%02d:%02d" | format(dur_hours, dur_minutes, dur_seconds) -%}
{%- set bytes_sent = module.rand.number.integer(50000, 200000000) -%}
{%- set bytes_rcv = module.rand.number.integer(100000, 800000000) -%}
{%- set syslog_ts = timestamp.strftime('%m/%d/%Y:%H:%M:%S') ~ " GMT" -%}
{%- set syslog_msg = syslog_ts ~ " " ~ hostname ~ " " ~ ppe ~ " : default SSLVPN ICAEND_CONNSTAT " ~ record_id ~ " 0 : [TECHSUPPORT][LAUNCH][" ~ app_name ~ "][" ~ app_server ~ "][ICAUUID=" ~ ica_uuid ~ "] - Source " ~ client_ip ~ ":" ~ client_port ~ " - Destination " ~ dest_ip ~ ":" ~ dest_port ~ " - username:domainname " ~ user ~ ":" ~ params.domain ~ " - Duration " ~ duration_str ~ " - Total_bytes_send " ~ bytes_sent ~ " - Total_bytes_recv " ~ bytes_rcv -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ fqdn }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "citrix": {
        "cef_format": false,
        "device_product": "NetScaler",
        "device_vendor": "Citrix",
        "device_version": "NS14.1",
        "facility": "local0",
        "hostname": "{{ hostname }}",
        "name": "SSLVPN ICAEND_CONNSTAT",
        "ppe_id": "{{ ppe }}",
        "priority": "info",
        "session_id": "{{ session_id }}"
    },
    "citrix_adc": {
        "log": {
            "application_name": "{{ app_name }}",
            "bytes": {
                "received": {{ bytes_rcv }},
                "sent": {{ bytes_sent }}
            },
            "client_ip": "{{ client_ip }}",
            "client_port": {{ client_port }},
            "destination": {
                "ip": "{{ dest_ip }}",
                "port": {{ dest_port }}
            },
            "duration": "{{ duration_str }}",
            "session_id": "{{ session_id }}",
            "source": {
                "ip": "{{ client_ip }}",
                "port": {{ client_port }}
            },
            "total_bytes_send": {{ bytes_sent }},
            "total_bytes_received": {{ bytes_rcv }},
            "user": "{{ user }}",
            "username": "{{ user }}",
            "vserver": {
                "ip": "{{ params.vserver_ip }}",
                "port": {{ params.vserver_port }}
            }
        }
    },
    "client": {
        "ip": "{{ client_ip }}",
        "port": {{ client_port }}
    },
    "data_stream": {
        "dataset": "citrix_adc.log",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        "address": "{{ dest_ip }}",
        "bytes": {{ bytes_rcv }},
        "ip": "{{ dest_ip }}",
        "port": {{ dest_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "application-terminated",
        "category": ["network", "session"],
        "dataset": "citrix_adc.log",
        "duration": {{ duration_secs * 1000000000 }},
        "end": "{{ timestamp.isoformat() }}",
        "kind": "event",
        "module": "citrix_adc",
        "original": "{{ syslog_msg }}",
        "outcome": "success",
        "severity": 6,
        "type": ["connection", "end"]
    },
    "host": {
        "hostname": "{{ hostname }}"
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 16
            },
            "priority": 134,
            "severity": {
                "code": 6
            }
        }
    },
    "network": {
        "bytes": {{ bytes_sent + bytes_rcv }}
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "name": "{{ fqdn }}",
        "product": "Netscaler",
        "type": "firewall",
        "vendor": "Citrix"
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ app_server }}"],
        "ip": ["{{ client_ip }}", "{{ dest_ip }}"],
        "user": ["{{ user }}"]
    },
    "source": {
        "address": "{{ client_ip }}",
        "bytes": {{ bytes_sent }},
        "ip": "{{ client_ip }}",
        "port": {{ client_port }},
        "user": {
            "name": "{{ user }}"
        }
    },
    "user": {
        "name": "{{ user }}",
        "domain": "{{ params.domain }}"
    },
    "tags": ["citrix_adc.log", "forwarded"]
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}