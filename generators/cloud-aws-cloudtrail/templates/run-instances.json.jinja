{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, tls_block, pick_user_agent, pick_source_ip, pick_error -%}
{%- set record_id = shared.get('record_counter', 0) -%}
{%- set account = samples.accounts | random -%}
{%- set region = samples.regions | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set request_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{#- Identity — usually AssumedRole for RunInstances -#}
{%- set identity_type = module.rand.weighted_choice(["AssumedRole", "IAMUser"], [75, 25]) -%}
{%- if identity_type == "AssumedRole" -%}
    {%- set assumed_roles = shared.get('assumed_roles', []) -%}
    {%- if assumed_roles | length > 0 -%}
        {%- set role_entry = module.rand.choice(assumed_roles) -%}
    {%- else -%}
        {%- set role = samples.roles | random -%}
        {%- set role_entry = {"role_name": role.role_name, "role_id": role.role_id, "session_name": role.session_prefix ~ "-" ~ module.rand.string.hex(6), "access_key_id": "ASIA" ~ module.rand.string.letters_uppercase(12) ~ module.rand.string.digits(4), "account_id": account.account_id} -%}
    {%- endif -%}
    {%- set identity_arn = "arn:aws:sts::" ~ role_entry.account_id ~ ":assumed-role/" ~ role_entry.role_name ~ "/" ~ role_entry.session_name -%}
    {%- set identity_principal = role_entry.role_id ~ ":" ~ role_entry.session_name -%}
    {%- set identity_key = role_entry.access_key_id -%}
    {%- set identity_user_name = role_entry.role_name -%}
    {%- set identity_account = role_entry.account_id -%}
{%- else -%}
    {%- set user = samples.users | random -%}
    {%- set identity_arn = "arn:aws:iam::" ~ account.account_id ~ ":user/" ~ user.username -%}
    {%- set identity_principal = user.principal_id -%}
    {%- set identity_key = user.access_key_id -%}
    {%- set identity_user_name = user.username -%}
    {%- set identity_account = account.account_id -%}
{%- endif -%}
{#- Instance details -#}
{%- set instance_type = module.rand.weighted_choice(["t3.micro", "t3.small", "t3.medium", "t3.large", "m5.large", "m5.xlarge", "c5.large", "c5.xlarge", "r5.large"], [15, 15, 20, 15, 10, 8, 7, 5, 5]) -%}
{%- set new_instance_id = "i-0" ~ module.rand.string.hex(16) -%}
{%- set az = region.region_code ~ module.rand.choice(["a", "b", "c"]) -%}
{%- set ami_id = "ami-0" ~ module.rand.string.hex(16) -%}
{%- set sg = samples.security_groups | random -%}
{#- Error injection -#}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("RunInstances", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
    {#- Store new instance in shared pool -#}
    {%- set running_instances = shared.get('running_instances', []) -%}
    {%- do running_instances.append({"instance_id": new_instance_id, "instance_type": instance_type, "az": az}) -%}
    {%- if running_instances | length > 100 -%}{%- do running_instances.pop(0) -%}{%- endif -%}
    {%- do shared.set('running_instances', running_instances) -%}
{%- endif -%}
{%- set req_params = {"instancesSet": {"items": [{"imageId": ami_id, "minCount": 1, "maxCount": 1}]}, "instanceType": instance_type, "monitoring": {"enabled": false}, "subnetId": "subnet-0" ~ module.rand.string.hex(16), "groupSet": {"items": [{"groupId": sg.group_id}]}} -%}
{%- set ua_value = pick_user_agent(identity_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block(account, region) }},
    {{ ecs_block() }},
    "event": {
        "action": "RunInstances",
        "category": ["host"],
        "dataset": "aws.cloudtrail",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "aws",
        "outcome": "{{ outcome }}",
        "provider": "cloudtrail",
        "type": ["creation"]
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}"
    },
    "user": {
        "name": "{{ identity_user_name }}",
        "id": "{{ identity_principal }}"
    },
    "user_agent": {
        "original": {{ ua_value | tojson }}
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ identity_user_name }}"]
    },
    "aws": {
        "cloudtrail": {
            "event_version": "{{ params.event_version }}",
            "event_source": "ec2.amazonaws.com",
            "event_name": "RunInstances",
            "event_type": "AwsApiCall",
            "event_category": "Management",
            "management_event": true,
            "read_only": false,
            "recipient_account_id": "{{ account.account_id }}",
            "request_id": "{{ request_id }}",
{%- if identity_type == "AssumedRole" %}
            "user_identity": {
                "type": "AssumedRole",
                "principal_id": "{{ identity_principal }}",
                "arn": "{{ identity_arn }}",
                "account_id": "{{ identity_account }}",
                "access_key_id": "{{ identity_key }}",
                "session_context": {
                    "session_issuer": {
                        "type": "Role",
                        "principal_id": "{{ role_entry.role_id }}",
                        "arn": "arn:aws:iam::{{ identity_account }}:role/{{ identity_user_name }}",
                        "account_id": "{{ identity_account }}",
                        "user_name": "{{ identity_user_name }}"
                    },
                    "attributes": {
                        "creation_date": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%SZ') }}",
                        "mfa_authenticated": "false"
                    }
                }
            },
{%- else %}
            "user_identity": {
                "type": "IAMUser",
                "principal_id": "{{ identity_principal }}",
                "arn": "{{ identity_arn }}",
                "account_id": "{{ identity_account }}",
                "access_key_id": "{{ identity_key }}",
                "user_name": "{{ identity_user_name }}"
            },
{%- endif %}
            "request_parameters": {{ req_params | tojson }},
{%- if is_error %}
            "error_code": "{{ error_code }}",
            "error_message": {{ error_message | tojson }},
            "response_elements": null,
{%- else %}
            "response_elements": {{ ({"requestId": request_id, "reservationId": "r-0" ~ module.rand.string.hex(16), "ownerId": account.account_id, "instancesSet": {"items": [{"instanceId": new_instance_id, "imageId": ami_id, "instanceState": {"code": 0, "name": "pending"}, "instanceType": instance_type, "availabilityZone": az, "privateDnsName": "ip-10-0-" ~ module.rand.number.integer(1, 254) ~ "-" ~ module.rand.number.integer(1, 254) ~ ".ec2.internal", "privateIpAddress": "10.0." ~ module.rand.number.integer(1, 254) ~ "." ~ module.rand.number.integer(1, 254)}]}}) | tojson }},
{%- endif %}
            {{ tls_block("ec2.amazonaws.com", region) }}
        }
    }
}
{%- do shared.set('record_counter', record_id + 1) -%}
