{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, tls_block, pick_user_agent, pick_source_ip, pick_error, iam_user_identity, assumed_role_identity -%}
{%- set record_id = shared.get('record_counter', 0) -%}
{%- set account = samples.accounts | random -%}
{%- set region = samples.regions | random -%}
{%- set src_ip = pick_source_ip(samples.source_ips) -%}
{%- set request_id = module.rand.crypto.uuid4() -%}
{%- set event_id = module.rand.crypto.uuid4() -%}
{#- Identity: mostly AssumedRole for EC2 operations -#}
{%- set identity_type = module.rand.weighted_choice(["AssumedRole", "IAMUser", "AWSService"], [65, 25, 10]) -%}
{%- if identity_type == "AssumedRole" -%}
    {%- set assumed_roles = shared.get('assumed_roles', []) -%}
    {%- if assumed_roles | length > 0 -%}
        {%- set role_entry = module.rand.choice(assumed_roles) -%}
        {%- set identity_arn = "arn:aws:sts::" ~ role_entry.account_id ~ ":assumed-role/" ~ role_entry.role_name ~ "/" ~ role_entry.session_name -%}
        {%- set identity_principal = role_entry.role_id ~ ":" ~ role_entry.session_name -%}
        {%- set identity_key = role_entry.access_key_id -%}
        {%- set identity_user_name = role_entry.role_name -%}
        {%- set identity_account = role_entry.account_id -%}
        {%- set role_id_only = role_entry.role_id -%}
    {%- else -%}
        {%- set role = samples.roles | random -%}
        {%- set sess = role.session_prefix ~ "-" ~ module.rand.string.hex(6) -%}
        {%- set identity_arn = "arn:aws:sts::" ~ account.account_id ~ ":assumed-role/" ~ role.role_name ~ "/" ~ sess -%}
        {%- set identity_principal = role.role_id ~ ":" ~ sess -%}
        {%- set identity_key = "ASIA" ~ module.rand.string.letters_uppercase(12) ~ module.rand.string.digits(4) -%}
        {%- set identity_user_name = role.role_name -%}
        {%- set identity_account = account.account_id -%}
        {%- set role_id_only = role.role_id -%}
    {%- endif -%}
{%- elif identity_type == "IAMUser" -%}
    {%- set user = samples.users | random -%}
    {%- set identity_arn = "arn:aws:iam::" ~ account.account_id ~ ":user/" ~ user.username -%}
    {%- set identity_principal = user.principal_id -%}
    {%- set identity_key = user.access_key_id -%}
    {%- set identity_user_name = user.username -%}
    {%- set identity_account = account.account_id -%}
{%- else -%}
    {%- set svc_name = module.rand.choice(["ec2.amazonaws.com", "autoscaling.amazonaws.com", "elasticloadbalancing.amazonaws.com"]) -%}
    {%- set identity_user_name = svc_name -%}
    {%- set identity_account = account.account_id -%}
{%- endif -%}
{#- Error injection -#}
{%- set is_error = module.rand.chance(params.get('error_rate', 4) / 100.0) -%}
{%- if is_error -%}
    {%- set err_data = pick_error("DescribeInstances", samples.error_scenarios) -%}
    {%- set error_code = err_data.split("|||")[0] -%}
    {%- set error_message = err_data.split("|||")[1] -%}
    {%- set outcome = "failure" -%}
{%- else -%}
    {%- set outcome = "success" -%}
{%- endif -%}
{#- Request parameters -#}
{%- set has_filter = module.rand.chance(0.4) -%}
{%- if has_filter -%}
    {%- set instance = samples.instances | random -%}
    {%- set req_params = {"instancesSet": {"items": [{"instanceId": instance.instance_id}]}, "filterSet": {}} -%}
{%- else -%}
    {%- set req_params = {"instancesSet": {}, "filterSet": {}, "maxResults": module.rand.choice([100, 500, 1000])} -%}
{%- endif -%}
{%- set ua_value = pick_user_agent(identity_type, samples.user_agents) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block(account, region) }},
    {{ ecs_block() }},
    "event": {
        "action": "DescribeInstances",
        "category": ["host"],
        "dataset": "aws.cloudtrail",
        "id": "{{ event_id }}",
        "kind": "event",
        "module": "aws",
        "outcome": "{{ outcome }}",
        "provider": "cloudtrail",
        "type": ["info"]
    },
{%- if identity_type != "AWSService" %}
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}"
    },
    "user": {
        "name": "{{ identity_user_name }}",
        "id": "{{ identity_principal }}"
    },
{%- endif %}
    "user_agent": {
        "original": {{ ua_value | tojson }}
    },
    "related": {
{%- if identity_type != "AWSService" %}
        "ip": ["{{ src_ip }}"],
{%- endif %}
        "user": ["{{ identity_user_name }}"]
    },
    "aws": {
        "cloudtrail": {
            "event_version": "{{ params.event_version }}",
            "event_source": "ec2.amazonaws.com",
            "event_name": "DescribeInstances",
            "event_type": "AwsApiCall",
            "event_category": "Management",
            "management_event": true,
            "read_only": true,
            "recipient_account_id": "{{ account.account_id }}",
            "request_id": "{{ request_id }}",
{%- if identity_type == "AssumedRole" %}
            "user_identity": {
                "type": "AssumedRole",
                "principal_id": "{{ identity_principal }}",
                "arn": "{{ identity_arn }}",
                "account_id": "{{ identity_account }}",
                "access_key_id": "{{ identity_key }}",
                "session_context": {
                    "session_issuer": {
                        "type": "Role",
                        "principal_id": "{{ role_id_only }}",
                        "arn": "arn:aws:iam::{{ identity_account }}:role/{{ identity_user_name }}",
                        "account_id": "{{ identity_account }}",
                        "user_name": "{{ identity_user_name }}"
                    },
                    "attributes": {
                        "creation_date": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%SZ') }}",
                        "mfa_authenticated": "false"
                    }
                }
            },
{%- elif identity_type == "IAMUser" %}
            "user_identity": {
                "type": "IAMUser",
                "principal_id": "{{ identity_principal }}",
                "arn": "{{ identity_arn }}",
                "account_id": "{{ identity_account }}",
                "access_key_id": "{{ identity_key }}",
                "user_name": "{{ identity_user_name }}"
            },
{%- else %}
            "user_identity": {
                "type": "AWSService",
                "invoked_by": "{{ svc_name }}"
            },
{%- endif %}
            "request_parameters": {{ req_params | tojson }},
{%- if is_error %}
            "error_code": "{{ error_code }}",
            "error_message": {{ error_message | tojson }},
            "response_elements": null,
{%- else %}
            "response_elements": null,
{%- endif %}
            {{ tls_block("ec2.amazonaws.com", region) }}
        }
    }
}
{%- do shared.set('record_counter', record_id + 1) -%}
