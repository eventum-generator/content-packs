{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set eid = next_event_id(shared) | int -%}
{%- set internal_type = module.rand.weighted_choice(['item_unsupported', 'trigger_unknown', 'lld_unsupported'], [50, 30, 20]) -%}
{%- if internal_type == 'item_unsupported' -%}
  {%- set item_key = module.rand.choice([
    'net.tcp.service[http,,8080]',
    'proc.num[mysqld]',
    'vfs.fs.size[/data,pfree]',
    'system.hw.cpu[0,freq]',
    'net.if.in[bond0]',
    'log[/var/log/app/error.log]',
    'web.page.get[http://localhost:9200]',
    'agent.hostname'
  ]) -%}
  {%- set error_msg = module.rand.choice([
    'Cannot open file "/var/log/app/error.log": [13] Permission denied',
    'Timeout while connecting to host',
    'Get value from agent failed: cannot connect to [[' ~ host.ip ~ ']:10050]: [111] Connection refused',
    'Not supported by Zabbix Agent',
    'Cannot open performance counter',
    'Network is unreachable'
  ]) -%}
  {%- set object_type = 4 -%}
  {%- set event_name = 'Item "' ~ item_key ~ '" became not supported' -%}
{%- elif internal_type == 'trigger_unknown' -%}
  {%- set trigger = samples.trigger_scenarios.pick() -%}
  {%- set error_msg = module.rand.choice([
    'Cannot evaluate expression: item is not supported',
    'Cannot evaluate function "last": not enough data',
    'Cannot evaluate expression: a]syntax error',
    'Trigger depends on item that is not supported'
  ]) -%}
  {%- set object_type = 0 -%}
  {%- set event_name = 'Trigger "' ~ trigger.description ~ '" became unknown' -%}
  {%- set item_key = trigger.item_key -%}
{%- else -%}
  {%- set item_key = module.rand.choice([
    'net.if.discovery',
    'vfs.fs.discovery',
    'system.cpu.discovery',
    'net.tcp.listen'
  ]) -%}
  {%- set error_msg = module.rand.choice([
    'Cannot execute discovery rule: timeout',
    'Cannot perform low-level discovery: agent returned empty response',
    'Invalid discovery rule value: not a JSON object'
  ]) -%}
  {%- set object_type = 5 -%}
  {%- set event_name = 'LLD rule "' ~ item_key ~ '" became not supported' -%}
{%- endif -%}
{%- set value = module.rand.weighted_choice([1, 0], [70, 30]) -%}
{
    {{ event_base(["host"], ["info"], "event", 2, "failure", timestamp, params) }},
    "message": {{ (event_name ~ ': ' ~ error_msg if value == 1 else 'Resolved: ' ~ event_name) | tojson }},
    "zabbix": {
        "event": {
            "eventid": {{ eid }},
            "source": 3,
            "object": {{ object_type }},
            "objectid": {{ module.rand.number.integer(30000, 39999) }},
            "value": {{ value }},
            "name": {{ event_name | tojson }}
        },
        "internal": {
            "type": {{ internal_type | tojson }},
            "item_key": {{ item_key | tojson }},
            "error": {{ (error_msg if value == 1 else '') | tojson }}
        },
        "host": {
            "hostid": {{ host.hostid | tojson }},
            "host": {{ host.hostname | tojson }},
            "host_group": {{ host.host_group | tojson }}
        }
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        }
    },
    "agent": {
        "type": "zabbix-agent",
        "version": {{ host.agent_version | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}]
    }
}