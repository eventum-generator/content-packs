{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set scenario = samples.discovery_scenarios.pick() -%}
{%- set eid = next_event_id(shared) | int -%}
{%- set subnet = module.rand.choice(['10.1.0', '10.1.2', '10.1.3', '10.1.4', '10.1.10', '10.1.20']) -%}
{%- set discovered_ip = subnet ~ '.' ~ module.rand.number.integer(1, 254) | string -%}
{%- set is_up = scenario.status == 'up' -%}
{%- set dns_name = '' -%}
{%- if is_up -%}
  {%- set dns_name = module.rand.choice(['srv', 'host', 'node', 'vm', 'dev']) ~ '-' ~ module.rand.string.hex(4) ~ '.corp.acme.com' -%}
{%- endif -%}
{
    {{ event_base(["host", "network"], ["info"], "event", 0, "success", timestamp, params) }},
    "message": "{{ 'Host' if is_up else 'Service' }} {{ 'up' if is_up else 'down' }}: {{ discovered_ip }}{% if scenario.port %} (port {{ scenario.port }}){% endif %}",
    "zabbix": {
        "event": {
            "eventid": {{ eid }},
            "source": 1,
            "object": {{ 1 if is_up else 2 }},
            "objectid": {{ scenario.dcheckid | tojson }},
            "value": {{ 0 if is_up else 2 }},
            "name": "Discovery: {{ scenario.drule_name }}"
        },
        "discovery": {
            "druleid": {{ scenario.druleid | tojson }},
            "drule_name": {{ scenario.drule_name | tojson }},
            "dcheckid": {{ scenario.dcheckid | tojson }},
            "dcheck_type": {{ scenario.dcheck_type | tojson }},
            "dcheck_key": {{ scenario.dcheck_key | tojson }},
            "ip": {{ discovered_ip | tojson }},
            "dns": {{ dns_name | tojson }},
            "port": {{ scenario.port | tojson }},
            "status": {{ scenario.status | tojson }},
            "ip_range": {{ scenario.ip_range | tojson }}
        }
    },
    "host": {
        "ip": [{{ discovered_ip | tojson }}]
        {%- if dns_name %},
        "hostname": {{ dns_name | tojson }}
        {%- endif %}
    },
    "related": {
        "ip": [{{ discovered_ip | tojson }}]
    }
}