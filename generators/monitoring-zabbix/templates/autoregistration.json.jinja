{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set eid = next_event_id(shared) | int -%}
{%- set subnet = module.rand.choice(['10.1.10', '10.1.20', '10.1.30']) -%}
{%- set agent_ip = subnet ~ '.' ~ module.rand.number.integer(1, 254) | string -%}
{%- set host_prefix = module.rand.weighted_choice(['DESKTOP', 'LAPTOP', 'SRV', 'VM'], [35, 25, 20, 20]) -%}
{%- set host_suffix = module.rand.string.hex(4) | upper -%}
{%- set agent_hostname = host_prefix ~ '-' ~ host_suffix -%}
{%- set agent_os = module.rand.weighted_choice(['Linux', 'Windows'], [60, 40]) -%}
{%- set listen_port = module.rand.weighted_choice([10050, 10051], [90, 10]) -%}
{%- set host_metadata = 'OS:' ~ agent_os ~ ',Role:' ~ module.rand.choice(['web', 'app', 'db', 'cache', 'worker', 'monitoring']) -%}
{
    {{ event_base(["host"], ["creation"], "event", 0, "success", timestamp, params) }},
    "message": "Host auto-registered: {{ agent_hostname }} ({{ agent_ip }})",
    "zabbix": {
        "event": {
            "eventid": {{ eid }},
            "source": 2,
            "object": 3,
            "objectid": {{ eid }},
            "value": 1,
            "name": "Auto-registration: {{ agent_hostname }}"
        },
        "autoregistration": {
            "host": {{ agent_hostname | tojson }},
            "ip": {{ agent_ip | tojson }},
            "dns": {{ (agent_hostname | lower ~ '.corp.acme.com') | tojson }},
            "port": {{ listen_port }},
            "host_metadata": {{ host_metadata | tojson }},
            "tls_accepted": {{ module.rand.weighted_choice([1, 2, 4], [50, 30, 20]) }},
            "os": {{ agent_os | tojson }}
        }
    },
    "host": {
        "hostname": {{ agent_hostname | tojson }},
        "ip": [{{ agent_ip | tojson }}],
        "os": {
            "name": {{ agent_os | tojson }}
        }
    },
    "agent": {
        "type": "zabbix-agent",
        "version": {{ params.get('agent_version', '7.0.6') | tojson }}
    },
    "related": {
        "hosts": [{{ agent_hostname | tojson }}],
        "ip": [{{ agent_ip | tojson }}]
    }
}