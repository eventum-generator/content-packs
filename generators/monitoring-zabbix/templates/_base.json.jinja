{#- Shared macros for Zabbix monitoring events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import event_base, next_event_id, severity_name %} -#}

{#- Zabbix severity code to name mapping -#}
{%- macro severity_name(code) -%}
{%- if code == 0 -%}Not classified
{%- elif code == 1 -%}Information
{%- elif code == 2 -%}Warning
{%- elif code == 3 -%}Average
{%- elif code == 4 -%}High
{%- elif code == 5 -%}Disaster
{%- else -%}Unknown
{%- endif -%}
{%- endmacro -%}

{#- Map Zabbix severity to ECS numeric severity (1-10 scale) -#}
{%- macro ecs_severity(zabbix_sev) -%}
{%- if zabbix_sev == 0 -%}1
{%- elif zabbix_sev == 1 -%}2
{%- elif zabbix_sev == 2 -%}4
{%- elif zabbix_sev == 3 -%}6
{%- elif zabbix_sev == 4 -%}8
{%- elif zabbix_sev == 5 -%}10
{%- else -%}1
{%- endif -%}
{%- endmacro -%}

{#- Base event envelope with common ECS fields -#}
{%- macro event_base(category, type, kind, sev, outcome, ts, p) -%}
    "@timestamp": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "event": {
        "kind": {{ kind | tojson }},
        "module": "zabbix",
        "dataset": "zabbix.events",
        "category": {{ category | tojson }},
        "type": {{ type | tojson }},
        "severity": {{ ecs_severity(sev) }},
        "outcome": {{ outcome | tojson }},
        "timezone": "UTC",
        "created": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
    },
    "observer": {
        "vendor": "Zabbix",
        "product": "Zabbix Server",
        "version": {{ p.get('zabbix_version', '7.0.6') | tojson }},
        "hostname": {{ p.get('zabbix_server', 'zabbix-srv01') | tojson }},
        "ip": [{{ p.get('zabbix_server_ip', '10.1.0.5') | tojson }}]
    }
{%- endmacro -%}

{#- Monotonically increasing event ID via shared state -#}
{%- macro next_event_id(sh) -%}
{%- set eid = sh.get('event_id', 5000000) -%}
{%- do sh.set('event_id', eid + 1) -%}
{{ eid }}
{%- endmacro -%}
