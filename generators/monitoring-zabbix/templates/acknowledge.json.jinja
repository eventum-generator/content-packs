{%- from 'templates/_base.json.jinja' import event_base, next_event_id, severity_name -%}
{%- set host = samples.hosts.pick() -%}
{%- set trigger = samples.trigger_scenarios.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set eid = next_event_id(shared) | int -%}
{%- set problem_eventid = module.rand.number.integer(4900000, 5100000) -%}
{%- set desc = trigger.description | replace('{HOST.NAME}', host.hostname) | replace('{$SERVICE}', module.rand.choice(['nginx', 'mysql', 'redis'])) -%}
{%- set action = module.rand.weighted_choice(
  ['acknowledge', 'add_message', 'change_severity', 'close_problem', 'suppress', 'unsuppress'],
  [35, 30, 10, 15, 5, 5]
) -%}
{%- if action == 'acknowledge' -%}
  {%- set action_code = 2 -%}
  {%- set action_msg = 'Problem acknowledged' -%}
  {%- set comment = module.rand.choice([
    'Investigating the issue',
    'Working on it',
    'Acknowledged, monitoring',
    'Assigned to on-call engineer',
    'Escalated to L2 support'
  ]) -%}
{%- elif action == 'add_message' -%}
  {%- set action_code = 4 -%}
  {%- set action_msg = 'Message added' -%}
  {%- set comment = module.rand.choice([
    'Root cause identified: high load from batch job',
    'Temporary fix applied, monitoring for recurrence',
    'Waiting for vendor response',
    'Service restarted, observing recovery',
    'Maintenance window scheduled for permanent fix',
    'Checked logs, no anomalies found',
    'Issue correlates with recent deployment'
  ]) -%}
{%- elif action == 'change_severity' -%}
  {%- set action_code = 8 -%}
  {%- set action_msg = 'Severity changed' -%}
  {%- set comment = 'Severity adjusted based on impact assessment' -%}
{%- elif action == 'close_problem' -%}
  {%- set action_code = 1 -%}
  {%- set action_msg = 'Problem manually closed' -%}
  {%- set comment = module.rand.choice([
    'False positive, closing',
    'Issue resolved manually',
    'Duplicate of another problem',
    'Planned maintenance, closing'
  ]) -%}
{%- elif action == 'suppress' -%}
  {%- set action_code = 16 -%}
  {%- set action_msg = 'Problem suppressed' -%}
  {%- set comment = 'Suppressing during maintenance window' -%}
{%- else -%}
  {%- set action_code = 32 -%}
  {%- set action_msg = 'Problem unsuppressed' -%}
  {%- set comment = 'Maintenance complete, unsuppressing' -%}
{%- endif -%}
{
    {{ event_base(["process"], ["info"], "event", trigger.severity, "success", timestamp, params) }},
    "message": {{ (action_msg ~ ': ' ~ desc) | tojson }},
    "zabbix": {
        "event": {
            "eventid": {{ problem_eventid }},
            "source": 0,
            "object": 0,
            "objectid": {{ trigger.triggerid | tojson }},
            "value": 1,
            "acknowledged": true,
            "severity": {{ trigger.severity }},
            "severity_name": {{ severity_name(trigger.severity) | tojson }},
            "name": {{ desc | tojson }}
        },
        "acknowledge": {
            "action": {{ action_code }},
            "action_name": {{ action_msg | tojson }},
            "message": {{ comment | tojson }},
            "clock": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
            "user": {{ user.username | tojson }},
            "user_name": "{{ user.name }} {{ user.surname }}",
            "user_role": {{ user.role | tojson }}
        },
        "trigger": {
            "triggerid": {{ trigger.triggerid | tojson }},
            "description": {{ trigger.description | tojson }},
            "priority": {{ trigger.severity }},
            "priority_name": {{ trigger.priority_name | tojson }}
        },
        "host": {
            "hostid": {{ host.hostid | tojson }},
            "host": {{ host.hostname | tojson }},
            "host_group": {{ host.host_group | tojson }}
        }
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        }
    },
    "user": {
        "name": {{ user.username | tojson }},
        "full_name": "{{ user.name }} {{ user.surname }}",
        "roles": [{{ user.role | tojson }}],
        "group": {
            "name": {{ user.user_group | tojson }}
        }
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}