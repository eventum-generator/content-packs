{%- from 'templates/_base.json.jinja' import event_base, next_event_id, severity_name -%}
{#- Recover a problem from the shared pool if available -#}
{%- set problem_pool = shared.get('problem_pool', []) -%}
{%- if problem_pool | length > 0 -%}
  {%- set idx = module.rand.number.integer(0, problem_pool | length - 1) -%}
  {%- set problem = problem_pool[idx] -%}
  {%- do problem_pool.pop(idx) -%}
  {%- do shared.set('problem_pool', problem_pool) -%}
  {%- set host = problem.host -%}
  {%- set trigger = problem.trigger -%}
  {%- set problem_eventid = problem.eventid -%}
  {%- set duration_secs = module.rand.number.integer(30, 7200) -%}
{%- else -%}
  {#- Fallback: generate a standalone recovery -#}
  {%- set host = samples.hosts.pick() -%}
  {%- set trigger = samples.trigger_scenarios.pick() -%}
  {%- set problem_eventid = module.rand.number.integer(4900000, 4999999) -%}
  {%- set duration_secs = module.rand.number.integer(60, 3600) -%}
{%- endif -%}
{%- set eid = next_event_id(shared) | int -%}
{%- set desc = trigger.description | replace('{HOST.NAME}', host.hostname) | replace('{$SERVICE}', module.rand.choice(['nginx', 'mysql', 'redis', 'rabbitmq', 'ssh'])) -%}
{%- set duration_min = (duration_secs / 60) | int -%}
{%- set duration_str = (duration_min | string) ~ 'm ' ~ ((duration_secs % 60) | string) ~ 's' -%}
{
    {{ event_base(["host"], ["info"], "alert", trigger.severity, "success", timestamp, params) }},
    "message": "Resolved: {{ desc }}",
    "zabbix": {
        "event": {
            "eventid": {{ eid }},
            "source": 0,
            "object": 0,
            "objectid": {{ trigger.triggerid | tojson }},
            "value": 0,
            "acknowledged": true,
            "severity": {{ trigger.severity }},
            "severity_name": {{ severity_name(trigger.severity) | tojson }},
            "name": "Resolved: {{ desc }}",
            "opdata": {{ trigger.opdata | tojson }},
            "suppressed": false,
            "r_eventid": {{ eid }},
            "c_eventid": {{ problem_eventid }},
            "problem_duration": {{ duration_secs }}
        },
        "trigger": {
            "triggerid": {{ trigger.triggerid | tojson }},
            "description": {{ trigger.description | tojson }},
            "expression": {{ trigger.expression | tojson }},
            "priority": {{ trigger.severity }},
            "priority_name": {{ trigger.priority_name | tojson }},
            "status": "enabled",
            "value": 0,
            "tags": {{ trigger.tags | tojson }}
        },
        "host": {
            "hostid": {{ host.hostid | tojson }},
            "host": {{ host.hostname | tojson }},
            "host_group": {{ host.host_group | tojson }}
        },
        "item": {
            "name": {{ trigger.item_name | tojson }},
            "key_": {{ trigger.item_key | tojson }}
        }
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        }
    },
    "agent": {
        "type": "zabbix-agent",
        "version": {{ host.agent_version | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}]
    }
}