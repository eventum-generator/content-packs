{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, weighted_pick_from_list, status_block, sub_status_block -%}
{%- set subscription = samples.subscriptions | random -%}
{%- set rg = samples.resource_groups | random -%}
{%- set region = samples.regions | random -%}
{%- set correlation_id = module.rand.crypto.uuid4() -%}
{%- set event_data_id = module.rand.crypto.uuid4() -%}
{%- set alert_id = module.rand.crypto.uuid4() -%}
{#- Pick a security alert using weights -#}
{%- set alert_idx = weighted_pick_from_list(samples.security_alerts) | int -%}
{%- set alert = samples.security_alerts[alert_idx] -%}
{%- set res_id = "/subscriptions/" ~ subscription.subscription_id ~ "/providers/Microsoft.Security/locations/" ~ region.region_code ~ "/alerts/" ~ alert_id -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block(subscription, region) }},
    {{ ecs_block() }},
    "event": {
        "action": "Microsoft.Security/locations/alerts/activate/action",
        "category": ["threat"],
        "dataset": "azure.activitylogs",
        "kind": "alert",
        "module": "azure",
        "outcome": "success",
        "type": ["indicator"]
    },
    "related": {
        "user": []
    },
    "azure": {
        "activitylogs": {
            "category": "Security",
            "event_category": "Security",
            "level": "Informational",
            "operation_name": "Microsoft.Security/locations/alerts/activate/action",
            "result_type": "Active",
            "result_signature": "Active",
            "properties": {
                "Severity": "{{ alert.severity }}",
                "ActionTaken": "Detected"
            },
            {{ status_block("Active") }},
            {{ sub_status_block("") }},
            "correlation_id": "{{ correlation_id }}",
            "resource_id": {{ res_id | tojson }},
            "tenant_id": "{{ params.tenant_id }}",
            "subscription_id": "{{ subscription.subscription_id }}"
        }
    }
}
