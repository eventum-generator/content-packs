{%- from 'templates/_base.json.jinja' import agent_block, ecs_block, cloud_block, weighted_pick_from_list, status_block, sub_status_block -%}
{%- set subscription = samples.subscriptions | random -%}
{%- set region = samples.regions | random -%}
{%- set correlation_id = module.rand.crypto.uuid4() -%}
{%- set event_data_id = module.rand.crypto.uuid4() -%}
{#- Pick a service health event type using weights -#}
{%- set sh_idx = weighted_pick_from_list(samples.service_health) | int -%}
{%- set sh_event = samples.service_health[sh_idx] -%}
{#- Pick an affected service -#}
{%- set affected_service = (samples.affected_services | random).name -%}
{#- Determine operation name based on incident type -#}
{%- if sh_event.incident_type == "Incident" -%}
    {%- set op_name = "Microsoft.ServiceHealth/incident/action" -%}
    {%- set level = "Warning" -%}
    {%- set status_value = "Active" -%}
{%- elif sh_event.incident_type == "Maintenance" -%}
    {%- set op_name = "Microsoft.ServiceHealth/maintenance/action" -%}
    {%- set level = "Informational" -%}
    {%- set status_value = "Active" -%}
{%- elif sh_event.incident_type == "Security" -%}
    {%- set op_name = "Microsoft.ServiceHealth/security/action" -%}
    {%- set level = "Warning" -%}
    {%- set status_value = "Active" -%}
{%- elif sh_event.incident_type == "ActionRequired" -%}
    {%- set op_name = "Microsoft.ServiceHealth/actionrequired/action" -%}
    {%- set level = "Warning" -%}
    {%- set status_value = "Active" -%}
{%- else -%}
    {%- set op_name = "Microsoft.ServiceHealth/informational/action" -%}
    {%- set level = "Informational" -%}
    {%- set status_value = "Active" -%}
{%- endif -%}
{%- set tracking_id = module.rand.string.letters_uppercase(3) ~ module.rand.string.digits(1) ~ "-" ~ module.rand.string.letters_uppercase(3) -%}
{%- set title = sh_event.title_prefix ~ " - " ~ affected_service ~ " - " ~ region.region_name -%}
{%- set communication_id = module.rand.string.digits(18) -%}
{%- set res_id = "/subscriptions/" ~ subscription.subscription_id -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    {{ agent_block(params) }},
    {{ cloud_block(subscription, region) }},
    {{ ecs_block() }},
    "event": {
        "action": {{ op_name | tojson }},
        "category": ["configuration"],
        "dataset": "azure.activitylogs",
        "kind": "event",
        "module": "azure",
        "outcome": "success",
        "type": ["info"]
    },
    "related": {
        "user": []
    },
    "azure": {
        "activitylogs": {
            "category": "ServiceHealth",
            "event_category": "ServiceHealth",
            "level": "{{ level }}",
            "operation_name": {{ op_name | tojson }},
            "result_type": "{{ status_value }}",
            "result_signature": "{{ status_value }}",
            "properties": {
                "title": {{ title | tojson }},
                "service": "{{ affected_service }}",
                "region": "{{ region.region_name }}",
                "communication": {{ ("Starting at approximately " ~ timestamp.strftime('%H:%M') ~ " UTC on " ~ timestamp.strftime('%d %b %Y') ~ ", a subset of customers in " ~ region.region_name ~ " may experience degraded performance, connectivity drops or timeouts when accessing their Azure " ~ affected_service ~ " resources hosted in this region. Engineers are investigating. The next update will be provided in 60 minutes, or as events warrant.") | tojson }},
                "incidentType": "{{ sh_event.incident_type }}",
                "trackingId": "{{ tracking_id }}",
                "impactStartTime": "{{ timestamp.isoformat() }}",
                "impactedServices": {{ ('[{"ImpactedRegions":[{"RegionName":"' ~ region.region_name ~ '"}],"ServiceName":"' ~ affected_service ~ '"}]') | tojson }},
                "defaultLanguageTitle": {{ title | tojson }},
                "stage": "{{ status_value }}",
                "communicationId": "{{ communication_id }}",
                "version": "0.1.1"
            },
            {{ status_block(status_value) }},
            {{ sub_status_block("") }},
            "correlation_id": "{{ correlation_id }}",
            "resource_id": {{ res_id | tojson }},
            "tenant_id": "{{ params.tenant_id }}",
            "subscription_id": "{{ subscription.subscription_id }}"
        }
    }
}
