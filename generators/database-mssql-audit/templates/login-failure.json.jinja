{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set instance = hostname ~ '\\\\' ~ host.instance_name -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set txn_id = shared.get('txn_id:' ~ hostname, 100000) -%}
{%- set fail_user = module.rand.weighted_choice(["sa", "admin", "api_service", "test_user", "backup_svc", "root"], [15, 25, 20, 20, 10, 10]) -%}
{%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_public(), module.rand.network.ip_v4_private_c(), module.rand.network.ip_v4_private_b()], [40, 35, 25]) -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{%- set app_name = module.rand.weighted_choice([".Net SqlClient Data Provider", "Microsoft SQL Server Management Studio", "SQLCMD", "Python", "DBeaver"], [35, 25, 15, 15, 10]) -%}
{%- set client_host = module.rand.weighted_choice(["UNKNOWN", "APPSRV01", "DEVSTN01", "WEBSRV01"], [40, 25, 20, 15]) -%}
{%- set session_counter = shared.get('session_counter:' ~ hostname, 50) -%}
{%- do shared.set('session_counter:' ~ hostname, session_counter + 1) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "winlogbeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "event": {
        "action": "login-failed",
        "category": ["database", "authentication"],
        "code": "33205",
        "dataset": "microsoft_sqlserver.audit",
        "kind": "event",
        "module": "microsoft_sqlserver",
        "outcome": "failure",
        "sequence": {{ seq }},
        "type": ["connection", "start"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "windows",
            "name": "{{ host.os_name }}",
            "type": "windows",
            "version": "{{ host.os_version }}"
        }
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ host.ip }}"],
        "user": ["{{ fail_user }}"]
    },
    "service": {
        "type": "microsoft_sqlserver"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "sqlserver": {
        "audit": {
            "action_id": "LGIF",
            "additional_information": "<action_info xmlns=\"http://schemas.microsoft.com/sqlserver/2008/sqlaudit_data\"><error_number>18456</error_number><error_state>5</error_state><pooled_connection>0</pooled_connection></action_info>",
            "application_name": "{{ app_name }}",
            "class_type": "LX",
            "client_ip": "{{ src_ip }}",
            "database_name": "master",
            "database_principal_name": "",
            "host_name": "{{ client_host }}",
            "object_name": "",
            "schema_name": "",
            "sequence_number": {{ seq }},
            "server_instance_name": "{{ instance }}",
            "server_principal_name": "{{ fail_user }}",
            "session_id": {{ session_counter }},
            "statement": "{{ fail_user }}",
            "succeeded": 0,
            "transaction_id": {{ txn_id }}
        }
    },
    "user": {
        "domain": "",
        "name": "{{ fail_user }}"
    },
    "winlog": {
        "channel": "Security",
        "event_id": "33205",
        "provider_name": "MSSQLSERVER$AUDIT"
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}
{%- do shared.set('txn_id:' ~ hostname, txn_id + 1) -%}