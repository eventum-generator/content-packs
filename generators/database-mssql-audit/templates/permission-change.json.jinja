{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set instance = hostname ~ '\\\\' ~ host.instance_name -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set txn_id = shared.get('txn_id:' ~ hostname, 100000) -%}
{#- Permission changes are done by admins/DBAs -#}
{%- set login = module.rand.weighted_choice(
  samples.logins | selectattr('login_name', 'equalto', 'sa') | list
  + samples.logins | selectattr('login_name', 'equalto', 'admin.jsmith') | list
  + samples.logins | selectattr('login_name', 'equalto', 'admin.mchen') | list
  + samples.logins | selectattr('login_name', 'equalto', 'dba_ops') | list,
  None) -%}
{%- if login.login_type == 'windows' -%}
  {%- set server_principal = login.domain ~ '\\\\' ~ login.login_name -%}
  {%- set user_domain = login.domain -%}
  {%- set user_name = login.login_name -%}
{%- else -%}
  {%- set server_principal = login.login_name -%}
  {%- set user_domain = "" -%}
  {%- set user_name = login.login_name -%}
{%- endif -%}
{%- set session_id = module.rand.number.integer(50, 500) -%}
{%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_private_c(), "127.0.0.1"], [70, 30]) -%}
{%- set app_name = login.app_name -%}
{%- set client_host = module.rand.weighted_choice(["DBASTN01", hostname], [60, 40]) -%}
{#- Pick permission operation -#}
{%- set perm_op = module.rand.weighted_choice(["G", "D", "R"], [60, 25, 15]) -%}
{%- set perm_action_map = {"G": "database-permission-grant", "D": "database-permission-deny", "R": "database-permission-revoke"} -%}
{%- set perm_verb_map = {"G": "GRANT", "D": "DENY", "R": "REVOKE"} -%}
{%- set event_action = perm_action_map[perm_op] -%}
{%- set perm_verb = perm_verb_map[perm_op] -%}
{#- Pick permission type and target -#}
{%- set permission = module.rand.weighted_choice(["SELECT", "INSERT", "UPDATE", "DELETE", "EXECUTE", "VIEW DEFINITION", "ALTER"], [25, 15, 15, 10, 15, 10, 10]) -%}
{%- set grantee = module.rand.choice(["api_service", "web_api", "app_readonly", "svc_reporting", "etl_user", "public"]) -%}
{#- Pick target object type -#}
{%- set target_type = module.rand.weighted_choice(["TABLE", "PROCEDURE", "SCHEMA", "DATABASE"], [40, 25, 20, 15]) -%}
{%- set class_type_map = {"TABLE": "U", "PROCEDURE": "P", "SCHEMA": "SC", "DATABASE": "DB"} -%}
{%- set class_type = class_type_map[target_type] -%}
{%- set db_entry = samples.databases | reject('equalto', samples.databases | last) | list | random -%}
{%- set db_name = db_entry.name -%}
{%- set schema_entry = db_entry.schemas | random -%}
{%- set schema_name = schema_entry.name -%}
{%- if target_type == "TABLE" and schema_entry.tables | length > 0 -%}
  {%- set object_name = schema_entry.tables | random -%}
  {%- set on_clause = " ON [" ~ schema_name ~ "].[" ~ object_name ~ "]" -%}
{%- elif target_type == "PROCEDURE" and schema_entry.procs | length > 0 -%}
  {%- set object_name = schema_entry.procs | random -%}
  {%- set on_clause = " ON [" ~ schema_name ~ "].[" ~ object_name ~ "]" -%}
{%- elif target_type == "SCHEMA" -%}
  {%- set object_name = schema_name -%}
  {%- set on_clause = " ON SCHEMA::[" ~ schema_name ~ "]" -%}
{%- else -%}
  {%- set object_name = db_name -%}
  {%- set on_clause = " ON DATABASE::[" ~ db_name ~ "]" -%}
{%- endif -%}
{%- set stmt = perm_verb ~ " " ~ permission ~ on_clause ~ " TO [" ~ grantee ~ "]" -%}
{%- set succeeded = module.rand.weighted_choice([1, 0], [92, 8]) -%}
{%- set outcome = "success" if succeeded == 1 else "failure" -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "winlogbeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "event": {
        "action": "{{ event_action }}",
        "category": ["database", "iam"],
        "code": "33205",
        "dataset": "microsoft_sqlserver.audit",
        "kind": "event",
        "module": "microsoft_sqlserver",
        "outcome": "{{ outcome }}",
        "sequence": {{ seq }},
        "type": ["admin"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "windows",
            "name": "{{ host.os_name }}",
            "type": "windows",
            "version": "{{ host.os_version }}"
        }
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ host.ip }}"],
        "user": ["{{ user_name }}", "{{ grantee }}"]
    },
    "service": {
        "type": "microsoft_sqlserver"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ module.rand.number.integer(49152, 65535) }}
    },
    "sqlserver": {
        "audit": {
            "action_id": "{{ perm_op }}",
            "additional_information": "",
            "application_name": "{{ app_name }}",
            "class_type": "{{ class_type }}",
            "client_ip": "{{ src_ip }}",
            "database_name": "{{ db_name }}",
            "database_principal_name": "dbo",
            "host_name": "{{ client_host }}",
            "object_name": "{{ object_name }}",
            "schema_name": "{{ schema_name }}",
            "sequence_number": {{ seq }},
            "server_instance_name": "{{ instance }}",
            "server_principal_name": "{{ server_principal }}",
            "session_id": {{ session_id }},
            "statement": {{ stmt | tojson }},
            "succeeded": {{ succeeded }},
            "transaction_id": {{ txn_id }}
        }
    },
    "user": {
        "domain": "{{ user_domain }}",
        "name": "{{ user_name }}"
    },
    "winlog": {
        "channel": "Security",
        "event_id": "33205",
        "provider_name": "MSSQLSERVER$AUDIT"
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}
{%- do shared.set('txn_id:' ~ hostname, txn_id + 1) -%}