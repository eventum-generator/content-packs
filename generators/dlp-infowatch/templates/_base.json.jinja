{#- Shared macros for InfoWatch Traffic Monitor DLP events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import envelope, next_event_id %} -#}

{#- Base event envelope with common ECS + CEF fields -#}
{%- macro envelope(ts, p, event_class_id, event_name, severity_num) -%}
    "@timestamp": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": {{ p.get('agent_id', 'f1ee4a83-b99b-4611-925d-b83b001f8b86') | tojson }},
        "name": {{ p.get('hostname', 'iwtm-srv01') | tojson }},
        "type": "filebeat",
        "version": {{ p.get('agent_version', '8.17.0') | tojson }}
    },
    "cef": {
        "device": {
            "event_class_id": {{ event_class_id | tojson }},
            "product": "Traffic Monitor",
            "vendor": "InfoWatch",
            "version": {{ p.get('iwtm_version', '7.3.0') | tojson }}
        },
{%- endmacro -%}

{#- Close cef block and add common tail fields -#}
{%- macro envelope_tail(ts, p) -%}
    "data_stream": {
        "dataset": "cef.log",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "host": {
        "hostname": {{ p.get('hostname', 'iwtm-srv01') | tojson }},
        "name": {{ p.get('hostname', 'iwtm-srv01') | tojson }}
    },
    "observer": {
        "product": "Traffic Monitor",
        "type": "dlp",
        "vendor": "InfoWatch",
        "version": {{ p.get('iwtm_version', '7.3.0') | tojson }}
    },
    "tags": ["cef", "forwarded", "dlp"]
{%- endmacro -%}

{#- Monotonically increasing event ID via shared state -#}
{%- macro next_event_id(sh) -%}
{%- set eid = sh.get('_event_id', 1000000) -%}
{%- do sh.set('_event_id', eid + 1) -%}
{{ eid }}
{%- endmacro -%}
