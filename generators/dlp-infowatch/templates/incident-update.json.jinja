{%- from 'templates/_base.json.jinja' import envelope, envelope_tail, next_event_id -%}
{%- set user = samples.users.pick() -%}
{%- set policy = samples.policies.weighted_pick('weight') -%}
{%- set channel = samples.channels.weighted_pick('weight') -%}
{%- set analysts = ['security_admin', 'dlp_officer', 'ib_analyst', 'chief_iso'] -%}
{%- set analyst = module.rand.choice(analysts) -%}
{%- set statuses = {'violation': 40, 'no_violation': 25, 'requires_processing': 20, 'escalated': 15} -%}
{%- set status = module.rand.weighted_choice(statuses) -%}
{%- set incident_id = 'INC-' ~ module.rand.number.integer(100000, 999999) | string -%}
{%- if status == 'violation' -%}
  {%- set severity_num = 7 -%}
{%- elif status == 'escalated' -%}
  {%- set severity_num = 8 -%}
{%- elif status == 'requires_processing' -%}
  {%- set severity_num = 4 -%}
{%- else -%}
  {%- set severity_num = 2 -%}
{%- endif -%}
{%- set incident_msg = 'Incident ' ~ incident_id ~ ' status updated to ' ~ status ~ ' by ' ~ analyst -%}
{
    {{ envelope(timestamp, params, '500', 'Incident Update', severity_num) }}
        "extensions": {
            "deviceAction": "update",
            "deviceCustomString1": {{ incident_id | tojson }},
            "deviceCustomString1Label": "IncidentID",
            "deviceCustomString2": {{ status | tojson }},
            "deviceCustomString2Label": "IncidentStatus",
            "deviceCustomString3": {{ policy.name | tojson }},
            "deviceCustomString3Label": "RelatedPolicy",
            "deviceCustomString4": {{ analyst | tojson }},
            "deviceCustomString4Label": "Analyst",
            "sourceUserName": {{ user.username | tojson }},
            "sourceAddress": {{ user.ip | tojson }},
            "transportProtocol": {{ channel.protocol | upper | tojson }},
            "message": {{ incident_msg | tojson }}
        },
        "name": "Incident Update",
        "severity": {{ severity_num | tojson | replace('"', '') }},
        "version": "0"
    },
    {{ envelope_tail(timestamp, params) }},
    "event": {
        "action": "update",
        "category": ["intrusion_detection"],
        "code": "500",
        "dataset": "cef.log",
        "id": "{{ next_event_id(shared) | trim }}",
        "kind": "event",
        "module": "cef",
        "outcome": "success",
        "severity": {{ severity_num }},
        "type": ["info"]
    },
    "message": {{ incident_msg | tojson }},
    "rule": {
        "name": {{ policy.name | tojson }},
        "category": "data-loss-prevention"
    },
    "source": {
        "address": {{ user.ip | tojson }},
        "ip": {{ user.ip | tojson }},
        "user": {
            "domain": {{ user.domain | tojson }},
            "email": {{ user.email | tojson }},
            "full_name": {{ user.full_name | tojson }},
            "name": {{ user.username | tojson }}
        }
    },
    "related": {
        "ip": [{{ user.ip | tojson }}],
        "user": [{{ user.username | tojson }}, {{ analyst | tojson }}],
        "hosts": [{{ params.get('hostname', 'iwtm-srv01') | tojson }}, {{ user.workstation | tojson }}]
    }
}