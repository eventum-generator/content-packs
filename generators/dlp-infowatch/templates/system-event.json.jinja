{%- from 'templates/_base.json.jinja' import envelope, envelope_tail, next_event_id -%}
{%- set system_events = [
    {'name': 'Database maintenance completed', 'class_id': '400', 'severity': 1, 'component': 'Database', 'weight': 15},
    {'name': 'Content analysis engine reloaded', 'class_id': '401', 'severity': 1, 'component': 'ContentAnalysis', 'weight': 10},
    {'name': 'Policy configuration updated', 'class_id': '402', 'severity': 3, 'component': 'PolicyEngine', 'weight': 12},
    {'name': 'Agent connection established', 'class_id': '410', 'severity': 0, 'component': 'AgentManager', 'weight': 25},
    {'name': 'Agent connection lost', 'class_id': '411', 'severity': 5, 'component': 'AgentManager', 'weight': 8},
    {'name': 'License check passed', 'class_id': '420', 'severity': 0, 'component': 'LicenseManager', 'weight': 10},
    {'name': 'OCR engine initialized', 'class_id': '403', 'severity': 0, 'component': 'OCREngine', 'weight': 5},
    {'name': 'Fingerprint database updated', 'class_id': '404', 'severity': 1, 'component': 'Fingerprinting', 'weight': 8},
    {'name': 'SIEM export batch sent', 'class_id': '430', 'severity': 0, 'component': 'SIEMConnector', 'weight': 15},
    {'name': 'Backup completed successfully', 'class_id': '440', 'severity': 1, 'component': 'BackupService', 'weight': 7}
] -%}
{%- set weights = system_events | map(attribute='weight') | list -%}
{%- set items = system_events -%}
{%- set evt = module.rand.weighted_choice(items, weights) -%}
{%- set user = samples.users.pick() -%}
{
    {{ envelope(timestamp, params, evt.class_id, evt.name, evt.severity) }}
        "extensions": {
            "deviceAction": "log",
            "deviceCustomString1": {{ evt.component | tojson }},
            "deviceCustomString1Label": "Component",
            "sourceAddress": {{ params.get('server_ip', '10.1.0.10') | tojson }},
            "message": {{ evt.name | tojson }}
        },
        "name": {{ evt.name | tojson }},
        "severity": {{ evt.severity | tojson | replace('"', '') }},
        "version": "0"
    },
    {{ envelope_tail(timestamp, params) }},
    "event": {
        "action": "log",
        "category": ["configuration"],
        "code": {{ evt.class_id | tojson }},
        "dataset": "cef.log",
        "id": "{{ next_event_id(shared) | trim }}",
        "kind": "event",
        "module": "cef",
        "outcome": "success",
        "severity": {{ evt.severity }},
        "type": ["info"]
    },
    "message": {{ evt.name | tojson }},
    "source": {
        "address": {{ params.get('server_ip', '10.1.0.10') | tojson }},
        "ip": {{ params.get('server_ip', '10.1.0.10') | tojson }}
    },
    "related": {
        "ip": [{{ params.get('server_ip', '10.1.0.10') | tojson }}],
        "hosts": [{{ params.get('hostname', 'iwtm-srv01') | tojson }}]
    }
}