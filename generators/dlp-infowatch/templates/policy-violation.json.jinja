{%- from 'templates/_base.json.jinja' import envelope, envelope_tail, next_event_id -%}
{%- set user = samples.users.pick() -%}
{%- set policy = samples.policies.weighted_pick('weight') -%}
{%- set channel = samples.channels.weighted_pick('weight') -%}
{%- set file_obj = samples.files.weighted_pick('weight') -%}
{%- set recipient = samples.external_recipients.weighted_pick('weight') -%}
{%- set file_path = 'C:\\Users\\' ~ user.username ~ '\\' ~ file_obj.dir ~ '\\' ~ file_obj.name -%}
{%- set file_size = module.rand.number.lognormal(10, 1.5) | int -%}
{%- set sha256 = module.rand.crypto.sha256() -%}
{%- set action_roll = module.rand.number.floating(0, 1) -%}
{%- if policy.severity == 'critical' -%}
  {%- set action = 'block' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 9 -%}
  {%- set event_type = ["denied"] -%}
{%- elif policy.severity == 'high' and action_roll < 0.7 -%}
  {%- set action = 'block' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 7 -%}
  {%- set event_type = ["denied"] -%}
{%- elif policy.severity == 'high' -%}
  {%- set action = 'alert' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 7 -%}
  {%- set event_type = ["info"] -%}
{%- elif policy.severity == 'medium' -%}
  {%- set action = 'alert' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 5 -%}
  {%- set event_type = ["info"] -%}
{%- else -%}
  {%- set action = 'log' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 3 -%}
  {%- set event_type = ["info"] -%}
{%- endif -%}
{%- set violation_msg = 'Policy violation: ' ~ policy.name ~ ' triggered on ' ~ channel.description ~ ' channel' -%}
{
    {{ envelope(timestamp, params, channel.event_class_id, 'Policy Violation', severity_num) }}
        "extensions": {
            "categoryOutcome": {{ ('Blocked' if action == 'block' else 'Allowed') | tojson }},
            "deviceAction": {{ action | tojson }},
            "deviceCustomString1": {{ policy.category | tojson }},
            "deviceCustomString1Label": "DataCategory",
            "deviceCustomString2": {{ policy.name | tojson }},
            "deviceCustomString2Label": "PolicyName",
            "deviceCustomString3": {{ policy.severity | tojson }},
            "deviceCustomString3Label": "ViolationLevel",
            "deviceCustomString4": "pending",
            "deviceCustomString4Label": "IncidentStatus",
            "deviceCustomNumber1": {{ file_size }},
            "deviceCustomNumber1Label": "FileSize",
            "sourceUserName": {{ user.username | tojson }},
            "destinationUserName": {{ recipient.email | tojson }},
            "sourceAddress": {{ user.ip | tojson }},
            "destinationAddress": {{ recipient.ip | tojson }},
            "transportProtocol": {{ channel.protocol | upper | tojson }},
            "fileName": {{ file_obj.name | tojson }},
            "filePath": {{ file_path | tojson }},
            "fileHash": {{ sha256 | tojson }},
            "message": {{ violation_msg | tojson }}
        },
        "name": "Policy Violation",
        "severity": {{ severity_num | tojson | replace('"', '') }},
        "version": "0"
    },
    {{ envelope_tail(timestamp, params) }},
    "destination": {
        "address": {{ recipient.ip | tojson }},
        "ip": {{ recipient.ip | tojson }},
        "user": {
            "email": {{ recipient.email | tojson }},
            "name": {{ recipient.email | tojson }}
        }
    },
    "event": {
        "action": {{ action | tojson }},
        "category": ["intrusion_detection"],
        "code": {{ channel.event_class_id | tojson }},
        "dataset": "cef.log",
        "id": "{{ next_event_id(shared) | trim }}",
        "kind": "alert",
        "module": "cef",
        "outcome": {{ outcome | tojson }},
        "severity": {{ severity_num }},
        "type": {{ event_type | tojson }}
    },
    "file": {
        "hash": {
            "sha256": {{ sha256 | tojson }}
        },
        "name": {{ file_obj.name | tojson }},
        "path": {{ file_path | tojson }},
        "size": {{ file_size }}
    },
    "message": {{ violation_msg | tojson }},
    "network": {
        "protocol": {{ channel.protocol | tojson }}
    },
    "rule": {
        "id": {{ policy.id | tojson }},
        "name": {{ policy.name | tojson }},
        "category": "data-loss-prevention"
    },
    "source": {
        "address": {{ user.ip | tojson }},
        "ip": {{ user.ip | tojson }},
        "user": {
            "domain": {{ user.domain | tojson }},
            "email": {{ user.email | tojson }},
            "full_name": {{ user.full_name | tojson }},
            "name": {{ user.username | tojson }}
        }
    },
    "related": {
        "ip": [{{ user.ip | tojson }}, {{ recipient.ip | tojson }}],
        "user": [{{ user.username | tojson }}, {{ recipient.email | tojson }}],
        "hash": [{{ sha256 | tojson }}],
        "hosts": [{{ params.get('hostname', 'iwtm-srv01') | tojson }}, {{ user.workstation | tojson }}]
    }
}