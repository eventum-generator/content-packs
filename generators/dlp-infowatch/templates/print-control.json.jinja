{%- from 'templates/_base.json.jinja' import envelope, envelope_tail, next_event_id -%}
{%- set user = samples.users.pick() -%}
{%- set file_obj = samples.files.weighted_pick('weight') -%}
{%- set file_path = 'C:\\Users\\' ~ user.username ~ '\\' ~ file_obj.dir ~ '\\' ~ file_obj.name -%}
{%- set pages = module.rand.number.integer(1, 50) -%}
{%- set printers = ['HP LaserJet Pro M404', 'Canon imageRUNNER C3226', 'Xerox VersaLink C405', 'Kyocera ECOSYS M5526', 'Ricoh MP C3004', 'Brother MFC-L8900CDW'] -%}
{%- set printer = module.rand.choice(printers) -%}
{%- set printer_locations = ['Floor 1 - Reception', 'Floor 2 - Open Space', 'Floor 3 - Management', 'Floor 2 - IT Room', 'Floor 1 - HR', 'Floor 3 - Conference'] -%}
{%- set printer_location = module.rand.choice(printer_locations) -%}
{%- set action_roll = module.rand.number.floating(0, 1) -%}
{%- if action_roll < 0.1 -%}
  {%- set action = 'block' -%}
  {%- set severity_num = 5 -%}
  {%- set event_type = ["denied"] -%}
  {%- set category_outcome = 'Blocked' -%}
{%- else -%}
  {%- set action = 'log' -%}
  {%- set severity_num = 1 -%}
  {%- set event_type = ["info"] -%}
  {%- set category_outcome = 'Allowed' -%}
{%- endif -%}
{%- set print_msg = 'Print job: ' ~ file_obj.name ~ ' (' ~ pages ~ ' pages) on ' ~ printer -%}
{
    {{ envelope(timestamp, params, '210', 'Print Control', severity_num) }}
        "extensions": {
            "categoryOutcome": {{ category_outcome | tojson }},
            "deviceAction": {{ action | tojson }},
            "deviceCustomString1": {{ printer | tojson }},
            "deviceCustomString1Label": "PrinterName",
            "deviceCustomString2": {{ printer_location | tojson }},
            "deviceCustomString2Label": "PrinterLocation",
            "deviceCustomNumber1": {{ pages }},
            "deviceCustomNumber1Label": "PageCount",
            "sourceUserName": {{ user.username | tojson }},
            "sourceAddress": {{ user.ip | tojson }},
            "fileName": {{ file_obj.name | tojson }},
            "filePath": {{ file_path | tojson }},
            "message": {{ print_msg | tojson }}
        },
        "name": "Print Control",
        "severity": {{ severity_num | tojson | replace('"', '') }},
        "version": "0"
    },
    {{ envelope_tail(timestamp, params) }},
    "event": {
        "action": {{ action | tojson }},
        "category": ["host"],
        "code": "210",
        "dataset": "cef.log",
        "id": "{{ next_event_id(shared) | trim }}",
        "kind": "event",
        "module": "cef",
        "outcome": "success",
        "severity": {{ severity_num }},
        "type": {{ event_type | tojson }}
    },
    "file": {
        "name": {{ file_obj.name | tojson }},
        "path": {{ file_path | tojson }}
    },
    "message": {{ print_msg | tojson }},
    "source": {
        "address": {{ user.ip | tojson }},
        "ip": {{ user.ip | tojson }},
        "user": {
            "domain": {{ user.domain | tojson }},
            "email": {{ user.email | tojson }},
            "full_name": {{ user.full_name | tojson }},
            "name": {{ user.username | tojson }}
        }
    },
    "related": {
        "ip": [{{ user.ip | tojson }}],
        "user": [{{ user.username | tojson }}],
        "hosts": [{{ params.get('hostname', 'iwtm-srv01') | tojson }}, {{ user.workstation | tojson }}]
    }
}