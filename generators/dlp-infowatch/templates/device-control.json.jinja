{%- from 'templates/_base.json.jinja' import envelope, envelope_tail, next_event_id -%}
{%- set user = samples.users.pick() -%}
{%- set device_types = ['USB Flash Drive', 'External HDD', 'USB Card Reader', 'MTP Device', 'CD/DVD Writer', 'Bluetooth Adapter', 'Wi-Fi Adapter', '3G/4G Modem'] -%}
{%- set device_weights = [35, 20, 10, 15, 5, 5, 5, 5] -%}
{%- set device_type = module.rand.weighted_choice(device_types, device_weights) -%}
{%- set device_vendors = ['Kingston', 'SanDisk', 'Samsung', 'Seagate', 'WD', 'Transcend', 'Toshiba', 'ADATA'] -%}
{%- set device_vendor = module.rand.choice(device_vendors) -%}
{%- set serial = module.rand.string.hex(16) | upper -%}
{%- set action_roll = module.rand.number.floating(0, 1) -%}
{%- if action_roll < 0.3 -%}
  {%- set action = 'block' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 6 -%}
  {%- set event_type = ["denied"] -%}
  {%- set category_outcome = 'Blocked' -%}
{%- elif action_roll < 0.6 -%}
  {%- set action = 'alert' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 4 -%}
  {%- set event_type = ["info"] -%}
  {%- set category_outcome = 'Allowed' -%}
{%- else -%}
  {%- set action = 'log' -%}
  {%- set outcome = 'success' -%}
  {%- set severity_num = 1 -%}
  {%- set event_type = ["info"] -%}
  {%- set category_outcome = 'Allowed' -%}
{%- endif -%}
{%- set device_msg = 'Device control: ' ~ device_type ~ ' (' ~ device_vendor ~ ') ' ~ ('blocked' if action == 'block' else 'detected') ~ ' on ' ~ user.workstation -%}
{
    {{ envelope(timestamp, params, '200', 'Device Control', severity_num) }}
        "extensions": {
            "categoryOutcome": {{ category_outcome | tojson }},
            "deviceAction": {{ action | tojson }},
            "deviceCustomString1": {{ device_type | tojson }},
            "deviceCustomString1Label": "DeviceType",
            "deviceCustomString2": {{ device_vendor | tojson }},
            "deviceCustomString2Label": "DeviceVendor",
            "deviceCustomString3": {{ serial | tojson }},
            "deviceCustomString3Label": "DeviceSerial",
            "deviceCustomString4": {{ ('blocked' if action == 'block' else 'allowed') | tojson }},
            "deviceCustomString4Label": "DeviceStatus",
            "sourceUserName": {{ user.username | tojson }},
            "sourceAddress": {{ user.ip | tojson }},
            "message": {{ device_msg | tojson }}
        },
        "name": "Device Control",
        "severity": {{ severity_num | tojson | replace('"', '') }},
        "version": "0"
    },
    {{ envelope_tail(timestamp, params) }},
    "event": {
        "action": {{ action | tojson }},
        "category": ["host"],
        "code": "200",
        "dataset": "cef.log",
        "id": "{{ next_event_id(shared) | trim }}",
        "kind": "event",
        "module": "cef",
        "outcome": {{ outcome | tojson }},
        "severity": {{ severity_num }},
        "type": {{ event_type | tojson }}
    },
    "message": {{ device_msg | tojson }},
    "source": {
        "address": {{ user.ip | tojson }},
        "ip": {{ user.ip | tojson }},
        "user": {
            "domain": {{ user.domain | tojson }},
            "email": {{ user.email | tojson }},
            "full_name": {{ user.full_name | tojson }},
            "name": {{ user.username | tojson }}
        }
    },
    "related": {
        "ip": [{{ user.ip | tojson }}],
        "user": [{{ user.username | tojson }}],
        "hosts": [{{ params.get('hostname', 'iwtm-srv01') | tojson }}, {{ user.workstation | tojson }}]
    }
}