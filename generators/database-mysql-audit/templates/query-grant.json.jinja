{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set event_id = shared.get('event_id:' ~ hostname, 1000) -%}
{%- set admin_user = module.rand.weighted_choice(["root", "admin_jsmith", "admin_mchen"], [40, 35, 25]) -%}
{%- set client_ip = module.rand.weighted_choice(["127.0.0.1", module.rand.network.ip_v4_private_c()], [40, 60]) -%}
{%- set conn_id = module.rand.number.integer(50, 5000) -%}
{%- set client_host = module.rand.weighted_choice(["dev-workstation", hostname, "admin-pc"], [40, 30, 30]) -%}
{%- set target_user = (samples.users | random).username -%}
{%- set db_entry = samples.databases | rejectattr('tables', 'equalto', []) | list | random -%}
{%- set grant_op = module.rand.weighted_choice(["GRANT", "REVOKE"], [75, 25]) -%}
{%- set privilege = module.rand.weighted_choice(["SELECT", "INSERT, UPDATE", "ALL PRIVILEGES", "SELECT, INSERT, UPDATE, DELETE", "EXECUTE", "CREATE, ALTER, DROP"], [30, 20, 10, 20, 10, 10]) -%}
{%- if grant_op == "GRANT" -%}
  {%- set stmt = grant_op ~ " " ~ privilege ~ " ON `" ~ db_entry.name ~ "`.* TO '" ~ target_user ~ "'@'%'" -%}
{%- else -%}
  {%- set stmt = grant_op ~ " " ~ privilege ~ " ON `" ~ db_entry.name ~ "`.* FROM '" ~ target_user ~ "'@'%'" -%}
{%- endif -%}
{%- set sql_cmd = grant_op | lower -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.get('agent_version', '8.17.0') }}"
    },
    "client": {
        "domain": "{{ client_host }}",
        "ip": "{{ client_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "data_stream": {
        "dataset": "mysql_enterprise.audit",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "mysql-query",
        "category": ["database", "iam"],
        "dataset": "mysql_enterprise.audit",
        "kind": "event",
        "module": "mysql_enterprise",
        "outcome": "success",
        "timezone": "+00:00",
        "type": ["admin"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "full": "x86_64-Linux",
            "name": "{{ host.os_name }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "mysqlenterprise": {
        "audit": {
            "account": {
                "host": "{{ client_host }}",
                "user": "{{ admin_user }}"
            },
            "class": "general",
            "connection_id": "{{ conn_id }}",
            "general_data": {
                "command": "Query",
                "query": {{ stmt | tojson }},
                "sql_command": "{{ sql_cmd }}",
                "status": 0
            },
            "id": "{{ event_id }}",
            "login": {
                "ip": "{{ client_ip }}",
                "os": "",
                "proxy": "",
                "user": "{{ admin_user }}"
            }
        }
    },
    "related": {
        "ip": ["{{ client_ip }}", "{{ host.ip }}"],
        "user": ["{{ admin_user }}", "{{ target_user }}"]
    },
    "server": {
        "user": {
            "name": "{{ admin_user }}"
        }
    },
    "service": {
        "id": "{{ host.server_id }}",
        "type": "mysql_enterprise",
        "version": "{{ host.mysql_version }}"
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "tags": ["mysql_enterprise-audit"],
    "user": {
        "name": "{{ admin_user }}"
    }
}
{%- do shared.set('event_id:' ~ hostname, event_id + 1) -%}