{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set event_id = shared.get('event_id:' ~ hostname, 1000) -%}
{#- Try to correlate with an existing session -#}
{%- set sessions = shared.get('sessions:' ~ hostname, []) -%}
{%- if sessions | length > 0 -%}
  {%- set sess = sessions.pop(0) -%}
  {%- do shared.set('sessions:' ~ hostname, sessions) -%}
  {%- set username = sess.user -%}
  {%- set client_ip = sess.client_ip -%}
  {%- set conn_id = sess.conn_id -%}
  {%- set conn_type = sess.conn_type -%}
  {%- set client_host = sess.client_host -%}
{%- else -%}
  {%- set user = samples.users.weighted_pick('weight') -%}
  {%- set username = user.username -%}
  {%- set client_ip = module.rand.weighted_choice([module.rand.network.ip_v4_private_c(), "127.0.0.1"], [80, 20]) -%}
  {%- set conn_id = module.rand.number.integer(50, 5000) -%}
  {%- set conn_type = module.rand.weighted_choice(["ssl", "tcp/ip", "socket"], [50, 35, 15]) -%}
  {%- set client_host = module.rand.choice(["app-server-01", "web-01", hostname]) -%}
{%- endif -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.get('agent_version', '8.17.0') }}"
    },
    "client": {
        "domain": "{{ client_host }}",
        "ip": "{{ client_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "data_stream": {
        "dataset": "mysql_enterprise.audit",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "mysql-disconnect",
        "category": ["database", "authentication"],
        "dataset": "mysql_enterprise.audit",
        "kind": "event",
        "module": "mysql_enterprise",
        "outcome": "success",
        "timezone": "+00:00",
        "type": ["connection", "end"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "full": "x86_64-Linux",
            "name": "{{ host.os_name }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "mysqlenterprise": {
        "audit": {
            "account": {
                "host": "{{ client_host }}",
                "user": "{{ username }}"
            },
            "class": "connection",
            "connection_data": {
                "connection_type": "{{ conn_type }}"
            },
            "connection_id": "{{ conn_id }}",
            "id": "{{ event_id }}",
            "login": {
                "ip": "{{ client_ip }}",
                "os": "",
                "proxy": "",
                "user": "{{ username }}"
            }
        }
    },
    "related": {
        "ip": ["{{ client_ip }}", "{{ host.ip }}"],
        "user": ["{{ username }}"]
    },
    "server": {
        "user": {
            "name": "{{ username }}"
        }
    },
    "service": {
        "id": "{{ host.server_id }}",
        "type": "mysql_enterprise",
        "version": "{{ host.mysql_version }}"
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "tags": ["mysql_enterprise-audit"],
    "user": {
        "name": "{{ username }}"
    }
}
{%- do shared.set('event_id:' ~ hostname, event_id + 1) -%}