{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set event_id = shared.get('event_id:' ~ hostname, 1000) -%}
{%- set admin_user = module.rand.weighted_choice(["root", "admin_jsmith", "admin_mchen", "svc_monitor"], [25, 25, 20, 30]) -%}
{%- set client_ip = module.rand.weighted_choice(["127.0.0.1", module.rand.network.ip_v4_private_c()], [50, 50]) -%}
{%- set conn_id = module.rand.number.integer(50, 5000) -%}
{%- set client_host = module.rand.weighted_choice([hostname, "admin-pc", "monitoring-srv"], [30, 35, 35]) -%}
{#- Pick an admin command -#}
{%- set admin_cmd = module.rand.weighted_choice([
  {"stmt": "SHOW VARIABLES", "sql_cmd": "show_variables"},
  {"stmt": "SHOW STATUS", "sql_cmd": "show_status"},
  {"stmt": "SHOW PROCESSLIST", "sql_cmd": "show_processlist"},
  {"stmt": "SHOW DATABASES", "sql_cmd": "show_databases"},
  {"stmt": "SHOW TABLE STATUS", "sql_cmd": "show_table_status"},
  {"stmt": "SHOW GRANTS FOR CURRENT_USER()", "sql_cmd": "show_grants"},
  {"stmt": "FLUSH PRIVILEGES", "sql_cmd": "flush"},
  {"stmt": "SET GLOBAL slow_query_log = 'ON'", "sql_cmd": "set_option"},
  {"stmt": "SHOW ENGINE INNODB STATUS", "sql_cmd": "show_engine_status"},
  {"stmt": "OPTIMIZE TABLE `ecommerce`.`orders`", "sql_cmd": "optimize_table"},
  {"stmt": "ANALYZE TABLE `ecommerce`.`customers`", "sql_cmd": "analyze_table"},
  {"stmt": "SHOW SLAVE STATUS", "sql_cmd": "show_slave_status"}
], None) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.get('agent_version', '8.17.0') }}"
    },
    "client": {
        "domain": "{{ client_host }}",
        "ip": "{{ client_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "data_stream": {
        "dataset": "mysql_enterprise.audit",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "mysql-query",
        "category": ["database"],
        "dataset": "mysql_enterprise.audit",
        "kind": "event",
        "module": "mysql_enterprise",
        "outcome": "success",
        "timezone": "+00:00",
        "type": ["info"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "full": "x86_64-Linux",
            "name": "{{ host.os_name }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "mysqlenterprise": {
        "audit": {
            "account": {
                "host": "{{ client_host }}",
                "user": "{{ admin_user }}"
            },
            "class": "general",
            "connection_id": "{{ conn_id }}",
            "general_data": {
                "command": "Query",
                "query": {{ admin_cmd.stmt | tojson }},
                "sql_command": "{{ admin_cmd.sql_cmd }}",
                "status": 0
            },
            "id": "{{ event_id }}",
            "login": {
                "ip": "{{ client_ip }}",
                "os": "",
                "proxy": "",
                "user": "{{ admin_user }}"
            }
        }
    },
    "related": {
        "ip": ["{{ client_ip }}", "{{ host.ip }}"],
        "user": ["{{ admin_user }}"]
    },
    "server": {
        "user": {
            "name": "{{ admin_user }}"
        }
    },
    "service": {
        "id": "{{ host.server_id }}",
        "type": "mysql_enterprise",
        "version": "{{ host.mysql_version }}"
    },
    "source": {
        "address": "{{ client_ip }}",
        "ip": "{{ client_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "tags": ["mysql_enterprise-audit"],
    "user": {
        "name": "{{ admin_user }}"
    }
}
{%- do shared.set('event_id:' ~ hostname, event_id + 1) -%}