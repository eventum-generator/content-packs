{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set event_id = shared.get('event_id:' ~ hostname, 1000) -%}
{%- set conn_counter = shared.get('conn_counter:' ~ hostname, 100) -%}
{%- do shared.set('conn_counter:' ~ hostname, conn_counter + 1) -%}
{#- Failed logins come from suspicious or misconfigured accounts -#}
{%- set fail_user = module.rand.weighted_choice(["root", "admin", "test", "mysql", "app_service", "backup", "deploy", ""], [20, 20, 15, 10, 15, 8, 7, 5]) -%}
{%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_public(), module.rand.network.ip_v4_private_c(), "127.0.0.1"], [40, 45, 15]) -%}
{%- set conn_type = module.rand.weighted_choice(["ssl", "tcp/ip", "socket"], [30, 55, 15]) -%}
{%- set error_code = module.rand.weighted_choice([1045, 1044, 1049, 1698], [60, 15, 15, 10]) -%}
{%- set client_host = module.rand.weighted_choice(["unknown", "app-server-01", "dev-workstation", "scanner-01", hostname], [35, 20, 20, 15, 10]) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.get('agent_version', '8.17.0') }}"
    },
    "client": {
        "domain": "{{ client_host }}",
        "ip": "{{ src_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "data_stream": {
        "dataset": "mysql_enterprise.audit",
        "namespace": "default",
        "type": "logs"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "mysql-connect",
        "category": ["database", "authentication"],
        "dataset": "mysql_enterprise.audit",
        "kind": "event",
        "module": "mysql_enterprise",
        "outcome": "failure",
        "timezone": "+00:00",
        "type": ["connection", "start"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "full": "x86_64-Linux",
            "name": "{{ host.os_name }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "mysqlenterprise": {
        "audit": {
            "account": {
                "host": "{{ client_host }}",
                "user": "{{ fail_user }}"
            },
            "class": "connection",
            "connection_data": {
                "connection_type": "{{ conn_type }}",
                "db": "",
                "status": {{ error_code }}
            },
            "connection_id": "{{ conn_counter }}",
            "id": "{{ event_id }}",
            "login": {
                "ip": "{{ src_ip }}",
                "os": "",
                "proxy": "",
                "user": "{{ fail_user }}"
            }
        }
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ host.ip }}"],
        "user": ["{{ fail_user }}"]
    },
    "server": {
        "user": {
            "name": "{{ fail_user }}"
        }
    },
    "service": {
        "id": "{{ host.server_id }}",
        "type": "mysql_enterprise",
        "version": "{{ host.mysql_version }}"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ module.rand.number.integer(32768, 65535) }}
    },
    "tags": ["mysql_enterprise-audit"],
    "user": {
        "name": "{{ fail_user }}"
    }
}
{%- do shared.set('event_id:' ~ hostname, event_id + 1) -%}