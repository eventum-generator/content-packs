{%- set seq_num = shared.get('sequence_number', 100000) -%}
{%- set hostname = params.hostname -%}
{#- Pick machine, platform, user -#}
{%- set machine = samples.machines | random -%}
{%- set platform = samples.client_platforms[machine.os_index] -%}
{%- set user = samples.usernames | random -%}
{%- set gw = samples.gateways | random -%}
{#- Source IPs -#}
{%- set private_ip = module.rand.network.ip_v4_private_c() -%}
{%- set public_ip = module.rand.network.ip_v4_public() -%}
{#- Tunnel type: IPSec ~90%, SSLVPN ~10% -#}
{%- set tunnel_type = module.rand.weighted_choice(["IPSec", "SSL-VPN"], [90, 10]) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "globalprotect",
        "category": ["network"],
        "code": "gateway-getconfig",
        "dataset": "panw.panos",
        "duration": 0,
        "kind": "event",
        "module": "panw",
        "outcome": "success"
    },
    "host": {
        "id": "{{ machine.host_id }}",
        "ip": ["{{ private_ip }}"],
        "name": "{{ machine.hostname | lower }}",
        "os": {
            "family": "{{ platform.os | lower }}",
            "full": "{{ platform.os_version }}"
        }
    },
    "log": {
        "syslog": {
            "facility": {
                "code": 1,
                "name": "user-level"
            },
            "hostname": "{{ hostname }}",
            "priority": 14,
            "severity": {
                "code": 6,
                "name": "Informational"
            }
        }
    },
    "observer": {
        "hostname": "{{ hostname }}",
        "product": "PAN-OS",
        "serial_number": "{{ params.serial_number }}",
        "type": "firewall",
        "vendor": "Palo Alto Networks"
    },
    "panw": {
        "panos": {
            "action_flags": "0x0",
            "client_ver": "{{ platform.client_ver }}",
            "description": "Gateway config retrieved, tunnel type: {{ tunnel_type }}",
            "error_code": 0,
            "error_message": "",
            "event": {
                "id": "gateway-getconfig",
                "reason": "",
                "status": "success"
            },
            "generated_time": "{{ timestamp.isoformat() }}",
            "login_duration": 0,
            "machine": {
                "mac_address": "{{ machine.mac_address }}",
                "name": "{{ machine.hostname }}"
            },
            "portal": "{{ gw.name }}",
            "received_time": "{{ timestamp.isoformat() }}",
            "repeat_count": 1,
            "selection_type": "",
            "sequence_number": "{{ seq_num }}",
            "serial_number": "{{ params.serial_number }}",
            "stage": "configuration",
            "tunnel_type": "{{ tunnel_type }}",
            "type": "GLOBALPROTECT",
            "virtual_sys": "{{ params.virtual_sys }}"
        }
    },
    "related": {
        "hosts": ["{{ hostname }}", "{{ machine.hostname | lower }}"],
        "ip": ["{{ public_ip }}", "{{ private_ip }}"],
        "user": ["{{ user.username }}"]
    },
    "source": {
        "ip": "{{ private_ip }}",
        "nat": {
            "ip": "{{ public_ip }}"
        },
        "user": {
            "domain": "{{ params.domain }}",
            "name": "{{ user.username }}"
        }
    },
    "user": {
        "domain": "{{ params.domain }}",
        "name": "{{ user.username }}"
    }
}
{%- do shared.set('sequence_number', (seq_num + 1) % 2147483647) -%}