{%- set record_id = shared.get('record_id', 1) -%}
{#- Resolve vars -#}
{%- set direction = vars.traffic_direction -%}
{%- set is_cross_continent = vars.cross_continent -%}
{%- set outcome = vars.event_outcome -%}
{%- set action = vars.event_action -%}
{#- Internal site geo (from params) -#}
{%- set int_continent_code = params.get('internal_continent_code', 'NA') -%}
{%- set int_continent_name = params.get('internal_continent_name', 'North America') -%}
{%- set int_country_iso = params.get('internal_country_iso_code', 'US') -%}
{%- set int_country_name = params.get('internal_country_name', 'United States') -%}
{%- set int_region = params.get('internal_region_name', 'Virginia') -%}
{%- set int_city = params.get('internal_city_name', 'Ashburn') -%}
{%- set int_lat = params.get('internal_lat', 39.0438) -%}
{%- set int_lon = params.get('internal_lon', -77.4874) -%}
{%- set int_tz = params.get('internal_timezone', 'America/New_York') -%}
{#- Pick external geo location -#}
{%- if is_cross_continent -%}
  {#- Filter locations to other continents only -#}
  {%- set other_continent_locs = samples.geo_locations | rejectattr("continent_code", "equalto", int_continent_code) | list -%}
  {%- set ext_geo = other_continent_locs | random -%}
{%- else -%}
  {#- Same continent locations -#}
  {%- set same_continent_locs = samples.geo_locations | selectattr("continent_code", "equalto", int_continent_code) | list -%}
  {%- set ext_geo = same_continent_locs | random -%}
{%- endif -%}
{#- Pick a service -#}
{%- set service = samples.services.weighted_pick('weight') -%}
{#- Pick AS number for external endpoint -#}
{%- set ext_asn = samples.as_numbers.weighted_pick('weight') -%}
{#- Pick internal host -#}
{%- set int_host = samples.internal_hosts | random -%}
{#- Generate IPs and ports -#}
{%- if direction == "outbound" -%}
  {%- set src_ip = int_host.ip -%}
  {%- set src_port = module.rand.number.integer(49152, 65535) -%}
  {%- set dst_ip = module.rand.network.ip_v4_public() -%}
  {%- set dst_port = service.port if service.port > 0 else module.rand.number.integer(1024, 49151) -%}
  {%- set src_geo_continent_code = int_continent_code -%}
  {%- set src_geo_continent_name = int_continent_name -%}
  {%- set src_geo_country_iso = int_country_iso -%}
  {%- set src_geo_country_name = int_country_name -%}
  {%- set src_geo_region = int_region -%}
  {%- set src_geo_city = int_city -%}
  {%- set src_geo_lat = int_lat -%}
  {%- set src_geo_lon = int_lon -%}
  {%- set src_geo_tz = int_tz -%}
  {%- set dst_geo_continent_code = ext_geo.continent_code -%}
  {%- set dst_geo_continent_name = ext_geo.continent_name -%}
  {%- set dst_geo_country_iso = ext_geo.country_iso_code -%}
  {%- set dst_geo_country_name = ext_geo.country_name -%}
  {%- set dst_geo_region = ext_geo.region_name -%}
  {%- set dst_geo_city = ext_geo.city_name -%}
  {%- set dst_geo_lat = ext_geo.lat -%}
  {%- set dst_geo_lon = ext_geo.lon -%}
  {%- set dst_geo_tz = ext_geo.timezone -%}
  {%- set src_as_number = 0 -%}
  {%- set src_as_org = "" -%}
  {%- set dst_as_number = ext_asn.number -%}
  {%- set dst_as_org = ext_asn.name -%}
  {%- set net_direction = "outbound" -%}
{%- else -%}
  {%- set src_ip = module.rand.network.ip_v4_public() -%}
  {%- set src_port = module.rand.number.integer(49152, 65535) -%}
  {#- Inbound targets DMZ or servers -#}
  {%- set dmz_hosts = samples.internal_hosts | selectattr("subnet", "equalto", "dmz") | list -%}
  {%- set srv_hosts = samples.internal_hosts | selectattr("role", "equalto", "server") | list -%}
  {%- set target_host = (dmz_hosts + srv_hosts) | random -%}
  {%- set dst_ip = target_host.ip -%}
  {%- set dst_port = service.port if service.port > 0 else module.rand.number.integer(1024, 49151) -%}
  {%- set src_geo_continent_code = ext_geo.continent_code -%}
  {%- set src_geo_continent_name = ext_geo.continent_name -%}
  {%- set src_geo_country_iso = ext_geo.country_iso_code -%}
  {%- set src_geo_country_name = ext_geo.country_name -%}
  {%- set src_geo_region = ext_geo.region_name -%}
  {%- set src_geo_city = ext_geo.city_name -%}
  {%- set src_geo_lat = ext_geo.lat -%}
  {%- set src_geo_lon = ext_geo.lon -%}
  {%- set src_geo_tz = ext_geo.timezone -%}
  {%- set dst_geo_continent_code = int_continent_code -%}
  {%- set dst_geo_continent_name = int_continent_name -%}
  {%- set dst_geo_country_iso = int_country_iso -%}
  {%- set dst_geo_country_name = int_country_name -%}
  {%- set dst_geo_region = int_region -%}
  {%- set dst_geo_city = int_city -%}
  {%- set dst_geo_lat = int_lat -%}
  {%- set dst_geo_lon = int_lon -%}
  {%- set dst_geo_tz = int_tz -%}
  {%- set src_as_number = ext_asn.number -%}
  {%- set src_as_org = ext_asn.name -%}
  {%- set dst_as_number = 0 -%}
  {%- set dst_as_org = "" -%}
  {%- set net_direction = "inbound" -%}
{%- endif -%}
{#- Traffic metrics — use lognormal-like distribution via min/max ranges -#}
{%- set duration_ms = module.rand.number.integer(service.duration_ms_min, service.duration_ms_max) -%}
{%- if outcome == "failure" -%}
  {#- Denied connections transfer minimal data -#}
  {%- set src_bytes = module.rand.number.integer(40, 200) -%}
  {%- set dst_bytes = module.rand.number.integer(0, 60) -%}
  {%- set src_packets = module.rand.number.integer(1, 3) -%}
  {%- set dst_packets = module.rand.number.integer(0, 1) -%}
  {%- set duration_ms = module.rand.number.integer(0, 500) -%}
{%- else -%}
  {%- set src_bytes = module.rand.number.integer(service.bytes_min, service.bytes_max) -%}
  {%- set resp_ratio = module.rand.number.floating(1.5, 20.0) -%}
  {%- set dst_bytes_raw = (src_bytes * resp_ratio) | int -%}
  {%- set dst_bytes = dst_bytes_raw if dst_bytes_raw > 0 else 1 -%}
  {%- set src_packets = (src_bytes / module.rand.number.integer(500, 1500)) | int -%}
  {%- set src_packets = src_packets if src_packets > 0 else 1 -%}
  {%- set dst_packets = (dst_bytes / module.rand.number.integer(500, 1500)) | int -%}
  {%- set dst_packets = dst_packets if dst_packets > 0 else 1 -%}
{%- endif -%}
{#- Community ID and flow ID -#}
{%- set community_id = "1:" ~ module.rand.string.hex(20) -%}
{%- set flow_id = module.rand.string.hex(11) -%}
{#- IANA number for transport -#}
{%- set iana_number = "6" if service.protocol == "tcp" else "17" -%}
{#- Event type list -#}
{%- if outcome == "failure" -%}
  {%- set event_types = ["connection", "denied"] -%}
{%- else -%}
  {%- set event_types = ["connection", "allowed"] -%}
{%- endif -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.get('agent_id', 'b2c3d4e5-f6a7-8901-bcde-f01234567890') }}",
        "name": "{{ params.get('observer_hostname', 'gw-edge-01') }}",
        "type": "filebeat",
        "version": "{{ params.get('agent_version', '8.17.0') }}"
    },
    "data_stream": {
        "dataset": "network.geo_traffic",
        "namespace": "default",
        "type": "logs"
    },
    "destination": {
        {% if dst_as_number > 0 %}"as": {
            "number": {{ dst_as_number }},
            "organization": {
                "name": "{{ dst_as_org }}"
            }
        },
        {% endif %}"bytes": {{ dst_bytes }},
        "geo": {
            "city_name": "{{ dst_geo_city }}",
            "continent_code": "{{ dst_geo_continent_code }}",
            "continent_name": "{{ dst_geo_continent_name }}",
            "country_iso_code": "{{ dst_geo_country_iso }}",
            "country_name": "{{ dst_geo_country_name }}",
            "location": {
                "lat": {{ dst_geo_lat }},
                "lon": {{ dst_geo_lon }}
            },
            "region_name": "{{ dst_geo_region }}",
            "timezone": "{{ dst_geo_tz }}"
        },
        "ip": "{{ dst_ip }}",
        "packets": {{ dst_packets }},
        "port": {{ dst_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "{{ action }}",
        "category": ["network"],
        "dataset": "network.geo_traffic",
        "duration": {{ duration_ms * 1000000 }},
        "kind": "event",
        "module": "network",
        "outcome": "{{ outcome }}",
        "type": {{ event_types | tojson }}
    },
    "flow": {
        "id": "{{ flow_id }}"
    },
    "network": {
        "application": "{{ service.application }}",
        "bytes": {{ src_bytes + dst_bytes }},
        "community_id": "{{ community_id }}",
        "direction": "{{ net_direction }}",
        "iana_number": "{{ iana_number }}",
        "packets": {{ src_packets + dst_packets }},
        "transport": "{{ service.protocol }}",
        "type": "ipv4"
    },
    "observer": {
        "hostname": "{{ params.get('observer_hostname', 'gw-edge-01') }}",
        "ip": ["{{ params.get('observer_ip', '198.51.100.1') }}"],
        "name": "{{ params.get('observer_hostname', 'gw-edge-01') }}.{{ params.get('observer_domain', 'example.com') }}",
        "product": "Network Gateway",
        "type": "firewall",
        "vendor": "Generic"
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"]
    },
    "source": {
        {% if src_as_number > 0 %}"as": {
            "number": {{ src_as_number }},
            "organization": {
                "name": "{{ src_as_org }}"
            }
        },
        {% endif %}"bytes": {{ src_bytes }},
        "geo": {
            "city_name": "{{ src_geo_city }}",
            "continent_code": "{{ src_geo_continent_code }}",
            "continent_name": "{{ src_geo_continent_name }}",
            "country_iso_code": "{{ src_geo_country_iso }}",
            "country_name": "{{ src_geo_country_name }}",
            "location": {
                "lat": {{ src_geo_lat }},
                "lon": {{ src_geo_lon }}
            },
            "region_name": "{{ src_geo_region }}",
            "timezone": "{{ src_geo_tz }}"
        },
        "ip": "{{ src_ip }}",
        "packets": {{ src_packets }},
        "port": {{ src_port }}
    },
    "tags": ["geo-enriched", "forwarded"{% if is_cross_continent %}, "cross-continent"{% endif %}]
}
{%- do shared.set('record_id', (record_id + 1) % 2147483647) -%}