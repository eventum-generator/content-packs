{%- set seq_num = shared.get('sequence_number', 100000) -%}
{%- set flow_id = shared.get('flow_id', 500000) -%}
{%- set hostname = params.hostname -%}
{#- Drop action -#}
{%- set action = module.rand.weighted_choice(["drop", "drop-icmp"], [70, 30]) -%}
{#- Zone flow selection (weighted) — drops are more common on inbound -#}
{%- set flow_dir = module.rand.weighted_choice(["outbound", "inbound_dmz", "internal", "dmz_to_internal"], [30, 45, 15, 10]) -%}
{#- Derive zones, interfaces, NAT behavior, and IPs from flow direction -#}
{%- if flow_dir == "outbound" -%}
  {%- set src_zone = "trust" -%}
  {%- set dst_zone = "untrust" -%}
  {%- set ingress_if = "ethernet1/2" -%}
  {%- set egress_if = "ethernet1/1" -%}
  {%- set has_nat = false -%}
  {%- set src_host = samples.internal_hosts | random -%}
  {%- set src_ip = src_host.ip -%}
  {%- set dst_ip = module.rand.network.ip_v4_public() -%}
  {%- set dst_country = module.rand.weighted_choice(["United States", "Russia", "China", "Germany", "Netherlands", "Romania", "Brazil", "India", "Ukraine", "Vietnam"], [20, 15, 12, 10, 8, 8, 8, 7, 6, 6]) -%}
  {%- set src_country = params.src_network -%}
{%- elif flow_dir == "inbound_dmz" -%}
  {%- set src_zone = "untrust" -%}
  {%- set dst_zone = "dmz" -%}
  {%- set ingress_if = "ethernet1/1" -%}
  {%- set egress_if = "ethernet1/3" -%}
  {%- set has_nat = false -%}
  {%- set src_ip = module.rand.network.ip_v4_public() -%}
  {%- set srv = samples.server_hosts | random -%}
  {%- set dst_ip = srv.ip -%}
  {%- set src_country = module.rand.weighted_choice(["China", "Russia", "United States", "Germany", "Netherlands", "Romania", "Brazil", "India", "Ukraine", "Vietnam"], [20, 18, 12, 8, 8, 8, 7, 7, 6, 6]) -%}
  {%- set dst_country = params.src_network -%}
{%- elif flow_dir == "internal" -%}
  {%- set src_zone = "trust" -%}
  {%- set dst_zone = "trust" -%}
  {%- set ingress_if = "ethernet1/2" -%}
  {%- set egress_if = "ethernet1/2" -%}
  {%- set has_nat = false -%}
  {%- set src_host = samples.internal_hosts | random -%}
  {%- set src_ip = src_host.ip -%}
  {%- set srv = samples.server_hosts | random -%}
  {%- set dst_ip = srv.ip -%}
  {%- set src_country = params.src_network -%}
  {%- set dst_country = params.src_network -%}
{%- else -%}
  {%- set src_zone = "dmz" -%}
  {%- set dst_zone = "trust" -%}
  {%- set ingress_if = "ethernet1/3" -%}
  {%- set egress_if = "ethernet1/2" -%}
  {%- set has_nat = false -%}
  {%- set srv = samples.server_hosts | random -%}
  {%- set src_ip = srv.ip -%}
  {%- set dst_host = samples.internal_hosts | random -%}
  {%- set dst_ip = dst_host.ip -%}
  {%- set src_country = params.src_network -%}
  {%- set dst_country = params.src_network -%}
{%- endif -%}
{#- Application: drops typically have incomplete/insufficient/not-applicable -#}
{%- set drop_app = module.rand.weighted_choice(["incomplete", "insufficient-data", "not-applicable"], [50, 30, 20]) -%}
{%- set drop_app_items = [] -%}
{%- for a in samples.applications -%}
  {%- if a.name == drop_app -%}
    {%- do drop_app_items.append(a) -%}
  {%- endif -%}
{%- endfor -%}
{%- if drop_app_items | length > 0 -%}
  {%- set application = drop_app_items[0] -%}
{%- else -%}
  {%- set application = {"name": "incomplete", "port": 0, "protocol": "tcp", "category": "unknown", "subcategory": "unknown", "technology": "unknown", "risk": 1} -%}
{%- endif -%}
{%- set app_protocol = application.protocol -%}
{%- set dst_port = module.rand.number.integer(1, 65535) -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{#- Username -#}
{%- if src_zone == "trust" -%}
  {%- set username = (samples.usernames | random).username -%}
{%- else -%}
  {%- set username = "" -%}
{%- endif -%}
{#- Security rule — use Deny-All or any deny rule -#}
{%- set deny_rules = [] -%}
{%- set deny_weights = [] -%}
{%- for r in samples.security_rules -%}
  {%- if r.action == "deny" -%}
    {%- do deny_rules.append(r) -%}
    {%- do deny_weights.append(r.weight) -%}
  {%- endif -%}
{%- endfor -%}
{%- if deny_rules | length > 0 -%}
  {%- set rule = module.rand.weighted_choice(deny_rules, deny_weights) -%}
{%- else -%}
  {%- set rule = {"name": "Deny-All"} -%}
{%- endif -%}
{#- URL category -#}
{%- set url_cat = samples.url_categories.weighted_pick('weight') -%}
{#- Bytes: small for drops -#}
{%- set bytes_sent = module.rand.number.integer(60, 500) -%}
{%- set bytes_received = 0 -%}
{%- set total_bytes = bytes_sent -%}
{#- Packets: 1-3 for drops -#}
{%- set packets_sent = module.rand.number.integer(1, 3) -%}
{%- set packets_received = 0 -%}
{%- set total_packets = packets_sent -%}
{#- Session and community IDs -#}
{%- set session_id = flow_id -%}
{%- set community_id = "1:" ~ module.rand.string.hex(20) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ params.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "destination": {
        "bytes": {{ bytes_received }},
        "geo": {
            "name": "{{ dst_country }}"
        },
        "ip": "{{ dst_ip }}",
        "packets": {{ packets_received }},
        "port": {{ dst_port }}
    },
    "ecs": {
        "version": "8.17.0"
    },
    "event": {
        "action": "flow_dropped",
        "category": ["network"],
        "dataset": "panw.panos",
        "kind": "event",
        "module": "panw",
        "outcome": "failure",
        "type": ["connection", "denied"]
    },
    "host": {
        "name": "{{ hostname }}"
    },
    "labels": {
        "nat_translated": false
    },
    "log": {
        "level": "informational",
        "syslog": {
            "facility": {
                "code": 1,
                "name": "user-level"
            },
            "hostname": "{{ hostname }}",
            "priority": 14,
            "severity": {
                "code": 6,
                "name": "Informational"
            }
        }
    },
    "network": {
        "application": "{{ application.name }}",
        "bytes": {{ total_bytes }},
        "community_id": "{{ community_id }}",
        "direction": "{% if flow_dir == 'outbound' %}outbound{% elif flow_dir == 'inbound_dmz' %}inbound{% else %}internal{% endif %}",
        "packets": {{ total_packets }},
        "transport": "{{ app_protocol }}",
        "type": "ipv4"
    },
    "observer": {
        "egress": {
            "interface": {
                "name": "{{ egress_if }}"
            },
            "zone": "{{ dst_zone }}"
        },
        "hostname": "{{ hostname }}",
        "ingress": {
            "interface": {
                "name": "{{ ingress_if }}"
            },
            "zone": "{{ src_zone }}"
        },
        "product": "PAN-OS",
        "serial_number": "{{ params.serial_number }}",
        "type": "firewall",
        "vendor": "Palo Alto Networks"
    },
    "panw": {
        "panos": {
            "action": "{{ action }}",
            "action_flags": "0x0",
            "bytes_received": {{ bytes_received }},
            "bytes_sent": {{ bytes_sent }},
            "elapsed_time": 0,
            "flow_id": "{{ session_id }}",
            "generated_time": "{{ timestamp.isoformat() }}",
            "log_profile": "{{ params.log_profile }}",
            "nat": {
                "dst": {
                    "ip": "0.0.0.0",
                    "port": 0
                },
                "src": {
                    "ip": "0.0.0.0",
                    "port": 0
                }
            },
            "packets_received": {{ packets_received }},
            "packets_sent": {{ packets_sent }},
            "received_time": "{{ timestamp.isoformat() }}",
            "repeat_count": 1,
            "ruleset": "{{ rule.name }}",
            "sequence_number": "{{ seq_num }}",
            "session_flags": "0x0",
            "sub_type": "drop",
            "type": "TRAFFIC",
            "url": {
                "category": "{{ url_cat.category }}"
            },
            "virtual_sys": "{{ params.virtual_sys }}"
        }
    },
    "related": {
        "hosts": ["{{ hostname }}"],
        "ip": ["{{ src_ip }}", "{{ dst_ip }}"],
        "user": [{% if username %}"{{ username }}"{% endif %}]
    },
    "rule": {
        "name": "{{ rule.name }}"
    },
    "source": {
        "bytes": {{ bytes_sent }},
        "geo": {
            "name": "{{ src_country }}"
        },
        "ip": "{{ src_ip }}",
        "packets": {{ packets_sent }},
        "port": {{ src_port }},
        "user": {
            "domain": "{{ params.domain }}",
            "name": "{{ username }}"
        }
    },
    "user": {
        "domain": "{{ params.domain }}",
        "name": "{{ username }}"
    }
}
{%- do shared.set('sequence_number', (seq_num + 1) % 2147483647) -%}
{%- do shared.set('flow_id', (flow_id + 1) % 2147483647) -%}
