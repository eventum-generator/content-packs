{%- from 'templates/_base.json.jinja' import metadata_block -%}
{%- set offset = shared.get('offset', 0) -%}
{%- do shared.set('offset', offset + 1) -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.endpoint_users.pick() -%}
{%- set scenario = samples.detection_scenarios.pick() -%}
{%- set proc = samples.processes.pick() -%}
{%- set process_id = module.rand.number.integer(1000, 99999999) -%}
{%- set parent_process_id = module.rand.number.integer(1000, 99999999) -%}
{%- set epoch_sec = (timestamp.timestamp()) | int -%}
{%- set epoch_ms = (timestamp.timestamp() * 1000) | int -%}
{%- set start_offset = module.rand.number.integer(1, 300) -%}
{
    {{ metadata_block("EppDetectionSummaryEvent", params.customer_id, offset, timestamp) }},
    "event": {
        "ProcessStartTime": {{ epoch_sec - start_offset }},
        "ProcessEndTime": 0,
        "ProcessId": {{ process_id }},
        "ParentProcessId": {{ parent_process_id }},
        "Hostname": {{ host.hostname | tojson }},
        "UserName": {{ user.username | tojson }},
        "Name": {{ scenario.name | tojson }},
        "Description": {{ scenario.description | tojson }},
        "Severity": {{ scenario.severity }},
        "SeverityName": {{ scenario.severity_name | tojson }},
        "FileName": {{ proc.child.name | tojson }},
        "FilePath": {{ proc.child.path | tojson }},
        "CommandLine": {{ proc.child.command_line | tojson }},
        "SHA256String": {{ proc.child.sha256 | tojson }},
        "MD5String": {{ proc.child.md5 | tojson }},
        "SHA1String": {{ proc.child.sha1 | tojson }},
        "LogonDomain": {{ host.machine_domain | tojson }},
        "AgentId": {{ host.agent_id | tojson }},
        "CompositeId": "ldt:{{ host.agent_id }}:{{ process_id }}",
        "AggregateId": "aggr:{{ host.agent_id }}:{{ parent_process_id }}",
{%- if scenario.ioc_type %}
        "IOCType": {{ scenario.ioc_type | tojson }},
        "IOCValue": {{ scenario.ioc_value | tojson }},
{%- else %}
        "IOCType": "",
        "IOCValue": "",
{%- endif %}
        "LocalIP": {{ host.local_ip | tojson }},
        "MACAddress": {{ host.mac_address | tojson }},
        "Tactic": {{ scenario.tactic | tojson }},
        "Technique": {{ scenario.technique | tojson }},
        "Objective": {{ scenario.objective | tojson }},
        "PatternDispositionValue": {{ scenario.pattern_disposition_value }},
        "PatternDispositionDescription": {{ scenario.pattern_disposition_description | tojson }},
        "PatternDispositionFlags": {{ scenario.pattern_disposition_flags | tojson }},
        "DataDomains": {{ scenario.data_domains | tojson }},
        "GrandparentImageFileName": {{ proc.grandparent.path | tojson }},
        "GrandparentCommandLine": {{ proc.grandparent.command_line | tojson }},
        "ParentImageFileName": {{ proc.parent.path | tojson }},
        "ParentCommandLine": {{ proc.parent.command_line | tojson }}
{%- if module.rand.chance(0.2) %},
        "NetworkAccesses": [
            {
{%- set net_dest = samples.network_destinations.pick() %}
                "ConnectionDirection": {{ net_dest.direction }},
                "Protocol": {{ net_dest.protocol }},
                "LocalAddress": {{ host.local_ip | tojson }},
                "LocalPort": {{ module.rand.number.integer(49152, 65535) }},
                "RemoteAddress": {{ net_dest.ip | tojson }},
                "RemotePort": {{ net_dest.port }},
                "IsIPv6": false
            }
        ]
{%- endif %}
{%- if module.rand.chance(0.2) %},
        "DnsRequests": [
            {
{%- set dns_dest = samples.network_destinations.pick() %}
{%- if dns_dest.domain %}
                "DomainName": {{ dns_dest.domain | tojson }},
{%- else %}
                "DomainName": "unknown.local",
{%- endif %}
                "InterfaceIndex": 0,
                "CausedDetect": {{ module.rand.choice(["true", "false"]) }}
            }
        ]
{%- endif %}
    }
}