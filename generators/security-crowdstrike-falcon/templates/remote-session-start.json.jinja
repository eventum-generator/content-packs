{%- from 'templates/_base.json.jinja' import metadata_block -%}
{%- set offset = shared.get('offset', 0) -%}
{%- do shared.set('offset', offset + 1) -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.console_users.pick() -%}
{%- set session_id = module.rand.crypto.uuid4() -%}
{%- set epoch_sec = (timestamp.timestamp()) | int -%}
{#- Store session in shared state for later end event, bounded to 20 -#}
{%- set sessions = shared.get('sessions', []) -%}
{%- if sessions | length >= 20 -%}
    {%- do sessions.pop(0) -%}
{%- endif -%}
{%- do sessions.append({"session_id": session_id, "agent_id": host.agent_id, "hostname": host.hostname, "username": user.email, "start_timestamp": epoch_sec}) -%}
{%- do shared.set('sessions', sessions) -%}
{
    {{ metadata_block("RemoteResponseSessionStartEvent", params.customer_id, offset, timestamp) }},
    "event": {
        "AgentIdString": {{ host.agent_id | tojson }},
        "HostnameField": {{ host.hostname | tojson }},
        "SessionId": {{ session_id | tojson }},
        "UserName": {{ user.email | tojson }},
        "StartTimestamp": {{ epoch_sec }}
    }
}