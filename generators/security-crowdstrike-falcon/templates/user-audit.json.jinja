{%- from 'templates/_base.json.jinja' import metadata_block -%}
{%- set offset = shared.get('offset', 0) -%}
{%- do shared.set('offset', offset + 1) -%}
{%- set user = samples.console_users.pick() -%}
{%- set op = samples.user_operations.pick() -%}
{%- set user_ip = module.rand.network.ip_v4_public() -%}
{%- set epoch_ms = (timestamp.timestamp() * 1000) | int -%}
{#- Build audit key values with realistic substitutions -#}
{%- set target_user = samples.console_users.pick() -%}
{%- set target_host = samples.hosts.pick() -%}
{%- set roles = ["admin", "analyst", "responder"] -%}
{%- set policy_names = ["Default Detection Policy", "High Security Policy", "Server Policy", "Workstation Policy"] -%}
{%- set change_types = ["enabled", "disabled", "modified", "created"] -%}
{%- set ioc_types = ["sha256", "md5", "domain", "ipv4"] -%}
{%- set report_types = ["Weekly Summary", "Detection Report", "Host Activity", "Vulnerability Assessment"] -%}
{%- set exclusion_types = ["ml_exclusion", "ioa_exclusion", "sv_exclusion"] -%}
{%- set audit_keys = [] -%}
{%- for kv in op.audit_key_template -%}
    {%- set val = kv.ValueString | replace('{email}', target_user.email) | replace('{role}', module.rand.choice(roles)) | replace('{old_role}', module.rand.choice(roles)) | replace('{new_role}', module.rand.choice(roles)) | replace('{policy}', module.rand.choice(policy_names)) | replace('{change}', module.rand.choice(change_types)) | replace('{ioc_type}', module.rand.choice(ioc_types)) | replace('{ioc_value}', module.rand.string.hex(32)) | replace('{action}', module.rand.choice(["detect", "block", "allow"])) | replace('{group}', target_host.host_groups) | replace('{type}', module.rand.choice(exclusion_types)) | replace('{value}', 'C:\\Program Files\\*') | replace('{report_type}', module.rand.choice(report_types)) | replace('{host_id}', target_host.agent_id) -%}
    {%- do audit_keys.append({"Key": kv.Key, "ValueString": val}) -%}
{%- endfor -%}
{
    {{ metadata_block("UserActivityAuditEvent", params.customer_id, offset, timestamp) }},
    "event": {
        "UserId": {{ user.email | tojson }},
        "UserIp": {{ user_ip | tojson }},
        "OperationName": {{ op.operation_name | tojson }},
        "ServiceName": {{ op.service_name | tojson }},
        "AuditKeyValues": {{ audit_keys | tojson }},
        "UTCTimestamp": {{ epoch_ms }}
    }
}