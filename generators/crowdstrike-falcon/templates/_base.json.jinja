{#- Shared macros for CrowdStrike Falcon Event Stream events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import metadata_block %} -#}

{%- macro metadata_block(event_type, customer_id, offset, timestamp) -%}
    "metadata": {
        "customerIDString": {{ customer_id | tojson }},
        "offset": {{ offset }},
        "eventType": {{ event_type | tojson }},
        "eventCreationTime": {{ (timestamp.timestamp() * 1000) | int }},
        "version": "1.0"
    }
{%- endmacro -%}
