{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set ext_ip = samples.external_ips.pick().ip -%}
{%- set domain = samples.malicious_domains.pick().domain -%}
{#- TAA (Targeted Attack Analyzer) detection scenarios -#}
{%- set taa_rules = [
    {'name': 'Suspicious DNS request to newly registered domain', 'category': 'DNS Anomaly', 'severity': 'Medium', 'tactic': 'Command and Control'},
    {'name': 'Multiple failed authentication followed by success', 'category': 'Brute Force', 'severity': 'High', 'tactic': 'Credential Access'},
    {'name': 'Unusual outbound traffic volume from endpoint', 'category': 'Data Exfiltration', 'severity': 'High', 'tactic': 'Exfiltration'},
    {'name': 'Process injection detected via CreateRemoteThread', 'category': 'Process Injection', 'severity': 'High', 'tactic': 'Defense Evasion'},
    {'name': 'Lateral movement via PsExec-like behavior', 'category': 'Lateral Movement', 'severity': 'High', 'tactic': 'Lateral Movement'},
    {'name': 'Suspicious PowerShell execution with encoded command', 'category': 'Script Execution', 'severity': 'Medium', 'tactic': 'Execution'},
    {'name': 'Registry persistence mechanism created', 'category': 'Persistence', 'severity': 'Medium', 'tactic': 'Persistence'},
    {'name': 'Credential dumping tool activity detected', 'category': 'Credential Theft', 'severity': 'High', 'tactic': 'Credential Access'},
    {'name': 'Suspicious scheduled task creation', 'category': 'Persistence', 'severity': 'Medium', 'tactic': 'Persistence'},
    {'name': 'Anomalous SMB traffic pattern detected', 'category': 'Network Anomaly', 'severity': 'Medium', 'tactic': 'Lateral Movement'}
] -%}
{%- set rule = taa_rules | random -%}
{%- set severity_map = {'High': 4, 'Medium': 3, 'Low': 2} -%}
{%- set sev_num = severity_map.get(rule.severity, 3) -%}
{
    {{ event_base(["threat", "intrusion_detection"], ["info"], sev_num, "success", timestamp, params, "taaScanning") }},
    "kaspersky": {
        "kata": {
            "event_id": {{ next_event_id(shared) }},
            "detection_type": "taaScanning",
            "detection_name": "TAA has tripped on events database",
            "technology": "Targeted Attack Analyzer",
            "taa": {
                "rule_name": {{ rule.name | tojson }},
                "category": {{ rule.category | tojson }},
                "tactic": {{ rule.tactic | tojson }},
                "severity": {{ rule.severity | tojson }}
            },
            "sensor_id": {{ host.sensor_id | tojson }}
        }
    },
    "threat": {
        "tactic": {
            "name": [{{ rule.tactic | tojson }}]
        },
        "framework": "MITRE ATT&CK"
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "source": {
        "ip": {{ host.ip | tojson }}
    },
    "destination": {
        "ip": {{ ext_ip | tojson }},
        "domain": {{ domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}, {{ domain | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ ext_ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}