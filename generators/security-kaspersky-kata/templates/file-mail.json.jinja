{%- from 'templates/_base.json.jinja' import event_base, next_event_id, cef_header -%}
{%- set host = samples.hosts.pick() -%}
{%- set recipient = samples.users.pick() -%}
{%- set detection = samples.file_detections.pick() -%}
{%- set ext = detection.extensions | random -%}
{%- set tech = detection.technologies | random -%}
{%- set domain = samples.malicious_domains.pick().domain -%}
{%- set ext_ip = samples.external_ips.pick().ip -%}
{%- set sha256 = module.rand.string.hex(64) -%}
{%- set md5 = module.rand.string.hex(32) -%}
{%- set fname = module.rand.string.letters_lowercase(8) | lower ~ ext -%}
{%- set fsize = module.rand.number.lognormal(10, 2) | int -%}
{%- set severity_map = {'High': 4, 'Medium': 3, 'Low': 2} -%}
{%- set sev_num = severity_map.get(detection.severity, 3) -%}
{%- set subj_template = samples.mail_subjects.pick().subject -%}
{%- set subject = subj_template | replace('{num}', module.rand.number.integer(1000, 9999) | string) | replace('{quarter}', module.rand.number.integer(1, 4) | string) | replace('{name}', recipient.full_name) -%}
{%- set sender_name = module.rand.string.letters_lowercase(6) | lower -%}
{%- set sender_email = sender_name ~ '@' ~ domain -%}
{%- set message_id = '<' ~ module.rand.string.hex(16) ~ '@' ~ domain ~ '>' -%}
{%- set sandbox = samples.sandbox_verdicts.pick() -%}
{
    {{ event_base(["malware", "email"], ["info"], sev_num, "success", timestamp, params, "file_mail") }},
    "kaspersky": {
        "kata": {
            "event_id": {{ next_event_id(shared) }},
            "detection_type": "file_mail",
            "detection_name": "File from mail detected",
            "technology": {{ tech | tojson }},
            "threat": {
                "name": {{ detection.threat_name | tojson }},
                "category": {{ detection.category | tojson }},
                "severity": {{ detection.severity | tojson }}
            },
            "sensor_id": {{ host.sensor_id | tojson }},
            "sandbox": {
                "verdict": {{ sandbox.verdict | tojson }},
                "risk_score": {{ sandbox.risk_score }},
                "image": {{ sandbox.sandbox_image | tojson }}
            }
        }
    },
    "email": {
        "message_id": {{ message_id | tojson }},
        "subject": {{ subject | tojson }},
        "from": {
            "address": [{{ sender_email | tojson }}]
        },
        "to": {
            "address": [{{ recipient.email | tojson }}]
        },
        "attachments": [
            {
                "file": {
                    "name": {{ fname | tojson }},
                    "size": {{ fsize }},
                    "hash": {
                        "sha256": {{ sha256 | tojson }},
                        "md5": {{ md5 | tojson }}
                    }
                }
            }
        ]
    },
    "file": {
        "name": {{ fname | tojson }},
        "size": {{ fsize }},
        "type": {{ detection.file_type | tojson }},
        "hash": {
            "sha256": {{ sha256 | tojson }},
            "md5": {{ md5 | tojson }}
        }
    },
    "source": {
        "ip": {{ ext_ip | tojson }}
    },
    "destination": {
        "ip": {{ host.ip | tojson }}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}, {{ domain | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ ext_ip | tojson }}],
        "user": [{{ recipient.username | tojson }}, {{ sender_name | tojson }}],
        "hash": [{{ sha256 | tojson }}, {{ md5 | tojson }}]
    }
}