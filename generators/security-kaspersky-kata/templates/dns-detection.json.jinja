{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set detection = samples.dns_detections.pick() -%}
{%- set domain = samples.malicious_domains.pick().domain -%}
{%- set ext_ip = samples.external_ips.pick().ip -%}
{%- set severity_map = {'High': 4, 'Medium': 3, 'Low': 2} -%}
{%- set sev_num = severity_map.get(detection.severity, 3) -%}
{%- set tech = detection.technologies | random -%}
{%- set dns_server_ip = params.get('dns_server_ip', '10.1.1.10') -%}
{
    {{ event_base(["network", "threat"], ["info"], sev_num, "success", timestamp, params, "dns") }},
    "kaspersky": {
        "kata": {
            "event_id": {{ next_event_id(shared) }},
            "detection_type": "dns",
            "detection_name": "DNS request detected",
            "technology": {{ tech | tojson }},
            "threat": {
                "category": {{ detection.category | tojson }},
                "severity": {{ detection.severity | tojson }}
            },
            "sensor_id": {{ host.sensor_id | tojson }}
        }
    },
    "dns": {
        "question": {
            "name": {{ domain | tojson }},
            "type": {{ detection.dns_type | tojson }}
        },
        "resolved_ip": [{{ ext_ip | tojson }}],
        "type": "query"
    },
    "source": {
        "ip": {{ host.ip | tojson }},
        "port": {{ module.rand.number.integer(49152, 65535) }}
    },
    "destination": {
        "ip": {{ dns_server_ip | tojson }},
        "port": 53
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "network": {
        "transport": "udp",
        "protocol": "dns",
        "direction": "outbound"
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}, {{ domain | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ ext_ip | tojson }}, {{ dns_server_ip | tojson }}]
    }
}