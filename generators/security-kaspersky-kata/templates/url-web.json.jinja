{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set detection = samples.url_detections.pick() -%}
{%- set domain = samples.malicious_domains.pick().domain -%}
{%- set ext_ip = samples.external_ips.pick().ip -%}
{%- set severity_map = {'High': 4, 'Medium': 3, 'Low': 2} -%}
{%- set sev_num = severity_map.get(detection.severity, 3) -%}
{%- set tech = detection.technologies | random -%}
{%- set path_segment = module.rand.string.letters_lowercase(6) | lower -%}
{%- set filename = module.rand.string.letters_lowercase(8) | lower ~ module.rand.weighted_choice({'.exe': 30, '.zip': 25, '.js': 20, '.php': 15, '.html': 10}) -%}
{%- set url = detection.url_pattern | replace('{domain}', domain) | replace('{path}', path_segment) | replace('{filename}', filename) -%}
{%- set method = module.rand.weighted_choice({'GET': 70, 'POST': 25, 'HEAD': 5}) -%}
{%- set response_code = module.rand.weighted_choice({200: 50, 301: 15, 302: 10, 403: 10, 404: 10, 500: 5}) -%}
{%- set ua = module.rand.weighted_choice({
    'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36': 40,
    'Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:121.0) Gecko/20100101 Firefox/121.0': 25,
    'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Edge/120.0.0.0 Safari/537.36': 20,
    'curl/7.88.1': 10,
    'python-requests/2.31.0': 5
}) -%}
{
    {{ event_base(["web", "threat"], ["info"], sev_num, "success", timestamp, params, "url_web") }},
    "kaspersky": {
        "kata": {
            "event_id": {{ next_event_id(shared) }},
            "detection_type": "url_web",
            "detection_name": "URL from web detected",
            "technology": {{ tech | tojson }},
            "threat": {
                "category": {{ detection.category | tojson }},
                "severity": {{ detection.severity | tojson }}
            },
            "sensor_id": {{ host.sensor_id | tojson }}
        }
    },
    "url": {
        "original": {{ url | tojson }},
        "domain": {{ domain | tojson }},
        "scheme": {{ url.split('://')[0] | tojson }}
    },
    "http": {
        "request": {
            "method": {{ method | tojson }}
        },
        "response": {
            "status_code": {{ response_code }}
        }
    },
    "user_agent": {
        "original": {{ ua | tojson }}
    },
    "source": {
        "ip": {{ host.ip | tojson }},
        "port": {{ module.rand.number.integer(49152, 65535) }}
    },
    "destination": {
        "ip": {{ ext_ip | tojson }},
        "port": {{ module.rand.weighted_choice({80: 55, 443: 40, 8080: 5}) }},
        "domain": {{ domain | tojson }}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "network": {
        "transport": "tcp",
        "direction": "outbound"
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}, {{ domain | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ ext_ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}