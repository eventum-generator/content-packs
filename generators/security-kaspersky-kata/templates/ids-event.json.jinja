{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set rule = samples.ids_rules.pick() -%}
{%- set ext_ip = samples.external_ips.pick().ip -%}
{%- set severity_map = {'High': 4, 'Medium': 3, 'Low': 2} -%}
{%- set sev_num = severity_map.get(rule.severity, 3) -%}
{%- set is_inbound = module.rand.chance(0.75) -%}
{%- set src_ip = ext_ip if is_inbound else host.ip -%}
{%- set dst_ip = host.ip if is_inbound else ext_ip -%}
{%- set src_port = module.rand.number.integer(1024, 65535) -%}
{%- set dst_port = module.rand.weighted_choice({80: 20, 443: 25, 445: 15, 22: 10, 3389: 10, 8080: 5, 53: 10, 25: 5}) -%}
{
    {{ event_base(["intrusion_detection"], ["info"], sev_num, "success", timestamp, params, "ids") }},
    "kaspersky": {
        "kata": {
            "event_id": {{ next_event_id(shared) }},
            "detection_type": "ids",
            "detection_name": "IDS event detected",
            "technology": "IDS",
            "rule": {
                "id": {{ rule.rule_id | tojson }},
                "name": {{ rule.rule_name | tojson }},
                "category": {{ rule.category | tojson }}
            },
            "sensor_id": {{ host.sensor_id | tojson }}
        }
    },
    "source": {
        "ip": {{ src_ip | tojson }},
        "port": {{ src_port }}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ dst_port }}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "network": {
        "transport": {{ rule.protocol | lower | tojson }},
        "direction": {{ ("inbound" if is_inbound else "outbound") | tojson }}
    },
    "rule": {
        "id": {{ rule.rule_id | tojson }},
        "name": {{ rule.rule_name | tojson }},
        "category": {{ rule.category | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ src_ip | tojson }}, {{ dst_ip | tojson }}]
    }
}