{#- Shared macros for Kaspersky KATA (Anti Targeted Attack Platform) events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import event_base, next_event_id, cef_header %} -#}

{#- Base event envelope with common ECS fields -#}
{%- macro event_base(category, type, severity, outcome, ts, p, detection_type) -%}
    "@timestamp": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "event": {
        "kind": "alert",
        "module": "kaspersky",
        "dataset": "kaspersky.kata",
        "category": {{ category | tojson }},
        "type": {{ type | tojson }},
        "severity": {{ severity }},
        "outcome": {{ outcome | tojson }},
        "timezone": "UTC",
        "created": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
    },
    "observer": {
        "vendor": "Kaspersky",
        "product": "Anti Targeted Attack Platform",
        "version": {{ p.get('kata_version', '7.1.1.531') | tojson }},
        "hostname": {{ p.get('central_node', 'KATA-CN01') | tojson }},
        "ip": [{{ p.get('central_node_ip', '10.1.0.50') | tojson }}],
        "type": "ids"
    }
{%- endmacro -%}

{#- Monotonically increasing event ID via shared state -#}
{%- macro next_event_id(sh) -%}
{%- set eid = sh.get('kata_event_id', 100000) -%}
{%- do sh.set('kata_event_id', eid + 1) -%}
{{ eid }}
{%- endmacro -%}

{#- CEF header for raw syslog representation -#}
{%- macro cef_header(detection_type, event_name, severity, p) -%}
CEF:0|AO Kaspersky Lab|Kaspersky Anti Targeted Attack Platform|{{ p.get('kata_version', '7.1.1.531') }}|{{ detection_type }}|{{ event_name }}|{{ severity }}|
{%- endmacro -%}
