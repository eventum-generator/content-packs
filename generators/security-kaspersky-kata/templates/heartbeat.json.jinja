{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{#- KATA heartbeat — periodic component health status -#}
{%- set components = [
    {'name': 'Central Node', 'id': 'central_node'},
    {'name': 'Sandbox', 'id': 'sandbox'},
    {'name': 'Sensor', 'id': 'sensor'},
    {'name': 'Anti-Malware Engine', 'id': 'am_engine'},
    {'name': 'YARA Engine', 'id': 'yara_engine'},
    {'name': 'IDS Engine', 'id': 'ids_engine'},
    {'name': 'URL Reputation', 'id': 'url_reputation'},
    {'name': 'Targeted Attack Analyzer', 'id': 'taa'}
] -%}
{%- set comp = components | random -%}
{#- 95% healthy, 5% error -#}
{%- set is_healthy = module.rand.chance(0.95) -%}
{%- set state = 0 if is_healthy else module.rand.number.integer(1, 5) -%}
{
    "@timestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "event": {
        "kind": "event",
        "module": "kaspersky",
        "dataset": "kaspersky.kata",
        "category": ["host"],
        "type": ["info"],
        "severity": 0,
        "outcome": {{ ("success" if is_healthy else "failure") | tojson }},
        "timezone": "UTC",
        "created": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
    },
    "observer": {
        "vendor": "Kaspersky",
        "product": "Anti Targeted Attack Platform",
        "version": {{ params.get('kata_version', '7.1.1.531') | tojson }},
        "hostname": {{ params.get('central_node', 'KATA-CN01') | tojson }},
        "ip": [{{ params.get('central_node_ip', '10.1.0.50') | tojson }}],
        "type": "ids"
    },
    "kaspersky": {
        "kata": {
            "event_id": {{ next_event_id(shared) }},
            "detection_type": "heartbeat",
            "detection_name": "Periodic state message",
            "component": {
                "name": {{ comp.name | tojson }},
                "id": {{ comp.id | tojson }},
                "state": {{ state }},
                "status": {{ ("OK" if is_healthy else "Error") | tojson }}
            }
        }
    },
    "host": {
        "hostname": {{ params.get('central_node', 'KATA-CN01') | tojson }},
        "ip": [{{ params.get('central_node_ip', '10.1.0.50') | tojson }}]
    },
    "related": {
        "hosts": [{{ params.get('central_node', 'KATA-CN01') | tojson }}],
        "ip": [{{ params.get('central_node_ip', '10.1.0.50') | tojson }}]
    }
}