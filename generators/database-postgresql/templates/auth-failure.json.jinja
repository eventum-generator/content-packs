{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set fail_user = module.rand.weighted_choice(["postgres", "admin", "root", "app_user", "test", "backup"], [20, 25, 15, 15, 15, 10]) -%}
{%- set db_name = module.rand.weighted_choice(["app_production", "postgres", "template1", "nonexistent_db"], [40, 30, 10, 20]) -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_public(), module.rand.network.ip_v4_private_c(), module.rand.network.ip_v4_private_b()], [50, 30, 20]) -%}
{%- set src_port = module.rand.number.integer(32768, 61000) -%}
{%- set fail_reason = module.rand.weighted_choice(["password authentication failed", "no pg_hba.conf entry", "role does not exist", "database does not exist"], [50, 20, 20, 10]) -%}
{%- if fail_reason == "password authentication failed" -%}
  {%- set detail = 'password authentication failed for user \\"' ~ fail_user ~ '\\"' -%}
  {%- set severity = "FATAL" -%}
{%- elif fail_reason == "no pg_hba.conf entry" -%}
  {%- set detail = "no pg_hba.conf entry for host \\\"" ~ src_ip ~ "\\\", user \\\"" ~ fail_user ~ "\\\", database \\\"" ~ db_name ~ "\\\", no encryption" -%}
  {%- set severity = "FATAL" -%}
{%- elif fail_reason == "role does not exist" -%}
  {%- set detail = 'role \\"' ~ fail_user ~ '\\" does not exist' -%}
  {%- set severity = "FATAL" -%}
{%- else -%}
  {%- set detail = 'database \\"' ~ db_name ~ '\\" does not exist' -%}
  {%- set severity = "FATAL" -%}
{%- endif -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "event": {
        "action": "authentication_failure",
        "category": ["database", "authentication"],
        "dataset": "postgresql.log",
        "kind": "event",
        "module": "postgresql",
        "outcome": "failure",
        "sequence": {{ seq }},
        "type": ["connection", "denied"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "kernel": "{{ host.os_kernel }}",
            "name": "{{ host.os_name }}",
            "platform": "{{ host.os_platform }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "log": {
        "level": "{{ severity }}"
    },
    "message": "{{ detail }}",
    "postgresql": {
        "log": {
            "connection_from": "{{ src_ip }}:{{ src_port }}",
            "database": "{{ db_name }}",
            "timestamp": "{{ timestamp.strftime('%Y-%m-%d %H:%M:%S.%f') }} UTC"
        }
    },
    "process": {
        "pid": {{ pid }}
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ fail_user }}"]
    },
    "server": {
        "address": "{{ host.ip }}",
        "port": {{ host.pg_port }}
    },
    "service": {
        "type": "postgresql"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "user": {
        "name": "{{ fail_user }}"
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}