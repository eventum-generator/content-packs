{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{#- Try to use a correlated connection -#}
{%- set conn_pool = shared.get('connections:' ~ hostname, []) -%}
{%- if conn_pool | length > 0 -%}
  {%- set conn = conn_pool.pop(0) -%}
  {%- do shared.set('connections:' ~ hostname, conn_pool) -%}
  {%- set username = conn.user -%}
  {%- set db_name = conn.db -%}
  {%- set pid = conn.pid -%}
  {%- set src_ip = conn.src_ip -%}
  {%- set src_port = conn.src_port -%}
{%- else -%}
  {%- set user = samples.users | random -%}
  {%- set username = user.username -%}
  {%- set db_entry = samples.databases | random -%}
  {%- set db_name = db_entry.name -%}
  {%- set pid = module.rand.number.integer(1000, 65535) -%}
  {%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_private_c(), module.rand.network.ip_v4_private_b(), "127.0.0.1"], [45, 40, 15]) -%}
  {%- set src_port = module.rand.number.integer(32768, 61000) -%}
{%- endif -%}
{%- set session_seconds = module.rand.weighted_choice([module.rand.number.integer(1, 30), module.rand.number.integer(30, 300), module.rand.number.integer(300, 3600), module.rand.number.integer(3600, 86400)], [30, 40, 20, 10]) -%}
{%- set session_h = session_seconds // 3600 -%}
{%- set session_m = (session_seconds % 3600) // 60 -%}
{%- set session_s = session_seconds % 60 -%}
{%- set session_ms = module.rand.number.integer(0, 999) -%}
{%- set session_time = "%02d:%02d:%02d.%03d" | format(session_h, session_m, session_s, session_ms) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "event": {
        "action": "disconnection",
        "category": ["database", "network"],
        "dataset": "postgresql.log",
        "kind": "event",
        "module": "postgresql",
        "outcome": "success",
        "sequence": {{ seq }},
        "type": ["connection", "end"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "kernel": "{{ host.os_kernel }}",
            "name": "{{ host.os_name }}",
            "platform": "{{ host.os_platform }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "log": {
        "level": "LOG"
    },
    "message": "disconnection: session time: {{ session_time }} user={{ username }} database={{ db_name }} host={{ src_ip }} port={{ src_port }}",
    "postgresql": {
        "log": {
            "connection_from": "{{ src_ip }}:{{ src_port }}",
            "database": "{{ db_name }}",
            "session_time_seconds": {{ session_seconds }},
            "timestamp": "{{ timestamp.strftime('%Y-%m-%d %H:%M:%S.%f') }} UTC"
        }
    },
    "process": {
        "pid": {{ pid }}
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ username }}"]
    },
    "server": {
        "address": "{{ host.ip }}",
        "port": {{ host.pg_port }}
    },
    "service": {
        "type": "postgresql"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "user": {
        "name": "{{ username }}"
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}