{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set user = module.rand.weighted_choice(samples.users | selectattr('role_type', 'equalto', 'application') | list + samples.users | selectattr('role_type', 'equalto', 'developer') | list, None) -%}
{%- set db_entry = samples.databases | random -%}
{%- set db_name = db_entry.name -%}
{%- set schema_name = db_entry.schema -%}
{%- set table = samples.tables | selectattr('schema', 'equalto', schema_name) | list -%}
{%- if table | length > 0 -%}
  {%- set tbl = table | random -%}
{%- else -%}
  {%- set tbl = samples.tables | random -%}
{%- endif -%}
{%- set query_entry = samples.queries_insert | random -%}
{%- set stmt = query_entry.stmt | replace('{schema}', tbl.schema) | replace('{table}', tbl.name) -%}
{%- set params_val = query_entry.params -%}
{%- set stmt_id = module.rand.number.integer(1, 500) -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set duration_ms = module.rand.weighted_choice([module.rand.number.floating(0.5, 5.0), module.rand.number.floating(5.0, 30.0), module.rand.number.floating(30.0, 200.0)], [55, 35, 10]) -%}
{%- set rows = module.rand.weighted_choice([1, module.rand.number.integer(2, 10), module.rand.number.integer(10, 100)], [75, 20, 5]) -%}
{%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_private_c(), module.rand.network.ip_v4_private_b(), "127.0.0.1"], [50, 40, 10]) -%}
{%- set src_port = module.rand.number.integer(32768, 61000) -%}
{%- set audit_line = "AUDIT: SESSION," ~ stmt_id ~ ",1,WRITE,INSERT,,," ~ stmt ~ "," ~ params_val -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "event": {
        "action": "INSERT",
        "category": ["database"],
        "dataset": "postgresql.log",
        "duration": {{ (duration_ms * 1000000) | int }},
        "kind": "event",
        "module": "postgresql",
        "outcome": "success",
        "sequence": {{ seq }},
        "type": ["change"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "kernel": "{{ host.os_kernel }}",
            "name": "{{ host.os_name }}",
            "platform": "{{ host.os_platform }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "log": {
        "level": "LOG"
    },
    "message": "{{ audit_line }}",
    "postgresql": {
        "log": {
            "database": "{{ db_name }}",
            "query": "{{ stmt }}",
            "query_name": "INSERT",
            "rows_affected": {{ rows }},
            "timestamp": "{{ timestamp.strftime('%Y-%m-%d %H:%M:%S.%f') }} UTC"
        }
    },
    "process": {
        "pid": {{ pid }}
    },
    "related": {
        "ip": ["{{ src_ip }}"],
        "user": ["{{ user.username }}"]
    },
    "server": {
        "address": "{{ host.ip }}",
        "port": {{ host.pg_port }}
    },
    "service": {
        "type": "postgresql"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "user": {
        "name": "{{ user.username }}"
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}