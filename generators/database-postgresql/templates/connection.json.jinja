{%- set host = samples.hosts | random -%}
{%- set hostname = host.name -%}
{%- set seq = shared.get('sequence:' ~ hostname, 1000) -%}
{%- set user = samples.users | random -%}
{%- set db_entry = samples.databases | random -%}
{%- set db_name = db_entry.name -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set src_ip = module.rand.weighted_choice([module.rand.network.ip_v4_private_c(), module.rand.network.ip_v4_private_b(), "127.0.0.1"], [45, 40, 15]) -%}
{%- set src_port = module.rand.number.integer(32768, 61000) -%}
{%- set auth_method = module.rand.weighted_choice(["md5", "scram-sha-256", "trust", "peer"], [30, 50, 10, 10]) -%}
{%- set app_name = user.app_name -%}
{#- Store connection for disconnection correlation -#}
{%- set conn_pool = shared.get('connections:' ~ hostname, []) -%}
{%- do conn_pool.append({"user": user.username, "db": db_name, "pid": pid, "src_ip": src_ip, "src_port": src_port, "app_name": app_name}) -%}
{%- if conn_pool | length > 100 -%}{%- do conn_pool.pop(0) -%}{%- endif -%}
{%- do shared.set('connections:' ~ hostname, conn_pool) -%}
{
    "@timestamp": "{{ timestamp.isoformat() }}",
    "agent": {
        "ephemeral_id": "{{ module.rand.crypto.uuid4() }}",
        "id": "{{ host.agent_id }}",
        "name": "{{ hostname }}",
        "type": "filebeat",
        "version": "{{ params.agent_version }}"
    },
    "ecs": {
        "version": "8.11.0"
    },
    "event": {
        "action": "connection_authorized",
        "category": ["database", "network"],
        "dataset": "postgresql.log",
        "kind": "event",
        "module": "postgresql",
        "outcome": "success",
        "sequence": {{ seq }},
        "type": ["connection", "start"]
    },
    "host": {
        "hostname": "{{ hostname }}",
        "ip": ["{{ host.ip }}"],
        "mac": ["{{ host.mac }}"],
        "name": "{{ hostname }}",
        "os": {
            "family": "linux",
            "kernel": "{{ host.os_kernel }}",
            "name": "{{ host.os_name }}",
            "platform": "{{ host.os_platform }}",
            "type": "linux",
            "version": "{{ host.os_version }}"
        }
    },
    "log": {
        "level": "LOG"
    },
    "message": "connection authorized: user={{ user.username }} database={{ db_name }} application_name={{ app_name }} SSL enabled (protocol=TLSv1.3, cipher=TLS_AES_256_GCM_SHA384, bits=256)",
    "postgresql": {
        "log": {
            "application_name": "{{ app_name }}",
            "connection_from": "{{ src_ip }}:{{ src_port }}",
            "database": "{{ db_name }}",
            "timestamp": "{{ timestamp.strftime('%Y-%m-%d %H:%M:%S.%f') }} UTC"
        }
    },
    "process": {
        "pid": {{ pid }}
    },
    "related": {
        "ip": ["{{ src_ip }}", "{{ host.ip }}"],
        "user": ["{{ user.username }}"]
    },
    "server": {
        "address": "{{ host.ip }}",
        "port": {{ host.pg_port }}
    },
    "service": {
        "type": "postgresql"
    },
    "source": {
        "address": "{{ src_ip }}",
        "ip": "{{ src_ip }}",
        "port": {{ src_port }}
    },
    "user": {
        "name": "{{ user.username }}"
    }
}
{%- do shared.set('sequence:' ~ hostname, (seq + 1) % 2147483647) -%}