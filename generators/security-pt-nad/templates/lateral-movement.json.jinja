{#- PT NAD lateral movement detection — east/west traffic between internal hosts -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id, mitre_block -%}
{%- set src_host = samples.hosts.pick() -%}
{%- set dst_host = samples.hosts.pick() -%}
{#- Ensure different hosts -#}
{%- if src_host.hostname == dst_host.hostname -%}
{%- set dst_host = samples.hosts.pick() -%}
{%- endif -%}
{%- set user = samples.users.pick() -%}
{%- set lateral_techniques = [
    {"name": "PsExec Remote Execution", "protocol": "smb", "port": 445, "tactic": "TA0008", "tactic_name": "Lateral Movement", "technique": "T1570", "technique_name": "Lateral Tool Transfer", "severity": 4},
    {"name": "WMI Remote Execution", "protocol": "dcerpc", "port": 135, "tactic": "TA0002", "tactic_name": "Execution", "technique": "T1047", "technique_name": "Windows Management Instrumentation", "severity": 4},
    {"name": "Remote Desktop Connection to Server", "protocol": "rdp", "port": 3389, "tactic": "TA0008", "tactic_name": "Lateral Movement", "technique": "T1021.001", "technique_name": "Remote Desktop Protocol", "severity": 3},
    {"name": "SMB Admin Share Access (C$ or ADMIN$)", "protocol": "smb", "port": 445, "tactic": "TA0008", "tactic_name": "Lateral Movement", "technique": "T1021.002", "technique_name": "SMB/Windows Admin Shares", "severity": 3},
    {"name": "SSH Connection Between Internal Hosts", "protocol": "ssh", "port": 22, "tactic": "TA0008", "tactic_name": "Lateral Movement", "technique": "T1021.004", "technique_name": "SSH", "severity": 3},
    {"name": "WinRM Remote PowerShell Session", "protocol": "http", "port": 5985, "tactic": "TA0008", "tactic_name": "Lateral Movement", "technique": "T1021.006", "technique_name": "Windows Remote Management", "severity": 4}
] -%}
{%- set technique = lateral_techniques | random -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{%- set bytes_sent = module.rand.number.lognormal(9, 2) | int -%}
{%- set bytes_recv = module.rand.number.lognormal(8, 2) | int -%}
{
    {{ event_base("alert", ["network", "intrusion_detection"], ["info"], technique.severity, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "lateral_movement",
        "detection_method": "behavioral_analysis",
        "lateral": {
            "technique_name": {{ technique.name | tojson }},
            "protocol": {{ technique.protocol | tojson }}
        },
        "app_protocol": {{ technique.protocol | tojson }},
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ src_host.ip | tojson }},
        "port": {{ src_port }},
        "bytes": {{ bytes_sent }},
        "address": {{ src_host.hostname | lower | tojson }}
    },
    "destination": {
        "ip": {{ dst_host.ip | tojson }},
        "port": {{ technique.port }},
        "bytes": {{ bytes_recv }},
        "address": {{ dst_host.hostname | lower | tojson }}
    },
    "host": {
        "hostname": {{ src_host.hostname | tojson }},
        "ip": [{{ src_host.ip | tojson }}],
        "os": {
            "name": {{ src_host.os | tojson }},
            "version": {{ src_host.os_version | tojson }}
        },
        "domain": {{ src_host.domain | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "network": {
        "transport": "tcp",
        "protocol": {{ technique.protocol | tojson }},
        "direction": "internal",
        "bytes": {{ bytes_sent + bytes_recv }}
    },
    {{ mitre_block(technique.tactic, technique.tactic_name, technique.technique, technique.technique_name) }},
    "related": {
        "hosts": [{{ src_host.hostname | tojson }}, {{ dst_host.hostname | tojson }}],
        "ip": [{{ src_host.ip | tojson }}, {{ dst_host.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}