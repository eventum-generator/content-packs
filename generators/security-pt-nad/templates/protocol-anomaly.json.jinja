{#- PT NAD protocol anomaly — traffic not matching expected protocol behavior -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set ext = samples.external_ips.pick() -%}
{%- set anomalies = [
    {"name": "Non-standard HTTP on Port 443", "expected": "tls", "actual": "http", "port": 443, "severity": 3},
    {"name": "DNS over Non-standard Port", "expected": "dns", "actual": "dns", "port": 5353, "severity": 2},
    {"name": "SSH on Non-standard Port", "expected": "ssh", "actual": "ssh", "port": 2222, "severity": 2},
    {"name": "Encrypted Traffic on HTTP Port", "expected": "http", "actual": "tls", "port": 80, "severity": 3},
    {"name": "Non-standard Protocol on HTTPS Port", "expected": "tls", "actual": "unknown", "port": 443, "severity": 4},
    {"name": "IRC Protocol Detected", "expected": "http", "actual": "irc", "port": 8080, "severity": 4},
    {"name": "Tor Traffic Detected", "expected": "tls", "actual": "tor", "port": 9001, "severity": 4},
    {"name": "SOCKS Proxy Protocol Detected", "expected": "http", "actual": "socks5", "port": 1080, "severity": 3}
] -%}
{%- set anomaly = anomalies | random -%}
{%- set is_outbound = module.rand.chance(0.7) -%}
{%- set src_ip = host.ip if is_outbound else ext.ip -%}
{%- set dst_ip = ext.ip if is_outbound else host.ip -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set bytes_sent = module.rand.number.lognormal(8, 2) | int -%}
{%- set bytes_recv = module.rand.number.lognormal(9, 2) | int -%}
{
    {{ event_base("alert", ["network"], ["info"], anomaly.severity, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "protocol_anomaly",
        "detection_method": "deep_inspection",
        "anomaly": {
            "name": {{ anomaly.name | tojson }},
            "expected_protocol": {{ anomaly.expected | tojson }},
            "actual_protocol": {{ anomaly.actual | tojson }},
            "port": {{ anomaly.port }}
        },
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ src_ip | tojson }},
        "port": {{ src_port }},
        "bytes": {{ bytes_sent }}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ anomaly.port }},
        "bytes": {{ bytes_recv }}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "network": {
        "transport": "tcp",
        "protocol": {{ anomaly.actual | tojson }},
        "direction": {{ ("outbound" if is_outbound else "inbound") | tojson }},
        "bytes": {{ bytes_sent + bytes_recv }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ src_ip | tojson }}, {{ dst_ip | tojson }}]
    }
}