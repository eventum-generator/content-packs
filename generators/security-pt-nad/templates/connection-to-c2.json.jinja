{#- PT NAD C2 communication detection — outbound connection to known command-and-control -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id, mitre_block -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set ioc = samples.reputation_indicators.pick() -%}
{%- set ext = samples.external_ips.pick() -%}
{%- set c2_protocols = [
    {"name": "HTTP Beacon", "protocol": "http", "port": 80, "interval_s": module.rand.number.integer(30, 300), "jitter_pct": module.rand.number.integer(5, 30)},
    {"name": "HTTPS Beacon", "protocol": "tls", "port": 443, "interval_s": module.rand.number.integer(60, 600), "jitter_pct": module.rand.number.integer(10, 40)},
    {"name": "DNS C2 Channel", "protocol": "dns", "port": 53, "interval_s": module.rand.number.integer(10, 60), "jitter_pct": module.rand.number.integer(5, 20)},
    {"name": "HTTPS Reverse Shell", "protocol": "tls", "port": 8443, "interval_s": module.rand.number.integer(5, 30), "jitter_pct": module.rand.number.integer(0, 10)}
] -%}
{%- set c2 = c2_protocols | random -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{%- set bytes_out = module.rand.number.lognormal(7, 1.5) | int -%}
{%- set bytes_in = module.rand.number.lognormal(8, 2) | int -%}
{%- set beacon_count = module.rand.number.integer(3, 50) -%}
{
    {{ event_base("alert", ["network", "intrusion_detection"], ["info"], 5, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "c2_communication",
        "detection_method": "behavioral_analysis",
        "c2": {
            "channel_type": {{ c2.name | tojson }},
            "beacon_interval_s": {{ c2.interval_s }},
            "jitter_pct": {{ c2.jitter_pct }},
            "beacon_count": {{ beacon_count }},
            "protocol": {{ c2.protocol | tojson }}
        },
        "threat_name": {{ ioc.threat_name | tojson }},
        "app_protocol": {{ c2.protocol | tojson }},
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ host.ip | tojson }},
        "port": {{ src_port }},
        "bytes": {{ bytes_out }}
    },
    "destination": {
        "ip": {{ ext.ip | tojson }},
        "port": {{ c2.port }},
        "bytes": {{ bytes_in }},
        "geo": {
            "country_iso_code": {{ ext.geo_country | tojson }},
            "city_name": {{ ext.geo_city | tojson }}
        },
        "as": {
            "number": {{ ext.asn }},
            "organization": { "name": {{ ext.org | tojson }} }
        }
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "network": {
        "transport": {{ ("udp" if c2.protocol == "dns" else "tcp") | tojson }},
        "protocol": {{ c2.protocol | tojson }},
        "direction": "outbound",
        "bytes": {{ bytes_out + bytes_in }}
    },
    {{ mitre_block("TA0011", "Command and Control", "T1071", "Application Layer Protocol") }},
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ ext.ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}