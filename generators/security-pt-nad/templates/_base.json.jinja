{#- Shared macros for PT Network Attack Discovery (PT NAD) events -#}
{#- Import with: {% from 'templates/_base.json.jinja' import event_base, next_event_id, session_id %} -#}

{#- Base event envelope with common ECS fields -#}
{%- macro event_base(kind, category, type, severity, outcome, ts, p) -%}
    "@timestamp": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "event": {
        "kind": {{ kind | tojson }},
        "module": "pt_nad",
        "dataset": "pt_nad.alert",
        "category": {{ category | tojson }},
        "type": {{ type | tojson }},
        "severity": {{ severity }},
        "outcome": {{ outcome | tojson }},
        "timezone": "UTC",
        "created": "{{ ts.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
    },
    "observer": {
        "vendor": "Positive Technologies",
        "product": "Network Attack Discovery",
        "version": {{ p.get('nad_version', '12.1.0.1234') | tojson }},
        "hostname": {{ p.get('sensor_name', 'PT-NAD-01') | tojson }},
        "ip": [{{ p.get('sensor_ip', '10.1.0.100') | tojson }}],
        "type": "ids"
    }
{%- endmacro -%}

{#- Monotonically increasing event ID via shared state -#}
{%- macro next_event_id(sh) -%}
{%- set eid = sh.get('nad_event_id', 1000000) -%}
{%- do sh.set('nad_event_id', eid + 1) -%}
{{ eid }}
{%- endmacro -%}

{#- Generate a unique session ID -#}
{%- macro session_id(sh) -%}
{%- set sid = sh.get('nad_session_id', 5000000) -%}
{%- do sh.set('nad_session_id', sid + module.rand.number.integer(1, 10)) -%}
{{ sid }}
{%- endmacro -%}

{#- MITRE ATT&CK block -#}
{%- macro mitre_block(tactic_id, tactic_name, technique_id, technique_name) -%}
    "threat": {
        "framework": "MITRE ATT&CK",
        "tactic": {
            "id": [{{ tactic_id | tojson }}],
            "name": [{{ tactic_name | tojson }}]
        },
        "technique": {
            "id": [{{ technique_id | tojson }}],
            "name": [{{ technique_name | tojson }}]
        }
    }
{%- endmacro -%}

{#- Network direction from internal/external IPs -#}
{%- macro net_direction(src_ip, internal_subnet) -%}
{%- if src_ip.startswith(internal_subnet) -%}outbound{%- else -%}inbound{%- endif -%}
{%- endmacro -%}
