{#- PT NAD reputation/IOC match alert — threat intelligence indicator triggered -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set ioc = samples.reputation_indicators.pick() -%}
{%- set ext = samples.external_ips.pick() -%}
{%- set is_inbound = module.rand.chance(0.5) -%}
{%- if ioc.indicator_type == "ip" -%}
{%- set malicious_ip = ioc.indicator -%}
{%- set src_ip = malicious_ip if is_inbound else host.ip -%}
{%- set dst_ip = host.ip if is_inbound else malicious_ip -%}
{%- else -%}
{%- set src_ip = ext.ip if is_inbound else host.ip -%}
{%- set dst_ip = host.ip if is_inbound else ext.ip -%}
{%- endif -%}
{%- set src_port = module.rand.number.integer(1024, 65535) -%}
{%- set dst_port = module.rand.weighted_choice({80: 20, 443: 40, 8080: 10, 53: 15, 445: 10, 25: 5}) -%}
{%- set direction = "inbound" if is_inbound else "outbound" -%}
{%- set sev_num = 4 if ioc.confidence >= 90 else 3 -%}
{
    {{ event_base("alert", ["network", "threat"], ["indicator"], sev_num, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "reputation",
        "detection_method": "threat_intelligence",
        "indicator": {
            "type": {{ ioc.indicator_type | tojson }},
            "value": {{ ioc.indicator | tojson }},
            "confidence": {{ ioc.confidence }},
            "feed": {{ ioc.feed | tojson }}
        },
        "threat_name": {{ ioc.threat_name | tojson }},
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ src_ip | tojson }},
        "port": {{ src_port }}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ dst_port }}
    },
{%- if ioc.indicator_type == "domain" %}
    "dns": {
        "question": {
            "name": {{ ioc.indicator | tojson }},
            "type": "A"
        }
    },
{%- endif %}
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "network": {
        "transport": "tcp",
        "direction": {{ direction | tojson }}
    },
    "threat": {
        "indicator": {
            "type": {{ ioc.indicator_type | tojson }},
            "description": {{ ioc.threat_name | tojson }},
            "confidence": {{ ioc.confidence }},
            "provider": {{ ioc.feed | tojson }}
{%- if ioc.indicator_type == "ip" %},
            "ip": {{ ioc.indicator | tojson }}
{%- elif ioc.indicator_type == "domain" %},
            "url": {
                "domain": {{ ioc.indicator | tojson }}
            }
{%- endif %}
        }
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}{% if ioc.indicator_type == "domain" %}, {{ ioc.indicator | tojson }}{% endif %}],
        "ip": [{{ src_ip | tojson }}, {{ dst_ip | tojson }}]
    }
}