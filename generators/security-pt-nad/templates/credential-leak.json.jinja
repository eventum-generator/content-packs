{#- PT NAD credential leak detection — cleartext credentials in network traffic -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id, mitre_block -%}
{%- set host = samples.hosts.pick() -%}
{%- set user = samples.users.pick() -%}
{%- set leak_types = [
    {"protocol": "ftp", "port": 21, "description": "FTP login credentials transmitted in plain text"},
    {"protocol": "telnet", "port": 23, "description": "Telnet session with cleartext authentication"},
    {"protocol": "http", "port": 80, "description": "HTTP Basic authentication credentials in plain text"},
    {"protocol": "pop3", "port": 110, "description": "POP3 mailbox credentials transmitted unencrypted"},
    {"protocol": "imap", "port": 143, "description": "IMAP mailbox credentials transmitted unencrypted"},
    {"protocol": "smtp", "port": 25, "description": "SMTP authentication credentials in plain text"},
    {"protocol": "ldap", "port": 389, "description": "LDAP simple bind with cleartext password"}
] -%}
{%- set leak = leak_types | random -%}
{%- set dst_ip = module.rand.weighted_choice({"10.1.2.20": 20, "10.1.6.10": 20, "10.1.3.10": 15, "10.1.1.10": 15, "10.1.4.15": 15, "10.1.5.10": 15}) -%}
{%- set src_port = module.rand.number.integer(49152, 65535) -%}
{
    {{ event_base("alert", ["network", "intrusion_detection"], ["info"], 3, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "credential_leak",
        "detection_method": "deep_inspection",
        "credential": {
            "protocol": {{ leak.protocol | tojson }},
            "description": {{ leak.description | tojson }},
            "username_detected": true,
            "password_detected": true
        },
        "app_protocol": {{ leak.protocol | tojson }},
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ host.ip | tojson }},
        "port": {{ src_port }}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ leak.port }}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "user": {
        "name": {{ user.username | tojson }},
        "domain": {{ user.domain | tojson }}
    },
    "network": {
        "transport": "tcp",
        "protocol": {{ leak.protocol | tojson }},
        "direction": "internal"
    },
    {{ mitre_block("TA0006", "Credential Access", "T1040", "Network Sniffing") }},
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ host.ip | tojson }}, {{ dst_ip | tojson }}],
        "user": [{{ user.username | tojson }}]
    }
}