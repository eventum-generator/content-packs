{#- PT NAD suspicious activity detection — behavioral/anomaly-based -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id, mitre_block -%}
{%- set host = samples.hosts.pick() -%}
{%- set activity = samples.suspicious_activities.pick() -%}
{%- set ext = samples.external_ips.pick() -%}
{%- set severity_map = {'critical': 5, 'high': 4, 'medium': 3, 'low': 2} -%}
{%- set sev_num = severity_map.get(activity.severity, 3) -%}
{%- set proto = activity.protocols | random -%}
{%- set is_outbound = module.rand.chance(0.65) -%}
{%- set src_ip = host.ip if is_outbound else ext.ip -%}
{%- set dst_ip = ext.ip if is_outbound else host.ip -%}
{%- set src_port = module.rand.number.integer(1024, 65535) -%}
{%- set dst_port = module.rand.number.integer(1, 65535) -%}
{%- set direction = "outbound" if is_outbound else "inbound" -%}
{%- set session_count = module.rand.number.integer(1, 50) -%}
{
    {{ event_base("alert", ["network", "intrusion_detection"], ["info"], sev_num, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "suspicious_activity",
        "detection_method": "behavioral_analysis",
        "activity": {
            "type": {{ activity.activity_type | tojson }},
            "name": {{ activity.name | tojson }},
            "description": {{ activity.description | tojson }}
        },
        "app_protocol": {{ proto | tojson }},
        "session_count": {{ session_count }},
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ src_ip | tojson }},
        "port": {{ src_port }}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ dst_port }}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
{%- if activity.mitre_tactic is defined %}
    {{ mitre_block(activity.mitre_tactic, activity.mitre_tactic_name, activity.mitre_technique, activity.mitre_technique_name) }},
{%- endif %}
    "network": {
        "transport": {{ ("udp" if proto in ["dns", "dhcp", "ntp", "snmp", "socks5", "llmnr", "icmp", "udp"] else "tcp") | tojson }},
        "protocol": {{ proto | tojson }},
        "direction": {{ direction | tojson }}
    },
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ src_ip | tojson }}, {{ dst_ip | tojson }}]
    }
}