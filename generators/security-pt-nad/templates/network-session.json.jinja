{#- PT NAD network session metadata — parsed protocol session record -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id -%}
{%- set host = samples.hosts.pick() -%}
{%- set proto_info = samples.protocols.pick() -%}
{%- set ext = samples.external_ips.pick() -%}
{%- set is_outbound = module.rand.chance(0.55) -%}
{%- set src_ip = host.ip if is_outbound else ext.ip -%}
{%- set dst_ip = ext.ip if is_outbound else host.ip -%}
{%- set src_port = module.rand.number.integer(32768, 65535) -%}
{%- set dst_port = proto_info.default_port -%}
{%- set direction = "outbound" if is_outbound else "inbound" -%}
{%- set bytes_sent = module.rand.number.lognormal(8, 2) | int -%}
{%- set bytes_recv = module.rand.number.lognormal(10, 2) | int -%}
{%- set pkts_sent = module.rand.number.integer(3, 200) -%}
{%- set pkts_recv = module.rand.number.integer(3, 500) -%}
{%- set duration_s = module.rand.number.exponential(15) | round(3) -%}
{%- set start_time = timestamp - module.datetime.timedelta(seconds=duration_s) -%}
{%- set cid_input = (src_ip ~ ":" ~ (src_port | string) ~ "<>" ~ dst_ip ~ ":" ~ (dst_port | string) ~ "/" ~ proto_info.transport).encode() -%}
{%- set community_id = "1:" ~ module.base64.b64encode(module.hashlib.sha1(cid_input).digest()).decode() -%}
{
    {{ event_base("event", ["network"], ["connection", "end"], 1, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "session",
        "app_protocol": {{ proto_info.name | lower | tojson }},
        "protocol_layer": {{ proto_info.layer }},
        "session": {
            "id": {{ module.rand.number.integer(10000000, 99999999) }},
            "duration": {{ duration_s }}
        },
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }}
    },
    "source": {
        "ip": {{ src_ip | tojson }},
        "port": {{ src_port }},
        "bytes": {{ bytes_sent }},
        "packets": {{ pkts_sent }}
{%- if is_outbound %},
        "address": {{ host.hostname | lower | tojson }}
{%- endif %}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ dst_port }},
        "bytes": {{ bytes_recv }},
        "packets": {{ pkts_recv }}
{%- if not is_outbound %},
        "address": {{ host.hostname | lower | tojson }}
{%- endif %}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "network": {
        "transport": {{ proto_info.transport | tojson }},
        "protocol": {{ proto_info.name | lower | tojson }},
        "direction": {{ direction | tojson }},
        "bytes": {{ bytes_sent + bytes_recv }},
        "packets": {{ pkts_sent + pkts_recv }},
        "community_id": {{ community_id | tojson }}
    },
    "event": {
        "kind": "event",
        "module": "pt_nad",
        "dataset": "pt_nad.session",
        "category": ["network"],
        "type": ["connection", "end"],
        "severity": 1,
        "duration": {{ (duration_s * 1000000000) | int }},
        "start": "{{ start_time.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
        "end": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
    },
    "related": {
        "ip": [{{ src_ip | tojson }}, {{ dst_ip | tojson }}]
    }
}