{#- PT NAD attack detection alert — rule-based threat detection -#}
{%- from 'templates/_base.json.jinja' import event_base, next_event_id, mitre_block, net_direction -%}
{%- set host = samples.hosts.pick() -%}
{%- set rule = samples.attack_rules.pick() -%}
{%- set ext = samples.external_ips.pick() -%}
{%- set severity_map = {'critical': 5, 'high': 4, 'medium': 3, 'low': 2} -%}
{%- set sev_num = severity_map.get(rule.severity, 3) -%}
{%- set is_inbound = module.rand.chance(0.6) -%}
{%- set src_ip = ext.ip if is_inbound else host.ip -%}
{%- set dst_ip = host.ip if is_inbound else ext.ip -%}
{%- set src_port = module.rand.number.integer(1024, 65535) -%}
{%- set dst_port = rule.port if rule.port > 0 else module.rand.number.integer(1, 1024) -%}
{%- set direction = "inbound" if is_inbound else "outbound" -%}
{%- set action = module.rand.weighted_choice({"allowed": 40, "denied": 60}) -%}
{%- set bytes_sent = module.rand.number.lognormal(8, 2) | int -%}
{%- set bytes_recv = module.rand.number.lognormal(9, 2) | int -%}
{%- set pkts_sent = module.rand.number.integer(3, 200) -%}
{%- set pkts_recv = module.rand.number.integer(3, 500) -%}
{
    {{ event_base("alert", ["network", "intrusion_detection"], [action], sev_num, "success", timestamp, params) }},
    "pt_nad": {
        "event_id": {{ next_event_id(shared) }},
        "detection_type": "attack",
        "detection_method": "rules",
        "rule": {
            "id": {{ rule.rule_id | tojson }},
            "name": {{ rule.rule_name | tojson }},
            "category": {{ rule.category | tojson }},
            "severity": {{ rule.severity | tojson }}
        },
        "app_protocol": {{ rule.app_protocol | tojson }},
        "sensor": {{ params.get('sensor_name', 'PT-NAD-01') | tojson }},
        "activity_id": {{ module.rand.number.integer(100000, 999999) }}
    },
    "source": {
        "ip": {{ src_ip | tojson }},
        "port": {{ src_port }},
        "bytes": {{ bytes_sent }},
        "packets": {{ pkts_sent }}
{%- if not is_inbound %},
        "geo": {
            "country_iso_code": {{ ext.geo_country | tojson }},
            "city_name": {{ ext.geo_city | tojson }}
        },
        "as": {
            "number": {{ ext.asn }},
            "organization": { "name": {{ ext.org | tojson }} }
        }
{%- endif %}
    },
    "destination": {
        "ip": {{ dst_ip | tojson }},
        "port": {{ dst_port }},
        "bytes": {{ bytes_recv }},
        "packets": {{ pkts_recv }}
{%- if is_inbound %},
        "geo": {
            "country_iso_code": {{ ext.geo_country | tojson }},
            "city_name": {{ ext.geo_city | tojson }}
        },
        "as": {
            "number": {{ ext.asn }},
            "organization": { "name": {{ ext.org | tojson }} }
        }
{%- endif %}
    },
    "host": {
        "hostname": {{ host.hostname | tojson }},
        "ip": [{{ host.ip | tojson }}],
        "mac": [{{ host.mac | tojson }}],
        "os": {
            "name": {{ host.os | tojson }},
            "version": {{ host.os_version | tojson }}
        },
        "domain": {{ host.domain | tojson }}
    },
    "network": {
        "transport": {{ rule.protocol | tojson }},
        "protocol": {{ rule.app_protocol | tojson }},
        "direction": {{ direction | tojson }},
        "bytes": {{ bytes_sent + bytes_recv }},
        "packets": {{ pkts_sent + pkts_recv }}
    },
    "rule": {
        "id": {{ rule.rule_id | tojson }},
        "name": {{ rule.rule_name | tojson }},
        "category": {{ rule.category | tojson }}
    },
    {{ mitre_block(rule.mitre_tactic, rule.mitre_tactic_name, rule.mitre_technique, rule.mitre_technique_name) }},
    "related": {
        "hosts": [{{ host.hostname | tojson }}],
        "ip": [{{ src_ip | tojson }}, {{ dst_ip | tojson }}]
    }
}