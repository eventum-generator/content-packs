{%- set host = samples.hosts.pick() -%}
{%- set fqdn = host.name ~ '.' ~ params.fqdn_suffix -%}
{%- set proc = samples.processes.pick() -%}
{%- set pid = module.rand.number.integer(1000, 65535) -%}
{%- set report_id = shared.get('report_id:' ~ host.device_id, 1000) -%}
{%- do shared.set('report_id:' ~ host.device_id, report_id + 1) -%}
{#- Determine account based on integrity level -#}
{%- if proc.integrity_level == "System" -%}
  {%- set acct_domain = "NT AUTHORITY" -%}
  {%- set acct_name = "system" -%}
  {%- set acct_sid = "S-1-5-18" -%}
  {%- set acct_upn = "" -%}
  {%- set acct_oid = "00000000-0000-0000-0000-000000000000" -%}
  {%- set token_elevation = "TokenElevationTypeDefault" -%}
{%- elif proc.integrity_level == "High" -%}
  {%- set user = samples.usernames.pick() -%}
  {%- if user.username.startswith("svc-") or user.username == "system" or user.username == "local service" or user.username == "network service" -%}
    {%- set user = samples.usernames.pick() -%}
  {%- endif -%}
  {%- set acct_domain = params.domain -%}
  {%- set acct_name = user.username -%}
  {%- set acct_sid = user.sid -%}
  {%- set acct_upn = user.upn -%}
  {%- set acct_oid = user.object_id -%}
  {%- set token_elevation = "TokenElevationTypeFull" -%}
{%- else -%}
  {%- set user = samples.usernames.pick() -%}
  {%- if user.username == "system" or user.username == "local service" or user.username == "network service" -%}
    {%- set user = samples.usernames.pick() -%}
  {%- endif -%}
  {%- set acct_domain = params.domain -%}
  {%- set acct_name = user.username -%}
  {%- set acct_sid = user.sid -%}
  {%- set acct_upn = user.upn -%}
  {%- set acct_oid = user.object_id -%}
  {%- set token_elevation = "TokenElevationTypeLimited" -%}
{%- endif -%}
{%- set logon_id = module.rand.number.integer(1000000, 9999999) -%}
{#- Pick an initiating process from pool or sample -#}
{%- set proc_pool = shared.get('proc_pool:' ~ host.device_id, []) -%}
{%- if proc_pool | length > 0 -%}
  {%- set iproc = proc_pool | random -%}
{%- else -%}
  {%- set iproc = samples.processes.pick() -%}
{%- endif -%}
{%- set iproc_pid = module.rand.number.integer(1000, 65535) -%}
{%- set iproc_creation = (timestamp - module.datetime.timedelta(seconds=module.rand.number.integer(60, 86400))).strftime('%Y-%m-%dT%H:%M:%S.%f') ~ 'Z' -%}
{%- set iproc_parent_pid = module.rand.number.integer(1000, 65535) -%}
{%- set iproc_parent_creation = (timestamp - module.datetime.timedelta(days=module.rand.number.integer(1, 7))).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] ~ 'Z' -%}
{#- Store new process in shared pool for correlation -#}
{%- do proc_pool.append({"name": proc.name, "path": proc.path, "command_line": proc.command_line, "sha1": proc.sha1, "sha256": proc.sha256, "md5": proc.md5, "file_size": proc.file_size, "company": proc.company, "product": proc.product, "product_version": proc.product_version, "internal_name": proc.internal_name, "original_file_name": proc.original_file_name, "description": proc.description, "signer_type": proc.signer_type, "signature_status": proc.signature_status, "integrity_level": proc.integrity_level, "parent_name": proc.parent_name, "pid": pid}) -%}
{%- if proc_pool | length > 100 -%}{%- do proc_pool.pop(0) -%}{%- endif -%}
{%- do shared.set('proc_pool:' ~ host.device_id, proc_pool) -%}
{
  "Tenant": {{ params.tenant | tojson }},
  "category": "AdvancedHunting-DeviceProcessEvents",
  "operationName": "Publish",
  "properties": {
    "Timestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f') }}Z",
    "DeviceId": "{{ host.device_id }}",
    "DeviceName": "{{ fqdn }}",
    "ActionType": "ProcessCreated",
    "FileName": {{ proc.name | tojson }},
    "FolderPath": {{ proc.path | tojson }},
    "SHA1": "{{ proc.sha1 }}",
    "SHA256": "{{ proc.sha256 }}",
    "MD5": "{{ proc.md5 }}",
    "FileSize": {{ proc.file_size }},
    "ProcessVersionInfoCompanyName": {{ proc.company | tojson }},
    "ProcessVersionInfoProductName": {{ proc.product | tojson }},
    "ProcessVersionInfoProductVersion": "{{ proc.product_version }}",
    "ProcessVersionInfoInternalFileName": {{ proc.internal_name | tojson }},
    "ProcessVersionInfoOriginalFileName": {{ proc.original_file_name | tojson }},
    "ProcessVersionInfoFileDescription": {{ proc.description | tojson }},
    "ProcessId": {{ pid }},
    "ProcessCommandLine": {{ proc.command_line | tojson }},
    "ProcessIntegrityLevel": "{{ proc.integrity_level }}",
    "ProcessTokenElevation": "{{ token_elevation }}",
    "ProcessCreationTime": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f') }}Z",
    "AccountDomain": {{ acct_domain | tojson }},
    "AccountName": {{ acct_name | tojson }},
    "AccountSid": "{{ acct_sid }}",
    "AccountUpn": "{{ acct_upn }}",
    "AccountObjectId": "{{ acct_oid }}",
    "LogonId": {{ logon_id }},
    "InitiatingProcessAccountDomain": {{ acct_domain | tojson }},
    "InitiatingProcessAccountName": {{ acct_name | tojson }},
    "InitiatingProcessAccountSid": "{{ acct_sid }}",
    "InitiatingProcessAccountUpn": "{{ acct_upn }}",
    "InitiatingProcessAccountObjectId": "{{ acct_oid }}",
    "InitiatingProcessLogonId": {{ logon_id }},
    "InitiatingProcessIntegrityLevel": "{{ iproc.integrity_level }}",
    "InitiatingProcessTokenElevation": "{{ token_elevation }}",
    "InitiatingProcessSHA1": "{{ iproc.sha1 }}",
    "InitiatingProcessSHA256": "{{ iproc.sha256 }}",
    "InitiatingProcessMD5": "{{ iproc.md5 }}",
    "InitiatingProcessFileName": {{ iproc.name | tojson }},
    "InitiatingProcessFileSize": {{ iproc.file_size }},
    "InitiatingProcessFolderPath": {{ iproc.path | tojson }},
    "InitiatingProcessId": {{ iproc_pid }},
    "InitiatingProcessCommandLine": {{ iproc.command_line | tojson }},
    "InitiatingProcessCreationTime": "{{ iproc_creation }}",
    "InitiatingProcessParentFileName": {{ iproc.parent_name | tojson }},
    "InitiatingProcessParentId": {{ iproc_parent_pid }},
    "InitiatingProcessParentCreationTime": "{{ iproc_parent_creation }}",
    "InitiatingProcessSignerType": "{{ iproc.signer_type }}",
    "InitiatingProcessSignatureStatus": "{{ iproc.signature_status }}",
    "InitiatingProcessVersionInfoCompanyName": {{ iproc.company | tojson }},
    "InitiatingProcessVersionInfoProductName": {{ iproc.product | tojson }},
    "InitiatingProcessVersionInfoProductVersion": "{{ iproc.product_version }}",
    "InitiatingProcessVersionInfoInternalFileName": {{ iproc.internal_name | tojson }},
    "InitiatingProcessVersionInfoOriginalFileName": {{ iproc.original_file_name | tojson }},
    "InitiatingProcessVersionInfoFileDescription": {{ iproc.description | tojson }},
    "IsInitiatingProcessRemoteSession": false,
    "InitiatingProcessRemoteSessionDeviceName": null,
    "InitiatingProcessRemoteSessionIP": null,
    "CreatedProcessSessionId": null,
    "IsProcessRemoteSession": false,
    "ProcessRemoteSessionDeviceName": null,
    "ProcessRemoteSessionIP": null,
    "ReportId": {{ report_id }},
    "AppGuardContainerId": null,
    "MachineGroup": "{{ host.machine_group }}",
    "AdditionalFields": null
  },
  "tenantId": "{{ params.tenant_id }}",
  "time": "{{ (timestamp + module.datetime.timedelta(seconds=module.rand.number.integer(60, 300))).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
}