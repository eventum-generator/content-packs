{%- set host = samples.hosts.pick() -%}
{%- set fqdn = host.name ~ '.' ~ params.fqdn_suffix -%}
{%- set report_id = shared.get('report_id:' ~ host.device_id, 1000) -%}
{%- do shared.set('report_id:' ~ host.device_id, report_id + 1) -%}
{%- set action_type = module.rand.weighted_choice({"LogonSuccess": 85, "LogonFailed": 15}) -%}
{%- set logon_type = module.rand.weighted_choice({"Network": 40, "Interactive": 25, "RemoteInteractive": 15, "Service": 12, "Batch": 8}) -%}
{%- set user = samples.usernames.pick() -%}
{%- if user.username == "system" or user.username == "local service" or user.username == "network service" -%}
  {%- set user = samples.usernames.pick() -%}
{%- endif -%}
{%- set logon_acct_domain = params.domain -%}
{%- set logon_acct_name = user.username -%}
{%- set logon_acct_sid = user.sid -%}
{%- set is_local_admin = user.is_admin -%}
{%- set protocol = module.rand.weighted_choice({"Negotiate": 40, "Kerberos": 35, "NTLM": 20, "": 5}) -%}
{%- set logon_id = module.rand.number.integer(1000000, 9999999) -%}
{#- Remote device info -#}
{%- set remote_host = samples.hosts.pick() -%}
{%- set remote_ip = module.rand.network.ip_v4_private_c() -%}
{%- set remote_port = module.rand.number.integer(49152, 65535) -%}
{%- if logon_type == "Interactive" -%}
  {%- set remote_device = "" -%}
  {%- set remote_ip_val = "" -%}
  {%- set remote_ip_type = "" -%}
  {%- set remote_port_val = 0 -%}
  {%- set is_local = true -%}
{%- else -%}
  {%- set remote_device = remote_host.name ~ '.' ~ params.fqdn_suffix -%}
  {%- set remote_ip_val = remote_ip -%}
  {%- set remote_ip_type = "Private" -%}
  {%- set remote_port_val = remote_port -%}
  {%- set is_local = false -%}
{%- endif -%}
{#- Failure reason for failed logons -#}
{%- if action_type == "LogonFailed" -%}
  {%- set failure_reason = module.rand.choice(["InvalidUserNameOrPassword", "AccountLockedOrDisabled", "ExpiredPassword", "OldPassword"]) -%}
{%- else -%}
  {%- set failure_reason = None -%}
{%- endif -%}
{#- Initiating process (lsass.exe for logon events) -#}
{%- set iproc = samples.processes.pick() -%}
{%- set iproc_user = samples.usernames.pick() -%}
{%- if iproc_user.username == "system" or iproc_user.username == "local service" or iproc_user.username == "network service" -%}
  {%- set iproc_user = samples.usernames.pick() -%}
{%- endif -%}
{%- set iproc_pid = module.rand.number.integer(1000, 65535) -%}
{%- set iproc_creation = (timestamp - module.datetime.timedelta(seconds=module.rand.number.integer(3600, 86400))).strftime('%Y-%m-%dT%H:%M:%S.%f') ~ 'Z' -%}
{%- set iproc_parent_pid = module.rand.number.integer(1000, 65535) -%}
{%- set iproc_parent_creation = (timestamp - module.datetime.timedelta(days=module.rand.number.integer(1, 7))).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] ~ 'Z' -%}
{
  "Tenant": {{ params.tenant | tojson }},
  "category": "AdvancedHunting-DeviceLogonEvents",
  "operationName": "Publish",
  "properties": {
    "Timestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f') }}Z",
    "DeviceId": "{{ host.device_id }}",
    "DeviceName": "{{ fqdn }}",
    "ActionType": "{{ action_type }}",
    "LogonType": "{{ logon_type }}",
    "AccountDomain": {{ logon_acct_domain | tojson }},
    "AccountName": {{ logon_acct_name | tojson }},
    "AccountSid": "{{ logon_acct_sid }}",
    "Protocol": "{{ protocol }}",
    "FailureReason": {{ failure_reason | tojson }},
    "IsLocalAdmin": {{ is_local_admin | lower }},
    "LogonId": {{ logon_id }},
    "RemoteDeviceName": "{{ remote_device }}",
    "RemoteIP": "{{ remote_ip_val }}",
    "RemoteIPType": "{{ remote_ip_type }}",
    "RemotePort": {{ remote_port_val }},
    "InitiatingProcessAccountDomain": {{ params.domain | tojson }},
    "InitiatingProcessAccountName": {{ iproc_user.username | tojson }},
    "InitiatingProcessAccountSid": "{{ iproc_user.sid }}",
    "InitiatingProcessAccountUpn": "{{ iproc_user.upn }}",
    "InitiatingProcessAccountObjectId": "{{ iproc_user.object_id }}",
    "InitiatingProcessLogonId": {{ module.rand.number.integer(1000000, 9999999) }},
    "InitiatingProcessIntegrityLevel": "{{ iproc.integrity_level }}",
    "InitiatingProcessTokenElevation": "TokenElevationTypeDefault",
    "InitiatingProcessSHA1": "{{ iproc.sha1 }}",
    "InitiatingProcessSHA256": "{{ iproc.sha256 }}",
    "InitiatingProcessMD5": "{{ iproc.md5 }}",
    "InitiatingProcessFileName": {{ iproc.name | tojson }},
    "InitiatingProcessFileSize": {{ iproc.file_size }},
    "InitiatingProcessFolderPath": {{ iproc.path | tojson }},
    "InitiatingProcessId": {{ iproc_pid }},
    "InitiatingProcessCommandLine": {{ iproc.command_line | tojson }},
    "InitiatingProcessCreationTime": "{{ iproc_creation }}",
    "InitiatingProcessParentFileName": {{ iproc.parent_name | tojson }},
    "InitiatingProcessParentId": {{ iproc_parent_pid }},
    "InitiatingProcessParentCreationTime": "{{ iproc_parent_creation }}",
    "InitiatingProcessSignerType": "{{ iproc.signer_type }}",
    "InitiatingProcessSignatureStatus": "{{ iproc.signature_status }}",
    "InitiatingProcessVersionInfoCompanyName": {{ iproc.company | tojson }},
    "InitiatingProcessVersionInfoProductName": {{ iproc.product | tojson }},
    "InitiatingProcessVersionInfoProductVersion": "{{ iproc.product_version }}",
    "InitiatingProcessVersionInfoInternalFileName": {{ iproc.internal_name | tojson }},
    "InitiatingProcessVersionInfoOriginalFileName": {{ iproc.original_file_name | tojson }},
    "InitiatingProcessVersionInfoFileDescription": {{ iproc.description | tojson }},
    "ReportId": {{ report_id }},
    "AppGuardContainerId": null,
    "MachineGroup": "{{ host.machine_group }}",
    "AdditionalFields": "{\"IsLocalLogon\": {{ is_local | lower }}}"
  },
  "tenantId": "{{ params.tenant_id }}",
  "time": "{{ (timestamp + module.datetime.timedelta(seconds=module.rand.number.integer(60, 300))).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
}