{%- set alert = samples.alert_profiles.pick() -%}
{%- set host = samples.hosts.pick() -%}
{%- set alert_suffix = module.rand.number.integer(100000000, 999999999) -%}
{
  "Tenant": {{ params.tenant | tojson }},
  "category": "AdvancedHunting-AlertInfo",
  "operationName": "Publish",
  "properties": {
    "Timestamp": "{{ timestamp.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z",
    "AlertId": "{{ alert.alert_id_prefix }}_{{ alert_suffix }}",
    "Title": {{ alert.title | tojson }},
    "Category": "{{ alert.category }}",
    "Severity": "{{ alert.severity }}",
    "ServiceSource": {{ alert.service_source | tojson }},
    "DetectionSource": "{{ alert.detection_source }}",
    "AttackTechniques": {{ alert.attack_techniques | tojson }},
    "MachineGroup": null
  },
  "tenantId": "{{ params.tenant_id }}",
  "time": "{{ (timestamp + module.datetime.timedelta(seconds=module.rand.number.integer(60, 300))).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] }}Z"
}